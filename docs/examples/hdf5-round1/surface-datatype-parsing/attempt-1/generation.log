ursively introspect a datatype, honouring API preconditions. */\nstatic void introspect_type(hid_t type_id, int depth)\n{\n    if (depth >= MAX_DEPTH)\n        return;\n    if (type_id < 0)\n        return;\n\n    /* Always valid for any type */\n    H5T_class_t cls  = H5Tget_class(type_id);\n    size_t       sz  = H5Tget_size(type_id);\n    (void)sz;\n\n    switch (cls) {\n\n    case H5T_COMPOUND: {\n        int nmembers = H5Tget_nmembers(type_id);\n        if (nmembers < 0)\n            break;\n        for (int i = 0; i < nmembers; i++) {\n            /* H5Tget_member_name returns malloc'd string; caller must free. */\n            char *mname = H5Tget_member_name(type_id, (unsigned)i);\n            if (mname)\n                H5free_memory(mname);\n\n            size_t off = H5Tget_member_offset(type_id, (unsigned)i);\n            (void)off;\n\n            /* H5Tget_member_type returns a new type ID that must be closed. */\n            hid_t mtype = H5Tget_member_type(type_id, (unsigned)i);\n            if (mtype >= 0) {\n                introspect_type(mtype, depth + 1);\n                H5Tclose(mtype);\n            }\n        }\n        break;\n    }\n\n    case H5T_ENUM: {\n        /* Enum: valid to call H5Tget_nmembers; member values via\n         * H5Tget_member_value; base type via H5Tget_super. */\n        int nmembers = H5Tget_nmembers(type_id);\n        if (nmembers < 0)\n            break;\n        for (int i = 0; i < nmembers; i++) {\n            char *mname = H5Tget_member_name(type_id, (unsigned)i);\n            if (mname)\n                H5free_memory(mname);\n\n            /* H5Tget_member_value writes into caller-supplied buffer;\n             * we pass a suitably-sized buffer for the base type. */\n            long long val = 0;\n            H5Tget_member_value(type_id, (unsigned)i, &val);\n        }\n        /* Introspect the integer base type */\n        hid_t super = H5Tget_super(type_id);\n        if (super >= 0) {\n            introspect_type(super, depth + 1);\n            H5Tclose(super);\n        }\n        break;\n    }\n\n    case H5T_VLEN: {\n        /* Variable-length sequence or string */\n        htri_t is_vstr = H5Tis_variable_str(type_id);\n        (void)is_vstr;\n\n        hid_t super = H5Tget_super(type_id);\n        if (super >= 0) {\n            introspect_type(super, depth + 1);\n            H5Tclose(super);\n        }\n        break;\n    }\n\n    case H5T_ARRAY: {\n        /* Array type: ndims, dims, element type */\n        int ndims = H5Tget_array_ndims(type_id);\n        if (ndims > 0 && ndims <= 32) {\n            hsize_t dims[32];\n            H5Tget_array_dims2(type_id, dims);\n        }\n        hid_t super = H5Tget_super(type_id);\n        if (super >= 0) {\n            introspect_type(super, depth + 1);\n            H5Tclose(super);\n        }\n        break;\n    }\n\n    case H5T_STRING: {\n        /* Fixed- or variable-length string */\n        htri_t is_vstr = H5Tis_variable_str(type_id);\n        (void)is_vstr;\n        break;\n    }\n\n    default:\n        /* INTEGER, FLOAT, BITFIELD, OPAQUE, REFERENCE, TIME — leaf types,\n         * no further nested APIs to call beyond get_class/get_size. */\n        break;\n    }\n}\n\n/* --------------------------------------------------------------------- */\n\n/* op_data passed into the H5Ovisit3 callback */\ntypedef struct {\n    hid_t file_id;\n} visit_data_t;\n\n/* H5Ovisit3 callback: called for every object in the file hierarchy. */\nstatic herr_t visit_cb(hid_t obj_id, const char *name,\n                        const H5O_info2_t *info, void *op_data)\n{\n    (void)obj_id; /* use file_id in op_data for reproducible open */\n\n    if (info->type != H5O_TYPE_NAMED_DATATYPE)\n        return 0; /* only care about committed (named) types */\n\n    visit_data_t *vd = (visit_data_t *)op_data;\n\n    /* Open the committed type the same way a real application would. */\n    hid_t type_id = H5Topen2(vd->file_id, name, H5P_DEFAULT);\n    if (type_id < 0)\n        return 0;\n\n    introspect_type(type_id, 0);\n\n    H5Tclose(type_id);\n    return 0; /* continue iteration */\n}\n\n/* --------------------------------------------------------------------- */\n\nint LLVMFuzzerTestOneInput(const uint8_t *data, size_t size)\n{\n    /* Suppress HDF5 error messages to keep output clean */\n    H5Eset_auto2(H5E_DEFAULT, NULL, NULL);\n\n    char filename[64];\n    snprintf(filename, sizeof(filename), \"/tmp/h5ct_%d\", getpid());\n\n    /* Write fuzz input to a temp file */\n    FILE *fp = fopen(filename, \"wb\");\n    if (!fp)\n        return 0;\n    if (size > 0)\n        fwrite(data, 1, size, fp);\n    fclose(fp);\n\n    /* Open the file read-only — a named-type reader never writes. */\n    hid_t file_id = H5Fopen(filename, H5F_ACC_RDONLY, H5P_DEFAULT);\n    if (file_id < 0) {\n        unlink(filename);\n        return 0;\n    }\n\n    /* Traverse every object and exercise the type introspection APIs on\n     * any committed (named) datatype we find. */\n    visit_data_t vd;\n    vd.file_id = file_id;\n    H5Ovisit3(file_id, H5_INDEX_NAME, H5_ITER_NATIVE, visit_cb, &vd,\n               H5O_INFO_BASIC);\n\n    H5Fclose(file_id);\n    unlink(filename);\n    return 0;\n}\n","structuredPatch":[],"originalFile":null}}
