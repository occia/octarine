{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019U49JeXehX5aAosJiZwgZ9","type":"tool_result","content":"1\t/* * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *\n2\t * Copyright by The HDF Group.                                               *\n3\t * All rights reserved.                                                      *\n4\t *                                                                           *\n5\t * This file is part of HDF5.  The full HDF5 copyright notice, including     *\n6\t * terms governing use, modification, and redistribution, is contained in    *\n7\t * the LICENSE file, which can be found at the root of the source code       *\n8\t * distribution tree, or in https://www.hdfgroup.org/licenses.               *\n9\t * If you do not have access to either file, you may request a copy from     *\n10\t * help@hdfgroup.org.                                                        *\n11\t * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * */\n12\t\n13\t/*\n14\t * This file contains public declarations for the H5A module.\n15\t */\n16\t#ifndef H5Apublic_H\n17\t#define H5Apublic_H\n18\t\n19\t#include \"H5public.h\"  /* Generic Functions                        */\n20\t#include \"H5Ipublic.h\" /* Identifiers                              */\n21\t#include \"H5Opublic.h\" /* Object Headers                           */\n22\t#include \"H5Tpublic.h\" /* Datatypes                                */\n23\t\n24\t//! <!-- [H5A_info_t_snip] -->\n25\t/**\n26\t * Information struct for H5Aget_info() / H5Aget_info_by_idx()\n27\t */\n28\ttypedef struct {\n29\t    bool              corder_valid; /**< Indicate if creation order is valid */\n30\t    H5O_msg_crt_idx_t corder;       /**< Creation order                 */\n31\t    H5T_cset_t        cset;         /**< Character set of attribute name */\n32\t    hsize_t           data_size;    /**< Size of raw data\t\t  */\n33\t} H5A_info_t;\n34\t//! <!-- [H5A_info_t_snip] -->\n35\t\n36\t//! <!-- [H5A_operator2_t_snip] -->\n37\t/**\n38\t * Typedef for H5Aiterate2() / H5Aiterate_by_name() callbacks\n39\t * \\param[in] location_id The identifier for the group, dataset\n40\t *            or named datatype being iterated over\n41\t * \\param[in] attr_name The name of the current object attribute\n42\t * \\param[in] ainfo The attribute's info struct\n43\t * \\param[in,out] op_data A pointer to the operator data passed into\n44\t *                H5Aiterate2() or H5Aiterate_by_name()\n45\t * \\return The return values from an operator are:\n46\t *          \\li Zero causes the iterator to continue, returning zero when\n47\t *              all attributes have been processed.\n48\t *          \\li Positive causes the iterator to immediately return that\n49\t *              positive value, indicating short-circuit success. The\n50\t *              iterator can be restarted at the next attribute.\n51\t *          \\li Negative causes the iterator to immediately return that value,\n52\t *              indicating failure. The iterator can be restarted at the next\n53\t *              attribute.\n54\t *\n55\t * \\callback_note\n56\t *\n57\t * \\since 1.8.0\n58\t *\n59\t */\n60\ttypedef herr_t (*H5A_operator2_t)(hid_t location_id /*in*/, const char *attr_name /*in*/,\n61\t                                  const H5A_info_t *ainfo /*in*/, void *op_data /*in,out*/);\n62\t//! <!-- [H5A_operator2_t_snip] -->\n63\t\n64\t/********************/\n65\t/* Public Variables */\n66\t/********************/\n67\t\n68\t/*********************/\n69\t/* Public Prototypes */\n70\t/*********************/\n71\t#ifdef __cplusplus\n72\textern \"C\" {\n73\t#endif\n74\t\n75\t/*-------------------------------------------------------------------------*/\n76\t/**\n77\t * \\ingroup H5A\n78\t *\n79\t * \\brief Closes the specified attribute\n80\t *\n81\t * \\attr_id\n82\t *\n83\t * \\return \\herr_t\n84\t *\n85\t * \\details H5Aclose() terminates access to the attribute through\n86\t *          \\p attr_id and releases the identifier.\n87\t *\n88\t * \\par Example\n89\t * \\snippet H5A_examples.c create\n90\t *\n91\t * \\since 1.0.0\n92\t *\n93\t * \\see H5Acreate(), H5Aopen()\n94\t */\n95\tH5_DLL herr_t H5Aclose(hid_t attr_id);\n96\t/*--------------------------------------------------------------------------*/\n97\t/**\n98\t * \\ingroup ASYNC\n99\t * \\async_variant_of{H5Aclose}\n100\t */\n101\t#ifndef H5_DOXYGEN\n102\tH5_DLL herr_t H5Aclose_async(const char *app_file, const char *app_func, unsigned app_line, hid_t attr_id,\n103\t                             hid_t es_id);\n104\t#else\n105\tH5_DLL herr_t H5Aclose_async(hid_t attr_id, hid_t es_id);\n106\t#endif\n107\t/* --------------------------------------------------------------------------*/\n108\t/**\n109\t * \\ingroup H5A\n110\t *\n111\t * \\brief Creates an attribute attached to a specified object\n112\t *\n113\t * \\fgdt_loc_id\n114\t * \\param[in] attr_name  Name of attribute\n115\t * \\param[in] type_id    Attribute datatype identifier\n116\t * \\space_id\n117\t * \\acpl_id\n118\t * \\aapl_id\n119\t *\n120\t * \\return \\hid_ti{attribute}\n121\t *\n122\t * \\details H5Acreate2() creates an attribute, \\p attr_name, which is attached\n123\t *          to the object specified by the identifier \\p loc_id.\n124\t *\n125\t *          The attribute name, \\p attr_name, must be unique for the object.\n126\t *\n127\t *          The attribute is created with the specified datatype and dataspace,\n128\t *          \\p type_id and \\p space_id.\n129\t *\n130\t *          \\plist_unused{aapl_id}\n131\t *\n132\t *          The attribute identifier returned by this function must be released\n133\t *          with H5Aclose() or resource leaks will develop.\n134\t *\n135\t * \\note If \\p loc_id is a file identifier, the attribute will be attached to\n136\t *       that file's root group.\n137\t *\n138\t * \\par Example\n139\t * \\snippet H5A_examples.c create\n140\t *\n141\t * \\since 1.8.0\n142\t *\n143\t * \\see H5Aclose()\n144\t *\n145\t */\n146\tH5_DLL hid_t H5Acreate2(hid_t loc_id, const char *attr_name, hid_t type_id, hid_t space_id, hid_t acpl_id,\n147\t                        hid_t aapl_id);\n148\t/*--------------------------------------------------------------------------*/\n149\t/**\n150\t * \\ingroup ASYNC\n151\t * \\async_variant_of{H5Acreate}\n152\t */\n153\t#ifndef H5_DOXYGEN\n154\tH5_DLL hid_t H5Acreate_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n155\t                             const char *attr_name, hid_t type_id, hid_t space_id, hid_t acpl_id,\n156\t                             hid_t aapl_id, hid_t es_id);\n157\t#else\n158\tH5_DLL hid_t H5Acreate_async(hid_t loc_id, const char *attr_name, hid_t type_id, hid_t space_id,\n159\t                             hid_t acpl_id, hid_t aapl_id, hid_t es_id);\n160\t#endif\n161\t\n162\t/*--------------------------------------------------------------------------*/\n163\t/**\n164\t * \\ingroup H5A\n165\t *\n166\t * \\brief  Creates an attribute attached to a specified object\n167\t *\n168\t * \\fgdt_loc_id\n169\t * \\param[in] obj_name  Name, relative to \\p loc_id, of object that\n170\t *                      attribute is to be attached to\n171\t * \\param[in] attr_name Attribute name\n172\t * \\param[in] type_id   Attribute datatype identifier\n173\t * \\space_id\n174\t * \\acpl_id\n175\t * \\aapl_id\n176\t * \\lapl_id\n177\t *\n178\t * \\return \\hid_ti{attribute}\n179\t *\n180\t * \\details H5Acreate_by_name() creates an attribute, \\p attr_name, which is\n181\t *          attached to the object specified by \\p loc_id and \\p obj_name.\n182\t *\n183\t *          \\p loc_id is a location identifier; \\p obj_name is the object\n184\t *          name relative to \\p loc_id.\n185\t *\n186\t *          The attribute name, \\p attr_name, must be unique for the object.\n187\t *\n188\t *          The attribute is created with the specified datatype and\n189\t *          dataspace, \\p type_id and \\p space_id.\n190\t *\n191\t *          \\plist_unused{aapl_id}\n192\t *\n193\t *          The link access property list, \\p lapl_id, may provide\n194\t *          information regarding the properties of links required to access\n195\t *          the object, \\p obj_name.\n196\t *\n197\t * \\since 1.8.0\n198\t *\n199\t */\n200\tH5_DLL hid_t H5Acreate_by_name(hid_t loc_id, const char *obj_name, const char *attr_name, hid_t type_id,\n201\t                               hid_t space_id, hid_t acpl_id, hid_t aapl_id, hid_t lapl_id);\n202\t/*--------------------------------------------------------------------------*/\n203\t/**\n204\t * \\ingroup ASYNC\n205\t * \\async_variant_of{H5Acreate_by_name}\n206\t */\n207\t#ifndef H5_DOXYGEN\n208\tH5_DLL hid_t H5Acreate_by_name_async(const char *app_file, const char *app_func, unsigned app_line,\n209\t                                     hid_t loc_id, const char *obj_name, const char *attr_name, hid_t type_id,\n210\t                                     hid_t space_id, hid_t acpl_id, hid_t aapl_id, hid_t lapl_id,\n211\t                                     hid_t es_id);\n212\t#else\n213\tH5_DLL hid_t H5Acreate_by_name_async(hid_t loc_id, const char *obj_name, const char *attr_name, hid_t type_id,\n214\t                                     hid_t space_id, hid_t acpl_id, hid_t aapl_id, hid_t lapl_id,\n215\t                                     hid_t es_id);\n216\t#endif\n217\t\n218\t/*-------------------------------------------------------------------------*/\n219\t/**\n220\t * \\ingroup H5A\n221\t *\n222\t * \\brief Deletes an attribute from a specified location\n223\t *\n224\t * \\fgdt_loc_id\n225\t * \\param[in] attr_name  Name of the attribute to delete\n226\t *\n227\t * \\return \\herr_t\n228\t *\n229\t * \\details H5Adelete() removes the attribute specified by its name,\n230\t *          \\p attr_name, from a file, dataset, group, or named datatype.\n231\t *\n232\t * \\attention This function should not be used when other attribute identifiers\n233\t *            are open on \\p loc_id. This may cause the internal indexes of\n234\t *            the attributes to change and future writes to the open\n235\t *            attributes to produce incorrect results.\n236\t *\n237\t * \\par Example\n238\t * \\snippet H5A_examples.c delete\n239\t *\n240\t * \\since 1.0.0\n241\t *\n242\t */\n243\tH5_DLL herr_t H5Adelete(hid_t loc_id, const char *attr_name);\n244\t/*-------------------------------------------------------------------------*/\n245\t/**\n246\t * \\ingroup H5A\n247\t *\n248\t * \\brief Deletes an attribute from an object according to index order\n249\t *\n250\t * \\fgdt_loc_id\n251\t * \\param[in] obj_name Name of object, relative to location, from which\n252\t *                     attribute is to be removed\n253\t * \\param[in] idx_type Type of index\n254\t * \\param[in] order    Order in which to iterate over the index\n255\t * \\param[in] n        Offset within the index\n256\t * \\lapl_id\n257\t *\n258\t * \\return \\herr_t\n259\t *\n260\t * \\details H5Adelete_by_idx() removes an attribute specified by its\n261\t *          location in an index, from an object.\n262\t *\n263\t *          The object from which the attribute is to be removed is\n264\t *          specified by a location identifier and name, \\p loc_id and\n265\t *          \\p obj_name, respectively.\n266\t *\n267\t *          The attribute to be removed is specified by a position in an\n268\t *          index, \\p n. The type of index is specified by \\p idx_type.\n269\t *          The order in which the index is to be traversed is specified by\n270\t *          \\p order. For example, if \\p idx_type, \\p order,\n271\t *          and \\p n are set to #H5_INDEX_NAME, #H5_ITER_INC, and 5,\n272\t *          respectively, the fifth attribute in the lexicographic order of\n273\t *          attribute names will be removed.\n274\t *\n275\t *          The link access property list, \\p lapl_id, may provide\n276\t *          information regarding the properties of links required to access\n277\t *          the object, \\p obj_name.\n278\t\n279\t * \\since 1.8.0\n280\t *\n281\t */\n282\tH5_DLL herr_t H5Adelete_by_idx(hid_t loc_id, const char *obj_name, H5_index_t idx_type, H5_iter_order_t order,\n283\t                               hsize_t n, hid_t lapl_id);\n284\t/*-------------------------------------------------------------------------*/\n285\t/**\n286\t * \\ingroup H5A\n287\t *\n288\t * \\brief Removes an attribute from a specified location\n289\t *\n290\t * \\fgdt_loc_id\n291\t * \\param[in] obj_name  Name of object, relative to location, from which\n292\t *                      attribute is to be removed\n293\t * \\param[in] attr_name Name of attribute to delete\n294\t * \\lapl_id\n295\t *\n296\t * \\return \\herr_t\n297\t *\n298\t * \\details H5Adelete_by_name() removes the attribute \\p attr_name\n299\t *          from an object specified by location and name, \\p loc_id and\n300\t *          \\p obj_name, respectively.\n301\t *\n302\t *          The link access property list, \\p lapl_id, may provide\n303\t *          information regarding the properties of links required to\n304\t *          access the object, \\p obj_name.\n305\t *\n306\t * \\since 1.8.0\n307\t *\n308\t */\n309\tH5_DLL herr_t H5Adelete_by_name(hid_t loc_id, const char *obj_name, const char *attr_name, hid_t lapl_id);\n310\t/*-------------------------------------------------------------------------*/\n311\t/**\n312\t * \\ingroup H5A\n313\t *\n314\t * \\brief Determines whether an attribute with a given name exists on an\n315\t *        object\n316\t *\n317\t * \\fgdt_loc_id{obj_id}\n318\t * \\param[in] attr_name  Attribute name\n319\t *\n320\t * \\return \\htri_t\n321\t *\n322\t * \\details H5Aexists() determines whether the attribute \\p attr_name\n323\t *          exists on the object specified by \\p obj_id.\n324\t *\n325\t * \\since 1.8.0\n326\t *\n327\t */\n328\tH5_DLL htri_t H5Aexists(hid_t obj_id, const char *attr_name);\n329\t/*--------------------------------------------------------------------------*/\n330\t/**\n331\t * \\ingroup ASYNC\n332\t * \\async_variant_of{H5Aexists}\n333\t */\n334\t#ifndef H5_DOXYGEN\n335\tH5_DLL herr_t H5Aexists_async(const char *app_file, const char *app_func, unsigned app_line, hid_t obj_id,\n336\t                              const char *attr_name, bool *exists, hid_t es_id);\n337\t#else\n338\tH5_DLL herr_t H5Aexists_async(hid_t obj_id, const char *attr_name, bool *exists, hid_t es_id);\n339\t#endif\n340\t\n341\t/*-------------------------------------------------------------------------*/\n342\t/**\n343\t * \\ingroup H5A\n344\t *\n345\t * \\brief  Determines whether an attribute with a given name exists on an\n346\t *         object\n347\t *\n348\t * \\fgdt_loc_id{obj_id}\n349\t * \\param[in] obj_name  Object name\n350\t * \\param[in] attr_name Attribute name\n351\t * \\lapl_id\n352\t *\n353\t * \\return \\htri_t\n354\t *\n355\t * \\details H5Aexists_by_name() determines whether the attribute\n356\t *          \\p attr_name exists on an object. That object is specified by\n357\t *          its location and name, \\p loc_id and \\p obj_name, respectively.\n358\t *\n359\t *          \\p loc_id specifies a location in the file containing the object.\n360\t *          \\p obj_name is the name of the object to which the attribute is\n361\t *          attached and can be a relative name, relative to \\p loc_id,\n362\t *          or an absolute name, based on the root group of the file.\n363\t *\n364\t *          The link access property list, \\p lapl_id, may provide\n365\t *          information regarding the properties of links required to access\n366\t *          \\p obj_name.\n367\t *\n368\t * \\since 1.8.0\n369\t *\n370\t */\n371\tH5_DLL htri_t H5Aexists_by_name(hid_t obj_id, const char *obj_name, const char *attr_name, hid_t lapl_id);\n372\t/*--------------------------------------------------------------------------*/\n373\t/**\n374\t * \\ingroup ASYNC\n375\t * \\async_variant_of{H5Aexists_by_name}\n376\t */\n377\t#ifndef H5_DOXYGEN\n378\tH5_DLL herr_t H5Aexists_by_name_async(const char *app_file, const char *app_func, unsigned app_line,\n379\t                                      hid_t loc_id, const char *obj_name, const char *attr_name, bool *exists,\n380\t                                      hid_t lapl_id, hid_t es_id);\n381\t#else\n382\tH5_DLL herr_t H5Aexists_by_name_async(hid_t loc_id, const char *obj_name, const char *attr_name, bool *exists,\n383\t                                      hid_t lapl_id, hid_t es_id);\n384\t#endif\n385\t\n386\t/*-------------------------------------------------------------------------*/\n387\t/**\n388\t * \\ingroup H5A\n389\t *\n390\t * \\brief Gets an attribute creation property list identifier\n391\t *\n392\t * \\attr_id\n393\t *\n394\t * \\return \\hid_ti{attribute's creation property list}\n395\t *\n396\t * \\details H5Aget_create_plist() returns an identifier for the attribute\n397\t *          creation property list associated with the attribute specified\n398\t *          by \\p attr_id.\n399\t *\n400\t *          The creation property list identifier should be released with\n401\t *          H5Pclose() to prevent resource leaks.\n402\t *\n403\t * \\since 1.8.0\n404\t *\n405\t */\n406\tH5_DLL hid_t H5Aget_create_plist(hid_t attr_id);\n407\t/*-------------------------------------------------------------------------*/\n408\t/**\n409\t * \\ingroup H5A\n410\t *\n411\t * \\brief Retrieves attribute information by attribute identifier\n412\t *\n413\t * \\attr_id\n414\t * \\param[out]  ainfo   Attribute information struct\n415\t *\n416\t * \\return \\herr_t\n417\t *\n418\t * \\details H5Aget_info() retrieves attribute information, locating the\n419\t *          attribute with an attribute identifier, \\p attr_id. The\n420\t *          attribute information is returned in the \\p ainfo struct.\n421\t *\n422\t * \\since 1.8.0\n423\t *\n424\t */\n425\tH5_DLL herr_t H5Aget_info(hid_t attr_id, H5A_info_t *ainfo /*out*/);\n426\t/*-------------------------------------------------------------------------*/\n427\t/**\n428\t * \\ingroup H5A\n429\t *\n430\t * \\brief Retrieves attribute information by attribute index position\n431\t *\n432\t * \\fgdt_loc_id\n433\t * \\param[in]  obj_name  Name of object to which attribute is attached,\n434\t *                       relative to location\n435\t * \\param[in]  idx_type  Type of index\n436\t * \\param[in]  order     Index traversal order\n437\t * \\param[in]  n         Attribute's position in index\n438\t * \\param[out] ainfo     Struct containing returned attribute information\n439\t * \\lapl_id\n440\t *\n441\t * \\return \\herr_t\n442\t *\n443\t * \\details H5Aget_info_by_idx() retrieves information for an attribute\n444\t *          that is attached to an object, which is specified by its\n445\t *          location and name, \\p loc_id and \\p obj_name, respectively.\n446\t *          The attribute is located by its index position, and the attribute\n447\t *          information is returned in the \\p ainfo struct.\n448\t *\n449\t *          The attribute is located by means of an index type, an index\n450\t *          traversal order, and a position in the index, \\p idx_type,\n451\t *          \\p order and \\p n, respectively.\n452\t *\n453\t *          The link access property list, \\p lapl_id, may provide\n454\t *          information regarding the properties of links required to access\n455\t *          the object, \\p obj_name.\n456\t *\n457\t * \\since 1.8.0\n458\t *\n459\t */\n460\tH5_DLL herr_t H5Aget_info_by_idx(hid_t loc_id, const char *obj_name, H5_index_t idx_type,\n461\t                                 H5_iter_order_t order, hsize_t n, H5A_info_t *ainfo /*out*/, hid_t lapl_id);\n462\t/*-------------------------------------------------------------------------*/\n463\t/**\n464\t * \\ingroup H5A\n465\t *\n466\t * \\brief Retrieves attribute information by attribute name\n467\t *\n468\t * \\fgdt_loc_id\n469\t * \\param[in] obj_name   Name of the object to which an attribute is attached,\n470\t *                       relative to location\n471\t * \\param[in] attr_name  Attribute name\n472\t * \\param[out] ainfo     Struct containing returned attribute information\n473\t * \\lapl_id\n474\t *\n475\t * \\return \\herr_t\n476\t *\n477\t * \\details H5Aget_info_by_name() retrieves information for an attribute,\n478\t *          \\p attr_name, that is attached to an object specified by its\n479\t *          location and name, \\p loc_id and \\p obj_name, respectively.\n480\t *          The attribute information is returned in the \\p ainfo struct.\n481\t *\n482\t *          The link access property list, \\p lapl_id, may provide\n483\t *          information regarding the properties of links required to\n484\t *          access the object, \\p obj_name.\n485\t *\n486\t * \\since 1.8.0\n487\t *\n488\t */\n489\tH5_DLL herr_t H5Aget_info_by_name(hid_t loc_id, const char *obj_name, const char *attr_name,\n490\t                                  H5A_info_t *ainfo /*out*/, hid_t lapl_id);\n491\t/*-------------------------------------------------------------------------*/\n492\t/**\n493\t * \\ingroup H5A\n494\t *\n495\t * \\brief Gets an attribute name\n496\t *\n497\t * \\attr_id\n498\t * \\param[in]  buf_size  The size of the buffer to store the name in\n499\t * \\param[out] buf       Buffer to store name in\n500\t *\n501\t * \\return  Returns the length of the attribute's name, which may be longer\n502\t *          than \\p buf_size, if successful. Otherwise, returns a negative\n503\t *          value.\n504\t *\n505\t * \\details H5Aget_name() retrieves the name of an attribute specified by\n506\t *          the identifier, \\p attr_id.\n507\t *\n508\t *          \\details_namelen{attribute,H5Aget_name}\n509\t *\n510\t * \\since 1.0.0\n511\t *\n512\t */\n513\tH5_DLL ssize_t H5Aget_name(hid_t attr_id, size_t buf_size, char *buf);\n514\t/*-------------------------------------------------------------------------*/\n515\t/**\n516\t * \\ingroup H5A\n517\t *\n518\t * \\brief Gets an attribute name by attribute index position\n519\t *\n520\t * \\fgdt_loc_id\n521\t * \\param[in]  obj_name   Name of object to which attribute is attached,\n522\t *                        relative to location\n523\t * \\param[in]  idx_type   Type of index\n524\t * \\param[in]  order      Index traversal order\n525\t * \\param[in]  n          Attribute's position in index\n526\t * \\param[out] name       Attribute name\n527\t * \\param[in]  size       Size, in bytes, of attribute name\n528\t * \\lapl_id\n529\t *\n530\t * \\return Returns attribute name size, in bytes, if successful;\n531\t *         otherwise, returns a negative value.\n532\t *\n533\t * \\details H5Aget_name_by_idx() retrieves the name of an attribute that is\n534\t *          attached to an object, which is specified by its location and\n535\t *          name, \\p loc_id and \\p obj_name, respectively. The attribute is\n536\t *          located by its index position, the size of the name is specified\n537\t *          in \\p size, and the attribute name is returned in \\p name.\n538\t *\n539\t *          The attribute is located by means of an index type, an index\n540\t *          traversal order, and a position in the index, \\p idx_type,\n541\t *          \\p order and \\p n, respectively.\n542\t *\n543\t *          \\details_namelen{attribute,H5Aget_name_by_idx}\n544\t *\n545\t *          The link access property list, \\p lapl_id, may provide\n546\t *          information regarding the properties of links required to access\n547\t *          the object, \\p obj_name.\n548\t *\n549\t * \\since 1.8.0\n550\t *\n551\t */\n552\tH5_DLL ssize_t H5Aget_name_by_idx(hid_t loc_id, const char *obj_name, H5_index_t idx_type,\n553\t                                  H5_iter_order_t order, hsize_t n, char *name /*out*/, size_t size,\n554\t                                  hid_t lapl_id);\n555\t/*-------------------------------------------------------------------------*/\n556\t/**\n557\t * \\ingroup H5A\n558\t *\n559\t * \\brief Gets a copy of the dataspace for an attribute\n560\t *\n561\t * \\attr_id\n562\t *\n563\t * \\return \\hid_ti{attribute dataspace}\n564\t *\n565\t * \\details  H5Aget_space() retrieves a copy of the dataspace for an\n566\t *           attribute. The dataspace identifier returned from this\n567\t *           function must be released with H5Sclose() or resource leaks\n568\t *           will develop.\n569\t *\n570\t * \\since 1.0.0\n571\t *\n572\t */\n573\tH5_DLL hid_t H5Aget_space(hid_t attr_id);\n574\t/*-------------------------------------------------------------------------*/\n575\t/**\n576\t * \\ingroup H5A\n577\t *\n578\t * \\brief Returns the amount of storage used to store an attribute\n579\t *\n580\t * \\attr_id\n581\t *\n582\t * \\return Returns the amount of storage size allocated for the attribute;\n583\t *         otherwise, returns 0 (zero).\n584\t *\n585\t * \\details H5Aget_storage_size() returns the amount of storage that is\n586\t *          required for the specified attribute, \\p attr_id.\n587\t *\n588\t * \\since 1.6.0\n589\t *\n590\t */\n591\tH5_DLL hsize_t H5Aget_storage_size(hid_t attr_id);\n592\t/*-------------------------------------------------------------------------*/\n593\t/**\n594\t * \\ingroup H5A\n595\t *\n596\t * \\brief Gets an attribute's datatype\n597\t *\n598\t * \\attr_id\n599\t *\n600\t * \\return \\hid_t{datatype}\n601\t *\n602\t * \\details H5Aget_type() retrieves a copy of the attribute's datatype.\n603\t *          The datatype is reopened if it is a named type before returning\n604\t *          it to the application. The datatypes returned by this function\n605\t *          are always read-only.\n606\t *\n607\t *          The datatype identifier returned from this function must be\n608\t *          released with H5Tclose() or resource leaks will develop.\n609\t *\n610\t * \\since 1.0.0\n611\t *\n612\t */\n613\tH5_DLL hid_t H5Aget_type(hid_t attr_id);\n614\t/*-------------------------------------------------------------------------*/\n615\t/**\n616\t * \\ingroup H5A\n617\t *\n618\t * \\brief Calls a user-defined function for each attribute on an object\n619\t *\n620\t * \\fgdt_loc_id\n621\t * \\param[in]     idx_type Type of index\n622\t * \\param[in]     order    Order in which to iterate over index\n623\t * \\param[in,out] idx      Initial and returned offset within index\n624\t * \\param[in]     op       User-defined function to pass each attribute to\n625\t * \\param[in,out] op_data  User data to pass through to and to be returned\n626\t *                         by iterator operator function\n627\t *\n628\t * \\return \\herr_t\n629\t *       Further note that this function returns the return value of the\n630\t *       last operator if it was non-zero, which can be a negative value,\n631\t *       zero if all attributes were processed, or a positive value\n632\t *       indicating short-circuit success.\n633\t *\n634\t * \\details H5Aiterate2() iterates over the attributes attached to a\n635\t *          dataset, named datatype, or group, as specified by \\p loc_id.\n636\t *          For each attribute, user-provided data, \\p op_data, with\n637\t *          additional information, as defined below, is passed to a\n638\t *          user-defined function, \\p op, which operates on that\n639\t *          attribute.\n640\t *\n641\t *          The order of the iteration and the attributes iterated over\n642\t *          are specified by three parameters: the index type,\n643\t *          \\p idx_type; the order in which the index is to be traversed,\n644\t *          \\p order; and the attribute's position in the index, \\p idx.\n645\t *          The next attribute to be operated on is specified by \\p idx,\n646\t *          a position in the index.\n647\t *\n648\t *          For example, if \\p idx_type, \\p order, and \\p idx are set to\n649\t *          #H5_INDEX_NAME, #H5_ITER_INC, and 5, respectively, the attribute\n650\t *          in question is the fifth attribute from the beginning of the\n651\t *          alphanumeric index of attribute names. If \\p order were set to\n652\t *          #H5_ITER_DEC, it would be the fifth attribute from the end of\n653\t *          the index.\n654\t *\n655\t *          The parameter \\p idx is passed in on an H5Aiterate2() call with\n656\t *          one value and may be returned with another value. The value\n657\t *          passed in identifies the parameter to be operated on first;\n658\t *          the value returned identifies the parameter to be operated on\n659\t *          in the next step of the iteration.\n660\t *\n661\t * \\note This function is also available through the H5Aiterate() macro.\n662\t *\n663\t * \\warning   Adding or removing attributes to the object during iteration\n664\t *            will lead to undefined behavior.\n665\t *\n666\t * \\callback_note\n667\t *\n668\t * \\since 1.8.0\n669\t *\n670\t */\n671\tH5_DLL herr_t H5Aiterate2(hid_t loc_id, H5_index_t idx_type, H5_iter_order_t order, hsize_t *idx,\n672\t                          H5A_operator2_t op, void *op_data);\n673\t/*--------------------------------------------------------------------------*/\n674\t/**\n675\t * \\ingroup H5A\n676\t *\n677\t * \\brief Calls user-defined function for each attribute on an object\n678\t *\n679\t * \\fgdt_loc_id\n680\t * \\param[in] obj_name    Name of object, relative to location\n681\t * \\param[in] idx_type    Type of index\n682\t * \\param[in] order       Order in which to iterate over index\n683\t * \\param[in,out] idx     Initial and returned offset within index\n684\t * \\param[in] op          User-defined function to pass each attribute to\n685\t * \\param[in,out] op_data User data to pass through to and to be returned\n686\t *                        by iterator operator function\n687\t * \\lapl_id\n688\t *\n689\t * \\return \\herr_t\n690\t *         Further note that this function returns the return value of\n691\t *         the last operator if it is non-zero, which can be a negative\n692\t *         value, zero if all attributes were processed, or a positive value\n693\t *         indicating short-circuit success.\n694\t *\n695\t * \\details H5Aiterate_by_name() iterates over the attributes attached\n696\t *          to the dataset or group specified with \\p loc_id and \\p obj_name.\n697\t *          For each attribute, user-provided data, \\p op_data, with\n698\t *          additional information, as defined below, is passed to a\n699\t *          user-defined function, \\p op, which operates on that attribute.\n700\t *\n701\t *          The order of the iteration and the attributes iterated over\n702\t *          are specified by three parameters: the index type, \\p idx_type;\n703\t *          the order in which the index is to be traversed, \\p order;\n704\t *          and the attribute's position in the index, \\p idx.\n705\t *          The next attribute to be operated on is specified by \\p idx,\n706\t *          a position in the index.\n707\t *\n708\t *          For example, if \\p idx_type, \\p order, and \\p idx are set to\n709\t *          #H5_INDEX_NAME, #H5_ITER_INC, and 5, respectively, the attribute\n710\t *          in question is the fifth attribute from the beginning of the\n711\t *          alphanumeric index of attribute names. If \\p order were set to\n712\t *          #H5_ITER_DEC, it would be the fifth attribute from the end of\n713\t *          the index.\n714\t *\n715\t *          The parameter \\p idx is passed in on an H5Aiterate_by_name()\n716\t *          call with one value and may be returned with another value. The\n717\t *          value passed in identifies the parameter to be operated on first;\n718\t *          the value returned identifies the parameter to be operated on in\n719\t *          the next step of the iteration.\n720\t *\n721\t *          The link access property list, \\p lapl_id, may provide\n722\t *          information regarding the properties of links required to access\n723\t *          the object, \\p obj_name.\n724\t *\n725\t * \\warning   Adding or removing attributes to the object during iteration\n726\t *            will lead to undefined behavior.\n727\t *\n728\t * \\since 1.8.0\n729\t *\n730\t */\n731\tH5_DLL herr_t H5Aiterate_by_name(hid_t loc_id, const char *obj_name, H5_index_t idx_type,\n732\t                                 H5_iter_order_t order, hsize_t *idx, H5A_operator2_t op, void *op_data,\n733\t                                 hid_t lapl_id);\n734\t/*--------------------------------------------------------------------------*/\n735\t/**\n736\t * \\ingroup H5A\n737\t *\n738\t * \\brief Opens an attribute for an object specified by object identifier and\n739\t *        attribute name\n740\t *\n741\t * \\fgdt_loc_id{obj_id}\n742\t * \\param[in]  attr_name    Name of attribute to open\n743\t * \\aapl_id\n744\t *\n745\t * \\return \\hid_ti{attribute}\n746\t *\n747\t * \\details H5Aopen() opens an existing attribute, \\p attr_name, that is\n748\t *          attached to the object specified by an object identifier, \\p obj_id.\n749\t *\n750\t *          \\plist_unused{aapl_id}\n751\t *\n752\t *          This function, H5Aopen_by_idx() or H5Aopen_by_name() must be called\n753\t *          before the attribute can be accessed for any further purpose,\n754\t *          including reading, writing, or any modification.\n755\t *\n756\t *          The attribute identifier returned by this function must be released\n757\t *          with H5Aclose() or resource leaks will develop.\n758\t *\n759\t * \\par Example\n760\t * \\snippet H5A_examples.c read\n761\t *\n762\t * \\since 1.8.0\n763\t *\n764\t * \\see H5Aclose(), H5Acreate()\n765\t */\n766\tH5_DLL hid_t H5Aopen(hid_t obj_id, const char *attr_name, hid_t aapl_id);\n767\t/*--------------------------------------------------------------------------*/\n768\t/**\n769\t * \\ingroup ASYNC\n770\t * \\async_variant_of{H5Aopen}\n771\t */\n772\t#ifndef H5_DOXYGEN\n773\tH5_DLL hid_t H5Aopen_async(const char *app_file, const char *app_func, unsigned app_line, hid_t obj_id,\n774\t                           const char *attr_name, hid_t aapl_id, hid_t es_id);\n775\t#else\n776\tH5_DLL hid_t H5Aopen_async(hid_t obj_id, const char *attr_name, hid_t aapl_id, hid_t es_id);\n777\t#endif\n778\t/*--------------------------------------------------------------------------*/\n779\t/**\n780\t * \\ingroup H5A\n781\t *\n782\t * \\brief Opens the nth attribute attached to an object\n783\t *\n784\t * \\loc_id\n785\t * \\param[in] obj_name  Name of object to which attribute is attached,\n786\t *                      relative to location\n787\t * \\param[in] idx_type  Type of index\n788\t * \\param[in] order     Index traversal order\n789\t * \\param[in] n         Attribute's position in index\n790\t * \\aapl_id\n791\t * \\lapl_id\n792\t *\n793\t * \\return \\hid_ti{attribute}\n794\t *\n795\t * \\details H5Aopen_by_idx() opens an existing attribute that is attached\n796\t *          to an object specified by location and name, \\p loc_id and\n797\t *          \\p obj_name, respectively.\n798\t *\n799\t *          The attribute is identified by an index type, an index traversal\n800\t *          order, and a position in the index, \\p idx_type, \\p order and\n801\t *          \\p n, respectively.\n802\t *\n803\t *          \\plist_unused{aapl_id}\n804\t *\n805\t *          The link access property list, \\p lapl_id, may provide\n806\t *          information regarding the properties of links required to access\n807\t *          the object, \\p obj_name.\n808\t *\n809\t *          This function, H5Aopen(), or H5Aopen_by_name() must be called\n810\t *          before an attribute can be accessed for any further purpose,\n811\t *          including reading, writing, or any modification.\n812\t *\n813\t *          The attribute identifier returned by this function must be\n814\t *          released with H5Aclose() or resource leaks will develop.\n815\t *\n816\t * \\since 1.8.0\n817\t *\n818\t */\n819\tH5_DLL hid_t H5Aopen_by_idx(hid_t loc_id, const char *obj_name, H5_index_t idx_type, H5_iter_order_t order,\n820\t                            hsize_t n, hid_t aapl_id, hid_t lapl_id);\n821\t/*--------------------------------------------------------------------------*/\n822\t/**\n823\t * \\ingroup ASYNC\n824\t * \\async_variant_of{H5Aopen_by_idx}\n825\t */\n826\t#ifndef H5_DOXYGEN\n827\tH5_DLL hid_t H5Aopen_by_idx_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n828\t                                  const char *obj_name, H5_index_t idx_type, H5_iter_order_t order, hsize_t n,\n829\t                                  hid_t aapl_id, hid_t lapl_id, hid_t es_id);\n830\t#else\n831\tH5_DLL hid_t H5Aopen_by_idx_async(hid_t loc_id, const char *obj_name, H5_index_t idx_type,\n832\t                                  H5_iter_order_t order, hsize_t n, hid_t aapl_id, hid_t lapl_id,\n833\t                                  hid_t es_id);\n834\t#endif\n835\t/*--------------------------------------------------------------------------*/\n836\t/**\n837\t * \\ingroup H5A\n838\t *\n839\t * \\brief Opens an attribute for an object by object name and attribute name\n840\t *\n841\t * \\fgdt_loc_id\n842\t * \\param[in] obj_name   Name of object to which attribute is attached,\n843\t *                       relative to \\p loc_id\n844\t * \\param[in] attr_name  Name of attribute to open\n845\t * \\aapl_id\n846\t * \\lapl_id\n847\t *\n848\t * \\return \\hid_ti{attribute}\n849\t *\n850\t * \\details H5Aopen_by_name() opens an existing attribute, \\p attr_name,\n851\t *          that is attached to an object specified by location and name,\n852\t *          \\p loc_id and \\p obj_name, respectively.\n853\t *\n854\t *          \\p loc_id specifies a location from which the target object can\n855\t *          be located and \\p obj_name is an object name relative to\n856\t *          \\p loc_id.\n857\t *\n858\t *          \\plist_unused{aapl_id}\n859\t *\n860\t *          The link access property list, \\p lapl_id, may provide\n861\t *          information regarding the properties of links required to access\n862\t *          the object, \\p obj_name.\n863\t *\n864\t *          This function, H5Aopen(), or H5Aopen_by_idx() must be called\n865\t *          before an attribute can be accessed for any further purpose,\n866\t *          including reading, writing, or any modification.\n867\t *\n868\t *          The attribute identifier returned by this function must be\n869\t *          released with H5Aclose() or resource leaks will develop.\n870\t *\n871\t * \\since 1.8.0\n872\t *\n873\t */\n874\tH5_DLL hid_t H5Aopen_by_name(hid_t loc_id, const char *obj_name, const char *attr_name, hid_t aapl_id,\n875\t                             hid_t lapl_id);\n876\t/*--------------------------------------------------------------------------*/\n877\t/**\n878\t * \\ingroup ASYNC\n879\t * \\async_variant_of{H5Aopen_by_name}\n880\t */\n881\t#ifndef H5_DOXYGEN\n882\tH5_DLL hid_t H5Aopen_by_name_async(const char *app_file, const char *app_func, unsigned app_line,\n883\t                                   hid_t loc_id, const char *obj_name, const char *attr_name, hid_t aapl_id,\n884\t                                   hid_t lapl_id, hid_t es_id);\n885\t#else\n886\tH5_DLL hid_t H5Aopen_by_name_async(hid_t loc_id, const char *obj_name, const char *attr_name, hid_t aapl_id,\n887\t                                   hid_t lapl_id, hid_t es_id);\n888\t#endif\n889\t\n890\t/*-------------------------------------------------------------------------- */\n891\t/**\n892\t * \\ingroup H5A\n893\t *\n894\t * \\brief Reads the value of an attribute\n895\t *\n896\t * \\attr_id\n897\t * \\mem_type_id{type_id}\n898\t * \\param[out] buf        Buffer for data to be read\n899\t *\n900\t * \\return \\herr_t\n901\t *\n902\t * \\details H5Aread() reads an attribute, specified with \\p attr_id. The\n903\t *          attribute's in-memory datatype is specified with \\p type_id. The\n904\t *          entire attribute is read into \\p buf from the file.\n905\t *\n906\t *          Datatype conversion takes place at the time of a read or write and\n907\t *          is automatic.\n908\t *\n909\t * \\par Example\n910\t * \\snippet H5A_examples.c read\n911\t *\n912\t * \\version 1.8.8  Fortran updated to Fortran2003.\n913\t * \\version 1.4.2  The \\p dims parameter was added to the Fortran API in this\n914\t *                 release.\n915\t * \\since   1.0.0\n916\t *\n917\t * \\see H5Awrite()\n918\t *\n919\t */\n920\tH5_DLL herr_t H5Aread(hid_t attr_id, hid_t type_id, void *buf);\n921\t/*--------------------------------------------------------------------------*/\n922\t/**\n923\t * \\ingroup ASYNC\n924\t * \\async_variant_of{H5Aread}\n925\t */\n926\t#ifndef H5_DOXYGEN\n927\tH5_DLL herr_t H5Aread_async(const char *app_file, const char *app_func, unsigned app_line, hid_t attr_id,\n928\t                            hid_t dtype_id, void *buf, hid_t es_id);\n929\t#else\n930\tH5_DLL herr_t H5Aread_async(hid_t attr_id, hid_t dtype_id, void *buf, hid_t es_id);\n931\t#endif\n932\t/*-------------------------------------------------------------------------*/\n933\t/**\n934\t * \\ingroup H5A\n935\t *\n936\t * \\brief Renames an attribute\n937\t *\n938\t * \\fgdt_loc_id\n939\t * \\param[in] old_name   Name of the attribute to be changed\n940\t * \\param[in] new_name   New name for the attribute\n941\t *\n942\t * \\return \\herr_t\n943\t *\n944\t * \\details H5Arename() changes the name of the attribute located at\n945\t *          \\p loc_id.\n946\t *\n947\t *          The old name, \\p old_name, is changed to the new name,\n948\t *          \\p new_name.\n949\t *\n950\t * \\since 1.6.0\n951\t *\n952\t */\n953\tH5_DLL herr_t H5Arename(hid_t loc_id, const char *old_name, const char *new_name);\n954\t/*--------------------------------------------------------------------------*/\n955\t/**\n956\t * \\ingroup ASYNC\n957\t * \\async_variant_of{H5Arename}\n958\t */\n959\t#ifndef H5_DOXYGEN\n960\tH5_DLL herr_t H5Arename_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n961\t                              const char *old_name, const char *new_name, hid_t es_id);\n962\t#else\n963\tH5_DLL herr_t H5Arename_async(hid_t loc_id, const char *old_name, const char *new_name, hid_t es_id);\n964\t#endif\n965\t/*--------------------------------------------------------------------------*/\n966\t/**\n967\t * \\ingroup ASYNC\n968\t * \\async_variant_of{H5Arename_by_name}\n969\t */\n970\t#ifndef H5_DOXYGEN\n971\tH5_DLL herr_t H5Arename_by_name_async(const char *app_file, const char *app_func, unsigned app_line,\n972\t                                      hid_t loc_id, const char *obj_name, const char *old_attr_name,\n973\t                                      const char *new_attr_name, hid_t lapl_id, hid_t es_id);\n974\t#else\n975\tH5_DLL herr_t H5Arename_by_name_async(hid_t loc_id, const char *obj_name, const char *old_attr_name,\n976\t                                      const char *new_attr_name, hid_t lapl_id, hid_t es_id);\n977\t#endif\n978\t/*--------------------------------------------------------------------------*/\n979\t/**\n980\t * \\ingroup H5A\n981\t *\n982\t * \\brief Writes data to an attribute\n983\t *\n984\t * \\attr_id\n985\t * \\mem_type_id{type_id}\n986\t * \\param[in]  buf       Data to be written\n987\t *\n988\t * \\return \\herr_t\n989\t *\n990\t * \\details H5Awrite() writes an attribute, specified with \\p attr_id. The\n991\t *          attribute's in-memory datatype is specified with \\p type_id.\n992\t *          The entire attribute is written from \\p buf to the file.\n993\t *\n994\t *          Datatype conversion takes place at the time of a read or write and\n995\t *          is automatic.\n996\t *\n997\t * \\par Example\n998\t * \\snippet H5A_examples.c update\n999\t *\n1000\t * \\version 1.8.8   Fortran updated to Fortran2003.\n1001\t * \\version 1.4.2   Fortran \\p dims parameter added in this release\n1002\t * \\since 1.0.0\n1003\t * \\see H5Aread()\n1004\t *\n1005\t */\n1006\tH5_DLL herr_t H5Awrite(hid_t attr_id, hid_t type_id, const void *buf);\n1007\t/*--------------------------------------------------------------------------*/\n1008\t/**\n1009\t * \\ingroup ASYNC\n1010\t * \\async_variant_of{H5Awrite}\n1011\t */\n1012\t#ifndef H5_DOXYGEN\n1013\tH5_DLL herr_t H5Awrite_async(const char *app_file, const char *app_func, unsigned app_line, hid_t attr_id,\n1014\t                             hid_t type_id, const void *buf, hid_t es_id);\n1015\t#else\n1016\tH5_DLL herr_t H5Awrite_async(hid_t attr_id, hid_t type_id, const void *buf, hid_t es_id);\n1017\t#endif\n1018\t/*-------------------------------------------------------------------------*/\n1019\t/**\n1020\t * \\ingroup H5A\n1021\t *\n1022\t * \\fgdt_loc_id\n1023\t * \\param[in] obj_name      Name of object, relative to location, whose\n1024\t *                          attribute is to be renamed\n1025\t * \\param[in] old_attr_name Prior attribute name\n1026\t * \\param[in] new_attr_name New attribute name\n1027\t * \\lapl_id\n1028\t *\n1029\t * \\details H5Arename_by_name() changes the name of attribute that is\n1030\t *          attached to the object specified by \\p loc_id and \\p obj_name.\n1031\t *          The attribute named \\p old_attr_name is renamed\n1032\t *          \\p new_attr_name.\n1033\t *\n1034\t *          The link access property list, \\p lapl_id, may provide\n1035\t *          information regarding the properties of links required to\n1036\t *          access the object, \\p obj_name.\n1037\t *\n1038\t * \\since 1.8.0\n1039\t *\n1040\t */\n1041\tH5_DLL herr_t H5Arename_by_name(hid_t loc_id, const char *obj_name, const char *old_attr_name,\n1042\t                                const char *new_attr_name, hid_t lapl_id);\n1043\t\n1044\t/// \\cond DEV\n1045\t/* API Wrappers for async routines */\n1046\t/* (Must be defined _after_ the function prototype) */\n1047\t/* (And must only defined when included in application code, not the library) */\n1048\t#ifndef H5A_MODULE\n1049\t#define H5Acreate_async(...)         H5Acreate_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1050\t#define H5Acreate_by_name_async(...) H5Acreate_by_name_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1051\t#define H5Aopen_async(...)           H5Aopen_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1052\t#define H5Aopen_by_name_async(...)   H5Aopen_by_name_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1053\t#define H5Aopen_by_idx_async(...)    H5Aopen_by_idx_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1054\t#define H5Awrite_async(...)          H5Awrite_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1055\t#define H5Aread_async(...)           H5Aread_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1056\t#define H5Arename_async(...)         H5Arename_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1057\t#define H5Arename_by_name_async(...) H5Arename_by_name_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1058\t#define H5Aexists_async(...)         H5Aexists_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1059\t#define H5Aexists_by_name_async(...) H5Aexists_by_name_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1060\t#define H5Aclose_async(...)          H5Aclose_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n1061\t\n1062\t/* Define \"wrapper\" versions of function calls, to allow compile-time values to\n1063\t *      be passed in by language wrapper or library layer on top of HDF5.\n1064\t */\n1065\t#define H5Acreate_async_wrap         H5_NO_EXPAND(H5Acreate_async)\n1066\t#define H5Acreate_by_name_async_wrap H5_NO_EXPAND(H5Acreate_by_name_async)\n1067\t#define H5Aopen_async_wrap           H5_NO_EXPAND(H5Aopen_async)\n1068\t#define H5Aopen_by_name_async_wrap   H5_NO_EXPAND(H5Aopen_by_name_async)\n1069\t#define H5Aopen_by_idx_async_wrap    H5_NO_EXPAND(H5Aopen_by_idx_async)\n1070\t#define H5Awrite_async_wrap          H5_NO_EXPAND(H5Awrite_async)\n1071\t#define H5Aread_async_wrap           H5_NO_EXPAND(H5Aread_async)\n1072\t#define H5Arename_async_wrap         H5_NO_EXPAND(H5Arename_async)\n1073\t#define H5Arename_by_name_async_wrap H5_NO_EXPAND(H5Arename_by_name_async)\n1074\t#define H5Aexists_async_wrap         H5_NO_EXPAND(H5Aexists_async)\n1075\t#define H5Aexists_by_name_async_wrap H5_NO_EXPAND(H5Aexists_by_name_async)\n1076\t#define H5Aclose_async_wrap          H5_NO_EXPAND(H5Aclose_async)\n1077\t#endif /* H5A_MODULE */\n1078\t/// \\endcond\n1079\t\n1080\t/* Symbols defined for compatibility with previous versions of the HDF5 API.\n1081\t *\n1082\t * Use of these symbols is deprecated.\n1083\t */\n1084\t#ifndef H5_NO_DEPRECATED_SYMBOLS\n1085\t\n1086\t/* Macros */\n1087\t\n1088\t/* Typedefs */\n1089\t\n1090\t//! <!-- [H5A_operator1_t_snip] -->\n1091\t/**\n1092\t * \\brief Typedef for H5Aiterate1() callbacks\n1093\t *\n1094\t * \\param[in] location_id The identifier for the group, dataset\n1095\t *            or named datatype being iterated over\n1096\t * \\param[in] attr_name The name of the current object attribute\n1097\t * \\param[in,out] operator_data A pointer to the operator data passed into\n1098\t *                H5Aiterate1()\n1099\t * \\return The return values from an operator are:\n1100\t *          \\li Zero causes the iterator to continue, returning zero when\n1101\t *              all attributes have been processed.\n1102\t *          \\li Positive causes the iterator to immediately return that\n1103\t *              positive value, indicating short-circuit success. The\n1104\t *              iterator can be restarted at the next attribute.\n1105\t *          \\li Negative causes the iterator to immediately return that value,\n1106\t *              indicating failure. The iterator can be restarted at the next\n1107\t *              attribute.\n1108\t */\n1109\ttypedef herr_t (*H5A_operator1_t)(hid_t location_id /*in*/, const char *attr_name /*in*/,\n1110\t                                  void *operator_data /*in,out*/);\n1111\t//! <!-- [H5A_operator1_t_snip] -->\n1112\t\n1113\t/* Function prototypes */\n1114\t/* --------------------------------------------------------------------------*/\n1115\t/**\n1116\t * \\ingroup H5A\n1117\t *\n1118\t * \\brief Creates an attribute attached to a specified object\n1119\t *\n1120\t * \\fgdt_loc_id\n1121\t * \\param[in] name     Name of attribute to locate and open\n1122\t * \\param[in] type_id  Identifier of attribute datatype\n1123\t * \\space_id\n1124\t * \\acpl_id\n1125\t *\n1126\t * \\return \\hid_ti{attribute}\n1127\t *\n1128\t * \\deprecation_note{H5Acreate2()}\n1129\t *\n1130\t * \\plist_unused{acpl}\n1131\t *\n1132\t * \\details H5Acreate1() creates an attribute, \\p name, which is attached\n1133\t *          to the object specified by the identifier \\p loc_id.\n1134\t *\n1135\t *          The attribute name, \\p name, must be unique for the object.\n1136\t *\n1137\t *          The attribute is created with the specified datatype and dataspace,\n1138\t *          \\p type_id and \\p space_id.\n1139\t *\n1140\t * \\since 1.8.0\n1141\t *\n1142\t * \\version 1.8.0 The function H5Acreate() was renamed to H5Acreate1() and\n1143\t *          deprecated in this release.\n1144\t *\n1145\t * \\see H5Aclose()\n1146\t *\n1147\t */\n1148\tH5_DLL hid_t H5Acreate1(hid_t loc_id, const char *name, hid_t type_id, hid_t space_id, hid_t acpl_id);\n1149\t/* --------------------------------------------------------------------------*/\n1150\t/**\n1151\t * \\ingroup H5A\n1152\t *\n1153\t * \\brief Determines the number of attributes attached to an object\n1154\t *\n1155\t * \\fgdt_loc_id\n1156\t *\n1157\t * \\return Returns the number of attributes if successful; otherwise, returns\n1158\t *         a negative value.\n1159\t *\n1160\t * \\deprecation_note{H5Oget_info(), H5Oget_info_by_name(), and H5Oget_info_by_idx()}\n1161\t *\n1162\t * \\details H5Aget_num_attrs() returns the number of attributes attached to\n1163\t *          the object specified by its identifier, \\p loc_id.\n1164\t *\n1165\t * \\since 1.0.0\n1166\t *\n1167\t */\n1168\tH5_DLL int H5Aget_num_attrs(hid_t loc_id);\n1169\t/* --------------------------------------------------------------------------*/\n1170\t/**\n1171\t * \\ingroup H5A\n1172\t *\n1173\t * \\brief Calls a user's function for each attribute on an object\n1174\t *\n1175\t * \\loc_id\n1176\t * \\param[in,out] idx     Starting (in) and ending (out) attribute index\n1177\t * \\param[in]     op      User's function to pass each attribute to\n1178\t * \\param[in,out] op_data User's data to pass through to the iterator operator\n1179\t *                        function\n1180\t *\n1181\t * \\return \\herr_t\n1182\t *\n1183\t * \\deprecation_note{H5Aiterate2()}\n1184\t *\n1185\t * \\details H5Aiterate1() iterates over the attributes of the object\n1186\t *          specified by its identifier, \\p loc_id. The object can be a\n1187\t *          group, dataset, or named datatype. For each attribute of the\n1188\t *          object, the \\p op_data and some additional information specified\n1189\t *          below are passed to the operator function \\p op. The iteration\n1190\t *          begins with the attribute specified by its index, \\p idx; the\n1191\t *          index for the next attribute to be processed by the operator,\n1192\t *          \\p op, is returned in \\p idx. If \\p idx is the null pointer,\n1193\t *          then all attributes are processed.\n1194\t *\n1195\t * \\warning   Adding or removing attributes to the object during iteration\n1196\t *            will lead to undefined behavior.\n1197\t *\n1198\t * \\callback_note\n1199\t *\n1200\t * \\version 1.8.0 The function \\p H5Aiterate was renamed to H5Aiterate1()\n1201\t *                and deprecated in this release.\n1202\t * \\since 1.0.0\n1203\t *\n1204\t */\n1205\tH5_DLL herr_t H5Aiterate1(hid_t loc_id, unsigned *idx, H5A_operator1_t op, void *op_data);\n1206\t/* --------------------------------------------------------------------------*/\n1207\t/**\n1208\t * \\ingroup H5A\n1209\t *\n1210\t * \\brief Opens the attribute specified by its index\n1211\t *\n1212\t * \\loc_id\n1213\t * \\param[in] idx Index of the attribute to open\n1214\t *\n1215\t * \\return \\hid_ti{attribute}\n1216\t *\n1217\t * \\deprecation_note{H5Aopen_by_idx()}\n1218\t *\n1219\t * \\details H5Aopen_idx() opens an attribute that is attached to the\n1220\t *          object specified with \\p loc_id. The location object may be\n1221\t *          either a group, dataset, or named datatype, all of which may\n1222\t *          have any sort of attribute. The attribute specified by the index,\n1223\t *          \\p idx, indicates the attribute to access. The value of \\p idx\n1224\t *          is a 0-based, non-negative integer. The attribute identifier\n1225\t *          returned from this function must be released with H5Aclose()\n1226\t *          or resource leaks will develop.\n1227\t *\n1228\t * \\since 1.0.0\n1229\t *\n1230\t */\n1231\tH5_DLL hid_t H5Aopen_idx(hid_t loc_id, unsigned idx);\n1232\t/* --------------------------------------------------------------------------*/\n1233\t/**\n1234\t * \\ingroup H5A\n1235\t *\n1236\t * \\brief Opens an attribute specified by name\n1237\t *\n1238\t * \\loc_id\n1239\t * \\param[in] name Attribute name\n1240\t *\n1241\t * \\return \\hid_ti{attribute}\n1242\t *\n1243\t * \\deprecation_note{H5Aopen_by_name()}\n1244\t *\n1245\t * \\details H5Aopen_name() opens an attribute specified by its name,\n1246\t *          \\p name, which is attached to the object specified with\n1247\t *          \\p loc_id. The location object may be either a group, dataset,\n1248\t *          or named datatype, which may have any sort of attribute. The\n1249\t *          attribute identifier returned from this function must be\n1250\t *          released with H5Aclose() or resource leaks will develop.\n1251\t *\n1252\t * \\since 1.0.0\n1253\t *\n1254\t */\n1255\tH5_DLL hid_t H5Aopen_name(hid_t loc_id, const char *name);\n1256\t\n1257\t#endif /* H5_NO_DEPRECATED_SYMBOLS */\n1258\t\n1259\t#ifdef __cplusplus\n1260\t}\n1261\t#endif\n1262\t\n1263\t#endif /* H5Apublic_H */\n1264\t"}]},"parent_tool_use_id":null,"session_id":"be3652af-fb85-42e7-b906-2c8c1c67ad95","uuid":"552dbac3-0b11-41f6-9a49-90668067a79a","timestamp":"2026-06-06T17:23:24.364Z","tool_use_result":{"type":"text","file":{"filePath":"/work/agent/target-src/src/H5Apublic.h","content":"/* * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *\n * Copyright by The HDF Group.                                               *\n * All rights reserved.                                                      *\n *                                                                           *\n * This file is part of HDF5.  The full HDF5 copyright notice, including     *\n * terms governing use, modification, and redistribution, is contained in    *\n * the LICENSE file, which can be found at the root of the source code       *\n * distribution tree, or in https://www.hdfgroup.org/licenses.               *\n * If you do not have access to either file, you may request a copy from     *\n * help@hdfgroup.org.                                                        *\n * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * */\n\n/*\n * This file contains public declarations for the H5A module.\n */\n#ifndef H5Apublic_H\n#define H5Apublic_H\n\n#include \"H5public.h\"  /* Generic Functions                        */\n#include \"H5Ipublic.h\" /* Identifiers                              */\n#include \"H5Opublic.h\" /* Object Headers                           */\n#include \"H5Tpublic.h\" /* Datatypes                                */\n\n//! <!-- [H5A_info_t_snip] -->\n/**\n * Information struct for H5Aget_info() / H5Aget_info_by_idx()\n */\ntypedef struct {\n    bool              corder_valid; /**< Indicate if creation order is valid */\n    H5O_msg_crt_idx_t corder;       /**< Creation order                 */\n    H5T_cset_t        cset;         /**< Character set of attribute name */\n    hsize_t           data_size;    /**< Size of raw data\t\t  */\n} H5A_info_t;\n//! <!-- [H5A_info_t_snip] -->\n\n//! <!-- [H5A_operator2_t_snip] -->\n/**\n * Typedef for H5Aiterate2() / H5Aiterate_by_name() callbacks\n * \\param[in] location_id The identifier for the group, dataset\n *            or named datatype being iterated over\n * \\param[in] attr_name The name of the current object attribute\n * \\param[in] ainfo The attribute's info struct\n * \\param[in,out] op_data A pointer to the operator data passed into\n *                H5Aiterate2() or H5Aiterate_by_name()\n * \\return The return values from an operator are:\n *          \\li Zero causes the iterator to continue, returning zero when\n *              all attributes have been processed.\n *          \\li Positive causes the iterator to immediately return that\n *              positive value, indicating short-circuit success. The\n *              iterator can be restarted at the next attribute.\n *          \\li Negative causes the iterator to immediately return that value,\n *              indicating failure. The iterator can be restarted at the next\n *              attribute.\n *\n * \\callback_note\n *\n * \\since 1.8.0\n *\n */\ntypedef herr_t (*H5A_operator2_t)(hid_t location_id /*in*/, const char *attr_name /*in*/,\n                                  const H5A_info_t *ainfo /*in*/, void *op_data /*in,out*/);\n//! <!-- [H5A_operator2_t_snip] -->\n\n/********************/\n/* Public Variables */\n/********************/\n\n/*********************/\n/* Public Prototypes */\n/*********************/\n#ifdef __cplusplus\nextern \"C\" {\n#endif\n\n/*-------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief Closes the specified attribute\n *\n * \\attr_id\n *\n * \\return \\herr_t\n *\n * \\details H5Aclose() terminates access to the attribute through\n *          \\p attr_id and releases the identifier.\n *\n * \\par Example\n * \\snippet H5A_examples.c create\n *\n * \\since 1.0.0\n *\n * \\see H5Acreate(), H5Aopen()\n */\nH5_DLL herr_t H5Aclose(hid_t attr_id);\n/*--------------------------------------------------------------------------*/\n/**\n * \\ingroup ASYNC\n * \\async_variant_of{H5Aclose}\n */\n#ifndef H5_DOXYGEN\nH5_DLL herr_t H5Aclose_async(const char *app_file, const char *app_func, unsigned app_line, hid_t attr_id,\n                             hid_t es_id);\n#else\nH5_DLL herr_t H5Aclose_async(hid_t attr_id, hid_t es_id);\n#endif\n/* --------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief Creates an attribute attached to a specified object\n *\n * \\fgdt_loc_id\n * \\param[in] attr_name  Name of attribute\n * \\param[in] type_id    Attribute datatype identifier\n * \\space_id\n * \\acpl_id\n * \\aapl_id\n *\n * \\return \\hid_ti{attribute}\n *\n * \\details H5Acreate2() creates an attribute, \\p attr_name, which is attached\n *          to the object specified by the identifier \\p loc_id.\n *\n *          The attribute name, \\p attr_name, must be unique for the object.\n *\n *          The attribute is created with the specified datatype and dataspace,\n *          \\p type_id and \\p space_id.\n *\n *          \\plist_unused{aapl_id}\n *\n *          The attribute identifier returned by this function must be released\n *          with H5Aclose() or resource leaks will develop.\n *\n * \\note If \\p loc_id is a file identifier, the attribute will be attached to\n *       that file's root group.\n *\n * \\par Example\n * \\snippet H5A_examples.c create\n *\n * \\since 1.8.0\n *\n * \\see H5Aclose()\n *\n */\nH5_DLL hid_t H5Acreate2(hid_t loc_id, const char *attr_name, hid_t type_id, hid_t space_id, hid_t acpl_id,\n                        hid_t aapl_id);\n/*--------------------------------------------------------------------------*/\n/**\n * \\ingroup ASYNC\n * \\async_variant_of{H5Acreate}\n */\n#ifndef H5_DOXYGEN\nH5_DLL hid_t H5Acreate_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n                             const char *attr_name, hid_t type_id, hid_t space_id, hid_t acpl_id,\n                             hid_t aapl_id, hid_t es_id);\n#else\nH5_DLL hid_t H5Acreate_async(hid_t loc_id, const char *attr_name, hid_t type_id, hid_t space_id,\n                             hid_t acpl_id, hid_t aapl_id, hid_t es_id);\n#endif\n\n/*--------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief  Creates an attribute attached to a specified object\n *\n * \\fgdt_loc_id\n * \\param[in] obj_name  Name, relative to \\p loc_id, of object that\n *                      attribute is to be attached to\n * \\param[in] attr_name Attribute name\n * \\param[in] type_id   Attribute datatype identifier\n * \\space_id\n * \\acpl_id\n * \\aapl_id\n * \\lapl_id\n *\n * \\return \\hid_ti{attribute}\n *\n * \\details H5Acreate_by_name() creates an attribute, \\p attr_name, which is\n *          attached to the object specified by \\p loc_id and \\p obj_name.\n *\n *          \\p loc_id is a location identifier; \\p obj_name is the object\n *          name relative to \\p loc_id.\n *\n *          The attribute name, \\p attr_name, must be unique for the object.\n *\n *          The attribute is created with the specified datatype and\n *          dataspace, \\p type_id and \\p space_id.\n *\n *          \\plist_unused{aapl_id}\n *\n *          The link access property list, \\p lapl_id, may provide\n *          information regarding the properties of links required to access\n *          the object, \\p obj_name.\n *\n * \\since 1.8.0\n *\n */\nH5_DLL hid_t H5Acreate_by_name(hid_t loc_id, const char *obj_name, const char *attr_name, hid_t type_id,\n                               hid_t space_id, hid_t acpl_id, hid_t aapl_id, hid_t lapl_id);\n/*--------------------------------------------------------------------------*/\n/**\n * \\ingroup ASYNC\n * \\async_variant_of{H5Acreate_by_name}\n */\n#ifndef H5_DOXYGEN\nH5_DLL hid_t H5Acreate_by_name_async(const char *app_file, const char *app_func, unsigned app_line,\n                                     hid_t loc_id, const char *obj_name, const char *attr_name, hid_t type_id,\n                                     hid_t space_id, hid_t acpl_id, hid_t aapl_id, hid_t lapl_id,\n                                     hid_t es_id);\n#else\nH5_DLL hid_t H5Acreate_by_name_async(hid_t loc_id, const char *obj_name, const char *attr_name, hid_t type_id,\n                                     hid_t space_id, hid_t acpl_id, hid_t aapl_id, hid_t lapl_id,\n                                     hid_t es_id);\n#endif\n\n/*-------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief Deletes an attribute from a specified location\n *\n * \\fgdt_loc_id\n * \\param[in] attr_name  Name of the attribute to delete\n *\n * \\return \\herr_t\n *\n * \\details H5Adelete() removes the attribute specified by its name,\n *          \\p attr_name, from a file, dataset, group, or named datatype.\n *\n * \\attention This function should not be used when other attribute identifiers\n *            are open on \\p loc_id. This may cause the internal indexes of\n *            the attributes to change and future writes to the open\n *            attributes to produce incorrect results.\n *\n * \\par Example\n * \\snippet H5A_examples.c delete\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Adelete(hid_t loc_id, const char *attr_name);\n/*-------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief Deletes an attribute from an object according to index order\n *\n * \\fgdt_loc_id\n * \\param[in] obj_name Name of object, relative to location, from which\n *                     attribute is to be removed\n * \\param[in] idx_type Type of index\n * \\param[in] order    Order in which to iterate over the index\n * \\param[in] n        Offset within the index\n * \\lapl_id\n *\n * \\return \\herr_t\n *\n * \\details H5Adelete_by_idx() removes an attribute specified by its\n *          location in an index, from an object.\n *\n *          The object from which the attribute is to be removed is\n *          specified by a location identifier and name, \\p loc_id and\n *          \\p obj_name, respectively.\n *\n *          The attribute to be removed is specified by a position in an\n *          index, \\p n. The type of index is specified by \\p idx_type.\n *          The order in which the index is to be traversed is specified by\n *          \\p order. For example, if \\p idx_type, \\p order,\n *          and \\p n are set to #H5_INDEX_NAME, #H5_ITER_INC, and 5,\n *          respectively, the fifth attribute in the lexicographic order of\n *          attribute names will be removed.\n *\n *          The link access property list, \\p lapl_id, may provide\n *          information regarding the properties of links required to access\n *          the object, \\p obj_name.\n\n * \\since 1.8.0\n *\n */\nH5_DLL herr_t H5Adelete_by_idx(hid_t loc_id, const char *obj_name, H5_index_t idx_type, H5_iter_order_t order,\n                               hsize_t n, hid_t lapl_id);\n/*-------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief Removes an attribute from a specified location\n *\n * \\fgdt_loc_id\n * \\param[in] obj_name  Name of object, relative to location, from which\n *                      attribute is to be removed\n * \\param[in] attr_name Name of attribute to delete\n * \\lapl_id\n *\n * \\return \\herr_t\n *\n * \\details H5Adelete_by_name() removes the attribute \\p attr_name\n *          from an object specified by location and name, \\p loc_id and\n *          \\p obj_name, respectively.\n *\n *          The link access property list, \\p lapl_id, may provide\n *          information regarding the properties of links required to\n *          access the object, \\p obj_name.\n *\n * \\since 1.8.0\n *\n */\nH5_DLL herr_t H5Adelete_by_name(hid_t loc_id, const char *obj_name, const char *attr_name, hid_t lapl_id);\n/*-------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief Determines whether an attribute with a given name exists on an\n *        object\n *\n * \\fgdt_loc_id{obj_id}\n * \\param[in] attr_name  Attribute name\n *\n * \\return \\htri_t\n *\n * \\details H5Aexists() determines whether the attribute \\p attr_name\n *          exists on the object specified by \\p obj_id.\n *\n * \\since 1.8.0\n *\n */\nH5_DLL htri_t H5Aexists(hid_t obj_id, const char *attr_name);\n/*--------------------------------------------------------------------------*/\n/**\n * \\ingroup ASYNC\n * \\async_variant_of{H5Aexists}\n */\n#ifndef H5_DOXYGEN\nH5_DLL herr_t H5Aexists_async(const char *app_file, const char *app_func, unsigned app_line, hid_t obj_id,\n                              const char *attr_name, bool *exists, hid_t es_id);\n#else\nH5_DLL herr_t H5Aexists_async(hid_t obj_id, const char *attr_name, bool *exists, hid_t es_id);\n#endif\n\n/*-------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief  Determines whether an attribute with a given name exists on an\n *         object\n *\n * \\fgdt_loc_id{obj_id}\n * \\param[in] obj_name  Object name\n * \\param[in] attr_name Attribute name\n * \\lapl_id\n *\n * \\return \\htri_t\n *\n * \\details H5Aexists_by_name() determines whether the attribute\n *          \\p attr_name exists on an object. That object is specified by\n *          its location and name, \\p loc_id and \\p obj_name, respectively.\n *\n *          \\p loc_id specifies a location in the file containing the object.\n *          \\p obj_name is the name of the object to which the attribute is\n *          attached and can be a relative name, relative to \\p loc_id,\n *          or an absolute name, based on the root group of the file.\n *\n *          The link access property list, \\p lapl_id, may provide\n *          information regarding the properties of links required to access\n *          \\p obj_name.\n *\n * \\since 1.8.0\n *\n */\nH5_DLL htri_t H5Aexists_by_name(hid_t obj_id, const char *obj_name, const char *attr_name, hid_t lapl_id);\n/*--------------------------------------------------------------------------*/\n/**\n * \\ingroup ASYNC\n * \\async_variant_of{H5Aexists_by_name}\n */\n#ifndef H5_DOXYGEN\nH5_DLL herr_t H5Aexists_by_name_async(const char *app_file, const char *app_func, unsigned app_line,\n                                      hid_t loc_id, const char *obj_name, const char *attr_name, bool *exists,\n                                      hid_t lapl_id, hid_t es_id);\n#else\nH5_DLL herr_t H5Aexists_by_name_async(hid_t loc_id, const char *obj_name, const char *attr_name, bool *exists,\n                                      hid_t lapl_id, hid_t es_id);\n#endif\n\n/*-------------------------------------------------------------------------*/\n/**\n * \\ingroup H5A\n *\n * \\brief Gets an attribute creation property list identifier\n *\n * \\attr_id\n *\n * \\return \\hid_ti{attribute's creation property list}\n *\n * \\details H5Aget_create_plist() returns an identifier for the attribute\n *          creation property list associated with the attribute specified\n *          by \\p attr_id.\n *\n *          The creation property list identifier should be released with\n *          H5Pclose() to prevent