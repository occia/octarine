{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RUChKh7UWAjPjVS18jgbjY","type":"tool_result","content":"1\t/* * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *\n2\t * Copyright by The HDF Group.                                               *\n3\t * All rights reserved.                                                      *\n4\t *                                                                           *\n5\t * This file is part of HDF5.  The full HDF5 copyright notice, including     *\n6\t * terms governing use, modification, and redistribution, is contained in    *\n7\t * the LICENSE file, which can be found at the root of the source code       *\n8\t * distribution tree, or in https://www.hdfgroup.org/licenses.               *\n9\t * If you do not have access to either file, you may request a copy from     *\n10\t * help@hdfgroup.org.                                                        *\n11\t * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * */\n12\t\n13\t/*-------------------------------------------------------------------------\n14\t *\n15\t * Created:             H5Gpublic.h\n16\t *\n17\t * Purpose:             Public declarations for the H5G package\n18\t *\n19\t *-------------------------------------------------------------------------\n20\t */\n21\t#ifndef H5Gpublic_H\n22\t#define H5Gpublic_H\n23\t\n24\t#include \"H5public.h\"  /* Generic Functions                        */\n25\t#include \"H5Ipublic.h\" /* Identifiers                              */\n26\t#include \"H5Lpublic.h\" /* Links                                    */\n27\t#include \"H5Opublic.h\" /* Object Headers                           */\n28\t\n29\t/*****************/\n30\t/* Public Macros */\n31\t/*****************/\n32\t\n33\t/*******************/\n34\t/* Public Typedefs */\n35\t/*******************/\n36\t\n37\t//! <!-- [H5G_storage_t_snip] -->\n38\t/**\n39\t * Types of link storage for groups\n40\t */\n41\ttypedef enum H5G_storage_type_t {\n42\t    H5G_STORAGE_TYPE_UNKNOWN = -1, /**< Unknown link storage type\t*/\n43\t    H5G_STORAGE_TYPE_SYMBOL_TABLE, /**< Links in group are stored with a \"symbol table\" */\n44\t                                   /**< (this is sometimes called \"old-style\" groups) */\n45\t    H5G_STORAGE_TYPE_COMPACT,      /**< Links are stored in object header */\n46\t    H5G_STORAGE_TYPE_DENSE         /**< Links are stored in fractal heap & indexed with v2 B-tree */\n47\t} H5G_storage_type_t;\n48\t//! <!-- [H5G_storage_t_snip] -->\n49\t\n50\t//! <!-- [H5G_info_t_snip] -->\n51\t/**\n52\t * Information struct for group for\n53\t * H5Gget_info(), H5Gget_info_by_name(), and H5Gget_info_by_idx()\n54\t */\n55\ttypedef struct H5G_info_t {\n56\t    H5G_storage_type_t storage_type; /**< Type of storage for links in group */\n57\t    hsize_t            nlinks;       /**< Number of links in group */\n58\t    int64_t            max_corder;   /**< Current max. creation order value for group */\n59\t    bool               mounted;      /**< Whether group has a file mounted on it */\n60\t} H5G_info_t;\n61\t//! <!-- [H5G_info_t_snip] -->\n62\t\n63\t/********************/\n64\t/* Public Variables */\n65\t/********************/\n66\t\n67\t/*********************/\n68\t/* Public Prototypes */\n69\t/*********************/\n70\t#ifdef __cplusplus\n71\textern \"C\" {\n72\t#endif\n73\t\n74\t/**\n75\t *-------------------------------------------------------------------------\n76\t * \\ingroup H5G\n77\t *\n78\t * \\brief Creates a new group and links it into the file\n79\t *\n80\t * \\fgdta_loc_id\n81\t * \\param[in] name      Name of the group to create\n82\t * \\lcpl_id\n83\t * \\gcpl_id\n84\t * \\gapl_id\n85\t *\n86\t * \\return \\hid_t{group}\n87\t *\n88\t * \\details H5Gcreate2() creates a new group in a file. After a\n89\t *          group has been created, links to datasets and to other groups\n90\t *          can be added.\n91\t *\n92\t *          The \\p loc_id and \\p name parameters specify where the group\n93\t *          is located. \\p loc_id may be a file, group, dataset, named\n94\t *          datatype or attribute in the file. If an attribute, dataset,\n95\t *          or named datatype is specified for \\p loc_id then the group\n96\t *          will be created at the location where the attribute, dataset,\n97\t *          or named datatype is attached. \\p name is the link to the group;\n98\t *          \\p name may be either an absolute path in the file (the links\n99\t *          from the root group to the new group) or a relative path from\n100\t *          \\p loc_id (the link(s) from the group specified by \\p loc_id\n101\t *          to the new group).\n102\t *\n103\t *          \\p lcpl_id, \\p gcpl_id, and \\p gapl_id are property list\n104\t *          identifiers. These property lists govern how the link to the\n105\t *          group is created, how the group is created, and how the group\n106\t *          can be accessed in the future, respectively. #H5P_DEFAULT can\n107\t *          be passed in if the default properties are appropriate for\n108\t *          these property lists. Currently, there are no APIs for the\n109\t *          group access property list; use #H5P_DEFAULT.\n110\t *\n111\t *          The group identifier should be closed by H5Gclose() when access\n112\t *          is no longer required to prevent resource leaks.\n113\t *\n114\t * \\since 1.8.0\n115\t *\n116\t * \\see H5Gopen2()\n117\t *\n118\t */\n119\tH5_DLL hid_t H5Gcreate2(hid_t loc_id, const char *name, hid_t lcpl_id, hid_t gcpl_id, hid_t gapl_id);\n120\t\n121\t/**\n122\t * --------------------------------------------------------------------------\n123\t * \\ingroup ASYNC\n124\t * \\async_variant_of{H5Gcreate}\n125\t */\n126\t#ifndef H5_DOXYGEN\n127\tH5_DLL hid_t H5Gcreate_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n128\t                             const char *name, hid_t lcpl_id, hid_t gcpl_id, hid_t gapl_id, hid_t es_id);\n129\t#else\n130\tH5_DLL hid_t H5Gcreate_async(hid_t loc_id, const char *name, hid_t lcpl_id, hid_t gcpl_id, hid_t gapl_id,\n131\t                             hid_t es_id);\n132\t#endif\n133\t\n134\t/**\n135\t *-------------------------------------------------------------------------\n136\t * \\ingroup H5G\n137\t *\n138\t * \\brief Creates a new empty group without linking it into the file structure\n139\t *\n140\t * \\fgdta_loc_id\n141\t * \\gcpl_id\n142\t * \\gapl_id\n143\t *\n144\t * \\return \\hid_t{group}\n145\t *\n146\t * \\details H5Gcreate_anon() creates a new empty group in the file\n147\t *          specified by \\p loc_id. With default settings, H5Gcreate_anon()\n148\t *          provides similar functionality to that provided by\n149\t *          H5Gcreate1(), with the differences described in the list below.\n150\t *\n151\t *          The new group's creation and access properties are specified\n152\t *          in \\p gcpl_id and \\p gapl_id, respectively.\n153\t *\n154\t *          H5Gcreate_anon() returns a new group identifier. This identifier\n155\t *          must be linked into the HDF5 file structure with H5Olink()\n156\t *          or it will be deleted from the file when the file is closed.\n157\t *\n158\t *          The differences between this function and H5Gcreate1() are\n159\t *          as follows:\n160\t *\n161\t *          \\li H5Gcreate1() does not provide for the use of custom property\n162\t *              lists; H5Gcreate1() always uses default properties.\n163\t *          \\li H5Gcreate_anon() neither provides the new group's name\n164\t *              nor links it into the HDF5 file structure; those actions\n165\t *              must be performed separately through a call to H5Olink(),\n166\t *              which offers greater control over linking.\n167\t *          \\li H5Gcreate_anon() does not directly provide a hint mechanism\n168\t *              for the group's heap size. Comparable information can be\n169\t *              included in the group creation property list \\p gcpl_id through\n170\t *              a H5Pset_local_heap_size_hint() call.\n171\t *\n172\t *          A group created with this function should be closed with\n173\t *          H5Gclose() when the group is no longer needed so that resource\n174\t *          leaks will not develop.\n175\t *\n176\t * \\see H5Olink(), H5Gcreate()\n177\t *\n178\t * \\since 1.8.0\n179\t *\n180\t */\n181\tH5_DLL hid_t H5Gcreate_anon(hid_t loc_id, hid_t gcpl_id, hid_t gapl_id);\n182\t\n183\t/**\n184\t *-------------------------------------------------------------------------\n185\t * \\ingroup H5G\n186\t *\n187\t * \\brief Opens an existing group in a file\n188\t *\n189\t * \\fgdta_loc_id\n190\t * \\param[in] name      Name of the group to open\n191\t * \\gapl_id\n192\t *\n193\t * \\return \\hid_t{group}\n194\t *\n195\t * \\details H5Gopen2() opens an existing group, \\p name, at the location\n196\t *          specified by \\p loc_id.\n197\t *\n198\t *          With default settings, H5Gopen2() provides similar functionality\n199\t *          to that provided by H5Gopen(). The only difference is that\n200\t *          H5Gopen2() can provide a group access property list, \\p gapl_id.\n201\t *\n202\t *          H5Gopen2() returns a group identifier for the group that was\n203\t *          opened. This group identifier should be released by H5Gclose()\n204\t *          when it is no longer needed to prevent resource leaks.\n205\t *\n206\t * \\since 1.8.0\n207\t *\n208\t * \\see H5Gcreate2()\n209\t *\n210\t */\n211\tH5_DLL hid_t H5Gopen2(hid_t loc_id, const char *name, hid_t gapl_id);\n212\t\n213\t/**\n214\t * --------------------------------------------------------------------------\n215\t * \\ingroup ASYNC\n216\t * \\async_variant_of{H5Gopen}\n217\t *\n218\t * \\since 1.12.0\n219\t *\n220\t */\n221\t#ifndef H5_DOXYGEN\n222\tH5_DLL hid_t H5Gopen_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n223\t                           const char *name, hid_t gapl_id, hid_t es_id);\n224\t#else\n225\tH5_DLL hid_t H5Gopen_async(hid_t loc_id, const char *name, hid_t gapl_id, hid_t es_id);\n226\t#endif\n227\t\n228\t/**\n229\t *-------------------------------------------------------------------------\n230\t * \\ingroup H5G\n231\t *\n232\t * \\brief Gets a group creation property list identifier\n233\t *\n234\t * \\group_id\n235\t *\n236\t * \\return \\hid_t{creation property list}\n237\t *\n238\t * \\details H5Gget_create_plist() returns an identifier for the group creation\n239\t *          property list associated with the group specified by \\p group_id.\n240\t *\n241\t *          The creation property list identifier should be released with\n242\t *          H5Pclose() to prevent resource leaks.\n243\t *\n244\t * \\since 1.8.0\n245\t *\n246\t */\n247\tH5_DLL hid_t H5Gget_create_plist(hid_t group_id);\n248\t\n249\t/**\n250\t *-------------------------------------------------------------------------\n251\t * \\ingroup H5G\n252\t *\n253\t * \\brief Retrieves information about a group\n254\t *\n255\t * \\fgdta_loc_id\n256\t * \\param[out] ginfo Struct in which group information is returned\n257\t *\n258\t * \\return \\hid_t{group}\n259\t *\n260\t * \\details H5Gget_info() retrieves information about the group at location\n261\t *          specified by \\p loc_id. The information is returned in the \\p ginfo.\n262\t *\n263\t *          \\p ginfo is an H5G_info_t struct and is defined (in H5Gpublic.h)\n264\t *          as follows:\n265\t *\n266\t * \\snippet this H5G_info_t_snip\n267\t * Possible values of \\p storage_type are:\n268\t * \\storage_type\n269\t *\n270\t * \\since 1.8.0\n271\t *\n272\t */\n273\tH5_DLL herr_t H5Gget_info(hid_t loc_id, H5G_info_t *ginfo);\n274\t\n275\t/**\n276\t * --------------------------------------------------------------------------\n277\t * \\ingroup ASYNC\n278\t * \\async_variant_of{H5Gget_info}\n279\t *\n280\t * \\since 1.12.0\n281\t *\n282\t */\n283\t#ifndef H5_DOXYGEN\n284\tH5_DLL herr_t H5Gget_info_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n285\t                                H5G_info_t *ginfo /*out*/, hid_t es_id);\n286\t#else\n287\tH5_DLL herr_t H5Gget_info_async(hid_t loc_id, H5G_info_t *ginfo /*out*/, hid_t es_id);\n288\t#endif\n289\t\n290\t/**\n291\t *-------------------------------------------------------------------------\n292\t * \\ingroup H5G\n293\t *\n294\t * \\brief Retrieves information about a group by its name\n295\t *\n296\t * \\fgdta_loc_id\n297\t * \\param[in] name      Name of the group to query\n298\t * \\param[out] ginfo Struct in which group information is returned\n299\t * \\lapl_id\n300\t *\n301\t * \\return \\herr_t\n302\t *\n303\t * \\details H5Gget_info_by_name() retrieves information about the group \\p name\n304\t *          at location specified by \\p loc_id. The information is returned in\n305\t *          the \\p ginfo struct.\n306\t *\n307\t *          If \\p loc_id specifies the group for which information is queried,\n308\t *          then the group's \\p name can be a dot (.).\n309\t *\n310\t *          \\p ginfo is an H5G_info_t struct and is defined (in H5Gpublic.h)\n311\t *          as follows:\n312\t *\n313\t * \\snippet this H5G_info_t_snip\n314\t * Possible values of \\p storage_type are:\n315\t * \\storage_type\n316\t *\n317\t * \\since 1.8.0\n318\t *\n319\t */\n320\tH5_DLL herr_t H5Gget_info_by_name(hid_t loc_id, const char *name, H5G_info_t *ginfo, hid_t lapl_id);\n321\t\n322\t/**\n323\t * --------------------------------------------------------------------------\n324\t * \\ingroup ASYNC\n325\t * \\async_variant_of{H5Gget_info_by_name}\n326\t *\n327\t * \\since 1.12.0\n328\t *\n329\t */\n330\t#ifndef H5_DOXYGEN\n331\tH5_DLL herr_t H5Gget_info_by_name_async(const char *app_file, const char *app_func, unsigned app_line,\n332\t                                        hid_t loc_id, const char *name, H5G_info_t *ginfo /*out*/,\n333\t                                        hid_t lapl_id, hid_t es_id);\n334\t#else\n335\tH5_DLL herr_t H5Gget_info_by_name_async(hid_t loc_id, const char *name, H5G_info_t *ginfo /*out*/,\n336\t                                        hid_t lapl_id, hid_t es_id);\n337\t#endif\n338\t\n339\t/**\n340\t *-------------------------------------------------------------------------\n341\t * \\ingroup H5G\n342\t *\n343\t * \\brief Retrieves information about a group, according to the group's\n344\t *        position within an index\n345\t *\n346\t * \\fgdta_loc_id\n347\t * \\param[in] group_name Name of the group to query\n348\t * \\param[in] idx_type   Transient index identifying object\n349\t * \\param[in] order      Transient index identifying object\n350\t * \\param[in] n          Position in the index of the group to query\n351\t * \\param[out] ginfo     Struct in which group information is returned\n352\t * \\lapl_id\n353\t *\n354\t * \\return Returns\n355\t *      \\li The size of the object name if successful, or\n356\t *      \\li 0 if no name is associated with the group identifier, or\n357\t *      \\li negative value, if failure occurred\n358\t *\n359\t * \\details H5Gget_info_by_idx() retrieves the same information\n360\t *          about a group as retrieved by the function H5Gget_info(),\n361\t *          but the means of identifying the group differs; the group is\n362\t *          identified by position in an index rather than by name.\n363\t *\n364\t *          \\p loc_id and \\p group_name specify the group containing\n365\t *          the group for which information is sought. The groups in \\p\n366\t *          group_name are indexed by \\p idx_type; the group for which\n367\t *          information is retrieved is identified in that index by index\n368\t *          order, \\p order, and index position, \\p n.\n369\t *\n370\t *          If \\p loc_id specifies the group containing the group for\n371\t *          which information is queried, \\p group_name can be a dot (.).\n372\t *\n373\t *          Valid values for \\p index_type are as follows:\n374\t * \\indexes\n375\t *          The order in which the index is to be examined, as specified\n376\t *          by \\p order, can be one of the following:\n377\t * \\orders\n378\t *\n379\t * \\since 1.8.0\n380\t *\n381\t */\n382\tH5_DLL herr_t H5Gget_info_by_idx(hid_t loc_id, const char *group_name, H5_index_t idx_type,\n383\t                                 H5_iter_order_t order, hsize_t n, H5G_info_t *ginfo, hid_t lapl_id);\n384\t\n385\t/**\n386\t * --------------------------------------------------------------------------\n387\t * \\ingroup ASYNC\n388\t * \\async_variant_of{H5Gget_info_by_idx}\n389\t *\n390\t * \\since 1.12.0\n391\t *\n392\t */\n393\t#ifndef H5_DOXYGEN\n394\tH5_DLL herr_t H5Gget_info_by_idx_async(const char *app_file, const char *app_func, unsigned app_line,\n395\t                                       hid_t loc_id, const char *group_name, H5_index_t idx_type,\n396\t                                       H5_iter_order_t order, hsize_t n, H5G_info_t *ginfo /*out*/,\n397\t                                       hid_t lapl_id, hid_t es_id);\n398\t#else\n399\tH5_DLL herr_t H5Gget_info_by_idx_async(hid_t loc_id, const char *group_name, H5_index_t idx_type,\n400\t                                       H5_iter_order_t order, hsize_t n, H5G_info_t *ginfo /*out*/,\n401\t                                       hid_t lapl_id, hid_t es_id);\n402\t#endif\n403\t\n404\t/**\n405\t *-------------------------------------------------------------------------\n406\t * \\ingroup H5G\n407\t *\n408\t * \\brief Flushes all buffers associated with a group to disk\n409\t *\n410\t * \\group_id\n411\t *\n412\t * \\return \\herr_t\n413\t *\n414\t * \\details H5Gflush() causes all buffers associated with a group to be\n415\t *          immediately flushed to the disk without removing the data from\n416\t *          the cache.\n417\t *\n418\t * \\attention\n419\t *          HDF5 does not possess full control over buffering. H5G_FLUSH\n420\t *          flushes the internal HDF5 buffers and then asks the operating\n421\t *          system (the OS) to flush the system buffers for the open\n422\t *          files. After that, the OS is responsible for ensuring that\n423\t *          the data is actually flushed to the disk.\n424\t *\n425\t * \\since 1.8.0\n426\t *\n427\t */\n428\tH5_DLL herr_t H5Gflush(hid_t group_id);\n429\t\n430\t/**\n431\t *-------------------------------------------------------------------------\n432\t * \\ingroup H5G\n433\t *\n434\t * \\brief Refreshes all buffers associated with a group\n435\t *\n436\t * \\group_id\n437\t *\n438\t * \\return \\herr_t\n439\t *\n440\t * \\details H5Grefresh() causes all buffers associated with a group to be\n441\t *          cleared and immediately re-loaded with updated contents from disk.\n442\t *\n443\t *          This function essentially closes the group, evicts all\n444\t *          metadata associated with it from the cache, and then reopens\n445\t *          the group. The reopened group is automatically re-registered\n446\t *          with the same identifier.\n447\t *\n448\t * \\since 1.8.0\n449\t *\n450\t */\n451\tH5_DLL herr_t H5Grefresh(hid_t group_id);\n452\t\n453\t/**\n454\t *-------------------------------------------------------------------------\n455\t * \\ingroup H5G\n456\t *\n457\t * \\brief Closes the specified group\n458\t *\n459\t * \\group_id\n460\t *\n461\t * \\return \\herr_t\n462\t *\n463\t * \\details H5Gclose() releases resources used by a group that was\n464\t *          opened by H5Gcreate() or H5Gopen().  After closing a group,\n465\t *          \\p group_id cannot be used again until another H5Gcreate()\n466\t *          or H5Gopen() is called on it.\n467\t *\n468\t *          Failure to release a group with this call will result in\n469\t *          resource leaks.\n470\t *\n471\t * \\par Example\n472\t * \\snippet H5F_examples.c mount\n473\t *\n474\t * \\since 1.0.0\n475\t *\n476\t */\n477\tH5_DLL herr_t H5Gclose(hid_t group_id);\n478\t\n479\t/**\n480\t * --------------------------------------------------------------------------\n481\t * \\ingroup ASYNC\n482\t * \\async_variant_of{H5Gclose}\n483\t *\n484\t * \\since 1.12.0\n485\t *\n486\t */\n487\t#ifndef H5_DOXYGEN\n488\tH5_DLL herr_t H5Gclose_async(const char *app_file, const char *app_func, unsigned app_line, hid_t group_id,\n489\t                             hid_t es_id);\n490\t#else\n491\tH5_DLL herr_t H5Gclose_async(hid_t group_id, hid_t es_id);\n492\t#endif\n493\t\n494\t/// \\cond DEV\n495\t/* API Wrappers for async routines */\n496\t/* (Must be defined _after_ the function prototype) */\n497\t/* (And must only defined when included in application code, not the library) */\n498\t#ifndef H5G_MODULE\n499\t#define H5Gcreate_async(...)           H5Gcreate_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n500\t#define H5Gopen_async(...)             H5Gopen_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n501\t#define H5Gget_info_async(...)         H5Gget_info_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n502\t#define H5Gget_info_by_name_async(...) H5Gget_info_by_name_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n503\t#define H5Gget_info_by_idx_async(...)  H5Gget_info_by_idx_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n504\t#define H5Gclose_async(...)            H5Gclose_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n505\t\n506\t/* Define \"wrapper\" versions of function calls, to allow compile-time values to\n507\t *      be passed in by language wrapper or library layer on top of HDF5.\n508\t */\n509\t#define H5Gcreate_async_wrap           H5_NO_EXPAND(H5Gcreate_async)\n510\t#define H5Gopen_async_wrap             H5_NO_EXPAND(H5Gopen_async)\n511\t#define H5Gget_info_async_wrap         H5_NO_EXPAND(H5Gget_info_async)\n512\t#define H5Gget_info_by_name_async_wrap H5_NO_EXPAND(H5Gget_info_by_name_async)\n513\t#define H5Gget_info_by_idx_async_wrap  H5_NO_EXPAND(H5Gget_info_by_idx_async)\n514\t#define H5Gclose_async_wrap            H5_NO_EXPAND(H5Gclose_async)\n515\t#endif /* H5G_MODULE */\n516\t/// \\endcond\n517\t\n518\t/* Symbols defined for compatibility with previous versions of the HDF5 API.\n519\t *\n520\t * Use of these symbols is deprecated.\n521\t */\n522\t#ifndef H5_NO_DEPRECATED_SYMBOLS\n523\t\n524\t/* Macros */\n525\t\n526\t/* Link definitions */\n527\t#define H5G_SAME_LOC   H5L_SAME_LOC   /**< Indicates operation occurs on same location \\since 1.6.0 */\n528\t#define H5G_LINK_ERROR H5L_TYPE_ERROR /**< Invalid link type id \\since 1.8.0 */\n529\t#define H5G_LINK_HARD  H5L_TYPE_HARD  /**< Hard link id \\since 1.8.0 */\n530\t#define H5G_LINK_SOFT  H5L_TYPE_SOFT  /**< Soft link id \\since 1.8.0 */\n531\t#define H5G_link_t     H5L_type_t     /**< Link types \\since 1.0.0 */\n532\t\n533\t/* Macros for types of objects in a group (see H5G_obj_t definition) */\n534\t#define H5G_NTYPES     256 /**< Max possible number of types \\since 1.0.0 */\n535\t#define H5G_NLIBTYPES  8   /**< Number of internal types \\since 1.2.0 */\n536\t#define H5G_NUSERTYPES (H5G_NTYPES - H5G_NLIBTYPES)\n537\t/**< Number of user-defined types \\since 1.2.0 */\n538\t#define H5G_USERTYPE(X) (8 + (X)) /**< User defined types \\since 1.2.0 */\n539\t\n540\t/* Typedefs */\n541\t\n542\t//! <!-- [H5G_obj_t_snip] -->\n543\t/**\n544\t * An object has a certain type. The first few numbers are reserved for use\n545\t * internally by HDF5. Users may add their own types with higher values.  The\n546\t * values are never stored in the file -- they only exist while an application\n547\t * is running.  An object may satisfy the `isa` function for more than one type.\n548\t *\n549\t * \\deprecated\n550\t */\n551\ttypedef enum H5G_obj_t {\n552\t    H5G_UNKNOWN = -1, /**< Unknown object type\t\t*/\n553\t    H5G_GROUP,        /**< Object is a group\t\t*/\n554\t    H5G_DATASET,      /**< Object is a dataset\t\t*/\n555\t    H5G_TYPE,         /**< Object is a named data type\t*/\n556\t    H5G_LINK,         /**< Object is a symbolic link\t*/\n557\t    H5G_UDLINK,       /**< Object is a user-defined link */\n558\t    H5G_RESERVED_5,   /**< Reserved for future use\t*/\n559\t    H5G_RESERVED_6,   /**< Reserved for future use\t*/\n560\t    H5G_RESERVED_7    /**< Reserved for future use\t*/\n561\t} H5G_obj_t;\n562\t//! <!-- [H5G_obj_t_snip] -->\n563\t\n564\t//! <!-- [H5G_iterate_t_snip] -->\n565\t/**\n566\t * Callback for H5Giterate()\n567\t *\n568\t * \\deprecated\n569\t */\n570\ttypedef herr_t (*H5G_iterate_t)(hid_t group, const char *name, void *op_data);\n571\t//! <!-- [H5G_iterate_t_snip] -->\n572\t\n573\t//! <!-- [H5G_stat_t_snip] -->\n574\t/**\n575\t * Information about an object\n576\t *\n577\t * \\deprecated\n578\t */\n579\ttypedef struct H5G_stat_t {\n580\t    unsigned long fileno[2]; /**< file number\t\t\t*/\n581\t    unsigned long objno[2];  /**< object number\t\t\t*/\n582\t    unsigned      nlink;     /**< number of hard links to object*/\n583\t    H5G_obj_t     type;      /**< basic object type\t\t*/\n584\t    time_t        mtime;     /**< modification time\t\t*/\n585\t    size_t        linklen;   /**< symbolic link value length\t*/\n586\t    H5O_stat_t    ohdr;      /**< Object header information    */\n587\t} H5G_stat_t;\n588\t//! <!-- [H5G_stat_t_snip] -->\n589\t\n590\t/* Function prototypes */\n591\t/**\n592\t *-------------------------------------------------------------------------\n593\t * \\ingroup H5G\n594\t *\n595\t * \\brief Creates a new group and links it into the file\n596\t *\n597\t * \\fgdta_loc_id\n598\t * \\param[in] name      Name of the group to create\n599\t * \\param[in] size_hint The number of bytes to reserve for the names\n600\t *                      that will appear in the group\n601\t *\n602\t * \\return \\hid_t{group}\n603\t *\n604\t * \\deprecated This function is deprecated in favor of H5Gcreate2().\n605\t *\n606\t * \\details H5Gcreate1() creates a new group with the specified name at the\n607\t *          specified location, \\p loc_id.  \\p loc_id may be a file, group,\n608\t *          dataset, named datatype or attribute.  If an attribute, dataset, or\n609\t *          named datatype is specified for \\p loc_id then the group will be\n610\t *          created at the location where the attribute, dataset, or named\n611\t *          datatype is attached. The name, name, must not already be taken by\n612\t *          some other object and all parent groups must already exist.\n613\t *\n614\t *          \\p name can be a relative path based at \\p loc_id or an absolute\n615\t *          path from the root of the file. Use of this function requires that\n616\t *          any intermediate groups specified in the path already exist.\n617\t *\n618\t *          The length of a group name, or of the name of any object within a\n619\t *          group, is not limited.\n620\t *\n621\t *          \\p size_hint is a hint for the number of bytes to reserve to store\n622\t *          the names which will be eventually added to the new group. This\n623\t *          value must be between 0 and UINT32_MAX (inclusive). If this\n624\t *          parameter is zero, a default value will be used.\n625\t *\n626\t *          The return value is a group identifier for the open group. This\n627\t *          group identifier should be closed by calling H5Gclose() when it is\n628\t *          no longer needed.\n629\t *\n630\t *          See H5Gcreate_anon() for a discussion of the differences between\n631\t *          H5Gcreate1() and H5Gcreate_anon().\n632\t *\n633\t * \\par Example\n634\t * \\snippet H5F_examples.c mount\n635\t *\n636\t * \\version 1.8.0 Function H5Gcreate() renamed to H5Gcreate1() and deprecated\n637\t *                in this release.\n638\t * \\since 1.0.0\n639\t *\n640\t */\n641\tH5_DLL hid_t H5Gcreate1(hid_t loc_id, const char *name, size_t size_hint);\n642\t/**\n643\t *-------------------------------------------------------------------------\n644\t * \\ingroup H5G\n645\t *\n646\t * \\brief Opens an existing group for modification and returns a group\n647\t *        identifier for that group\n648\t *\n649\t * \\fgdta_loc_id\n650\t * \\param[in] name      Name of the group to open\n651\t *\n652\t * \\return \\hid_t{group}\n653\t *\n654\t * \\deprecated This function is deprecated in favor of H5Gopen2().\n655\t *\n656\t * \\details H5Gopen1() opens an existing group, \\p name, at the location\n657\t *          specified by \\p loc_id.\n658\t *\n659\t *          H5Gopen1() returns a group identifier for the group that was\n660\t *          opened. This group identifier should be released by calling\n661\t *          H5Gclose() when it is no longer needed.\n662\t *\n663\t * \\version 1.8.0 The function H5Gopen() was renamed to H5Gopen1()\n664\t *                and deprecated in this release.\n665\t * \\since 1.0.0\n666\t *\n667\t */\n668\tH5_DLL hid_t H5Gopen1(hid_t loc_id, const char *name);\n669\t/**\n670\t *-------------------------------------------------------------------------\n671\t * \\ingroup H5G\n672\t *\n673\t * \\brief Creates a link of the specified type from \\p new_name to \\p\n674\t *        cur_name\n675\t *\n676\t * \\fg_loc_id{cur_loc_id}\n677\t * \\param[in] type Link type\n678\t * \\param[in] cur_name Name of the existing object\n679\t * \\param[in] new_name New name for the object\n680\t *\n681\t * \\return \\herr_t\n682\t *\n683\t * \\deprecated This function is deprecated.\n684\t *\n685\t * \\details H5Glink() creates a new name for an object that has some current\n686\t *          name, possibly one of many names it currently has.\n687\t *\n688\t *          If \\p link_type is #H5G_LINK_HARD, then \\p cur_name must specify\n689\t *          the name of an existing object and both names are interpreted\n690\t *          relative to \\p cur_loc_id, which is either a file identifier or a\n691\t *          group identifier.\n692\t *\n693\t *          If \\p link_type is #H5G_LINK_SOFT, then \\p cur_name can be anything\n694\t *          and is interpreted at lookup time relative to the group which\n695\t *          contains the final component of \\p new_name. For instance, if \\p\n696\t *          cur_name is \\TText{./foo}, \\p new_name is \\TText{./x/y/bar}, and a\n697\t *          request is made for \\TText{./x/y/bar}, then the actual object looked\n698\t *          up is \\TText{./x/y/./foo}.\n699\t *\n700\t * \\version 1.8.0 Function deprecated in this release.\n701\t *\n702\t * \\since 1.0.0\n703\t *\n704\t */\n705\tH5_DLL herr_t H5Glink(hid_t cur_loc_id, H5G_link_t type, const char *cur_name, const char *new_name);\n706\t/**\n707\t *-------------------------------------------------------------------------\n708\t * \\ingroup H5G\n709\t *\n710\t * \\brief Creates a link of the specified type from \\p cur_name to \\p\n711\t *        new_name\n712\t *\n713\t * \\fg_loc_id{cur_loc_id}\n714\t * \\param[in] cur_name Name of the existing object\n715\t * \\param[in] type Link type\n716\t * \\fg_loc_id{new_loc_id}\n717\t * \\param[in] new_name New name for the object\n718\t *\n719\t * \\return \\herr_t\n720\t *\n721\t * \\deprecated This function is deprecated.\n722\t *\n723\t * \\details H5Glink2() creates a new name for an object that has some current\n724\t *          name, possibly one of many names it currently has.\n725\t *\n726\t *          If \\p link_type is #H5G_LINK_HARD, then \\p cur_name must specify the\n727\t *          name of an existing object and both names are interpreted relative\n728\t *          to \\p cur_loc_id and \\p new_loc_id, respectively, which are either\n729\t *          file identifiers or group identifiers.\n730\t *\n731\t *          If \\p link_type is #H5G_LINK_SOFT, then \\p cur_name can be anything\n732\t *          and is interpreted at lookup time relative to the group which\n733\t *          contains the final component of \\p new_name. For instance, if \\p\n734\t *          current_name is \\TText{./foo}, \\p new_name is \\TText{./x/y/bar}, and a\n735\t *          request is made for \\TText{./x/y/bar}, then the actual object looked\n736\t *          up is \\TText{./x/y/./foo}.\n737\t *\n738\t * \\version 1.8.0 Function deprecated in this release.\n739\t *\n740\t * \\since 1.6.0\n741\t *\n742\t */\n743\tH5_DLL herr_t H5Glink2(hid_t cur_loc_id, const char *cur_name, H5G_link_t type, hid_t new_loc_id,\n744\t                       const char *new_name);\n745\t/**\n746\t *-------------------------------------------------------------------------\n747\t * \\ingroup H5G\n748\t *\n749\t * \\brief Renames an object within an HDF5 file\n750\t *\n751\t * \\fg_loc_id{src_loc_id}\n752\t * \\param[in] src_name Object's original name\n753\t * \\param[in] dst_name Object's new name\n754\t *\n755\t * \\return \\herr_t\n756\t *\n757\t * \\deprecated This function is deprecated.\n758\t *\n759\t * \\details H5Gmove() renames an object within an HDF5 file. The original name,\n760\t *          \\p src_name, is unlinked from the group graph and the new name, \\p\n761\t *          dst_name, is inserted as an atomic operation. Both names are\n762\t *          interpreted relative to \\p loc_id, which is either a file or a group\n763\t *          identifier.\n764\t *\n765\t * \\attention Exercise care in moving groups as it is possible to render data in\n766\t *            a file inaccessible with H5Gmove(). See The Group Interface in the\n767\t *            \\ref UG.\n768\t *\n769\t * \\version 1.8.0 Function deprecated in this release.\n770\t *\n771\t * \\since 1.0.0\n772\t *\n773\t */\n774\tH5_DLL herr_t H5Gmove(hid_t src_loc_id, const char *src_name, const char *dst_name);\n775\t/**\n776\t *-------------------------------------------------------------------------\n777\t * \\ingroup H5G\n778\t *\n779\t * \\brief Renames an object within an HDF5 file\n780\t *\n781\t * \\fg_loc_id{src_loc_id}\n782\t * \\param[in] src_name Object's original name\n783\t * \\fg_loc_id{dst_loc_id}\n784\t * \\param[in] dst_name Object's new name\n785\t *\n786\t * \\return \\herr_t\n787\t *\n788\t * \\deprecated This function is deprecated.\n789\t *\n790\t * \\details H5Gmove2() renames an object within an HDF5 file. The original name,\n791\t *          \\p src_name, is unlinked from the group graph and the new name, \\p\n792\t *          dst_name, is inserted as an atomic operation.\n793\t *\n794\t *          \\p src_name and \\p dst_name are interpreted relative to \\p\n795\t *          src_loc_id and \\p dst_loc_id, respectively, which are either file or\n796\t *          group identifiers.\n797\t *\n798\t * \\attention Exercise care in moving groups as it is possible to render data in\n799\t *            a file inaccessible with H5Gmove2(). See The Group Interface in the\n800\t *            \\ref UG.\n801\t *\n802\t * \\version 1.8.0 Function deprecated in this release.\n803\t *\n804\t * \\since 1.6.0\n805\t *\n806\t */\n807\tH5_DLL herr_t H5Gmove2(hid_t src_loc_id, const char *src_name, hid_t dst_loc_id, const char *dst_name);\n808\t/**\n809\t *-------------------------------------------------------------------------\n810\t * \\ingroup H5G\n811\t *\n812\t * \\brief Removes the link to an object from a group\n813\t *\n814\t * \\fg_loc_id{loc_id}\n815\t * \\param[in] name Name of the object to unlink\n816\t *\n817\t * \\return \\herr_t\n818\t *\n819\t * \\deprecated This function is deprecated in favor of the function H5Ldelete().\n820\t *\n821\t * \\details H5Gunlink() removes the object specified by \\p name from the group\n822\t *          graph and decrements the link count for the object to which \\p name\n823\t *          points. This action eliminates any association between name and the\n824\t *          object to which name pointed.\n825\t *\n826\t *          Object headers keep track of how many hard links refer to an object;\n827\t *          when the link count reaches zero, the object can be removed from the\n828\t *          file. Objects which are open are not removed until all identifiers\n829\t *          to the object are closed.\n830\t *\n831\t *          If the link count reaches zero, all file space associated with the\n832\t *          object will be released, i.e., identified in memory as freespace. If\n833\t *          any object identifier is open for the object, the space will not be\n834\t *          released until after the object identifier is closed.\n835\t *\n836\t *          Note that space identified as freespace is available for reuse only\n837\t *          as long as the file remains open; once a file has been closed, the\n838\t *          HDF5 library loses track of freespace. See “Freespace Management” in\n839\t *          the \\ref UG for further details.\n840\t *\n841\t * \\attention Exercise care in moving groups as it is possible to render data in\n842\t *            a file inaccessible with H5Gunlink(). See \\ref sec_group in the\n843\t *            \\ref UG.\n844\t *\n845\t * \\version 1.8.0 Function deprecated in this release.\n846\t *\n847\t * \\since 1.0.0\n848\t *\n849\t */\n850\tH5_DLL herr_t H5Gunlink(hid_t loc_id, const char *name);\n851\t/**\n852\t *-------------------------------------------------------------------------\n853\t * \\ingroup H5G\n854\t *\n855\t * \\brief Returns the name of the object that the symbolic link points to\n856\t *\n857\t * \\fg_loc_id{loc_id}\n858\t * \\param[in] name Symbolic link to the object whose name is to be returned\n859\t * \\param[in] size Maximum number of characters of value to be returned\n860\t * \\param[out] buf A buffer to hold the name of the object being sought\n861\t *\n862\t * \\return \\herr_t\n863\t *\n864\t * \\deprecated This function is deprecated in favor of the function H5Lget_val().\n865\t *\n866\t * \\details H5Gget_linkval() returns up to size characters of the name of the\n867\t *          object that the symbolic link name points to.\n868\t *\n869\t *          The parameter \\p loc_id is a file or group identifier.\n870\t *\n871\t *          The parameter \\p name must be a symbolic link pointing to the\n872\t *          desired object and must be defined relative to \\p loc_id.\n873\t *\n874\t *          If size is smaller than the size of the returned object name, then\n875\t *          the name stored in the buffer value will not be \\c NULL terminated.\n876\t *\n877\t *          This function fails if \\p name is not a symbolic link. The presence\n878\t *          of a symbolic link can be tested by passing zero for \\p size and \\p\n879\t *          NULL for value.\n880\t *\n881\t *          This function should be used only after H5Lget_info1() (or the\n882\t *          deprecated function H5Gget_objinfo()) has been called to verify that\n883\t *          name is a symbolic link.\n884\t *\n885\t * \\version 1.8.0 Function deprecated in this release.\n886\t *\n887\t * \\since 1.0.0\n888\t *\n889\t */\n890\tH5_DLL herr_t H5Gget_linkval(hid_t loc_id, const char *name, size_t size, char *buf /*out*/);\n891\t/**\n892\t *-------------------------------------------------------------------------\n893\t * \\ingroup H5G\n894\t *\n895\t * \\brief Sets comment for specified object\n896\t *\n897\t * \\fgdt_loc_id\n898\t * \\param[in] name Name of the object whose comment is to be set or reset\n899\t *                 name must be \\TText{'.'} (dot) if \\p loc_id fully specifies\n900\t *                 the object for which the comment is to be set.\n901\t * \\param[in] comment The new comment\n902\t *\n903\t * \\return \\herr_t\n904\t *\n905\t * \\deprecated This function is deprecated in favor of the function\n906\t *             H5Oset_comment().\n907\t *\n908\t * \\details H5Gset_comment() sets the comment for the object specified by \\p\n909\t *          loc_id and name to comment. Any previously existing comment is\n910\t *          overwritten.\n911\t *\n912\t *          \\p loc_id can specify any object in the file. name can be one of the\n913\t *          following:\n914\t *          \\li The name of the object relative to \\p loc_id\n915\t *          \\li An absolute name of the object, starting from \\c /, the file's\n916\t *              root group\n917\t *          \\li A dot (\\c .), if \\p loc_id fully specifies the object\n918\t *\n919\t *          If \\p comment is the empty string or a null pointer, the comment\n920\t *          message is removed from the object.\n921\t *\n922\t *          Comments should be relatively short, null-terminated, ASCII strings.\n923\t *\n924\t *          Comments can be attached to any object that has an object header,\n925\t *          e.g., datasets, groups, and named datatypes, but not symbolic links.\n926\t *\n927\t * \\version 1.8.0 Function deprecated in this release.\n928\t *\n929\t * \\since 1.0.0\n930\t *\n931\t */\n932\tH5_DLL herr_t H5Gset_comment(hid_t loc_id, const char *name, const char *comment);\n933\t/**\n934\t *-------------------------------------------------------------------------\n935\t * \\ingroup H5G\n936\t *\n937\t * \\brief Retrieves comment for specified object\n938\t *\n939\t * \\fgdt_loc_id\n940\t * \\param[in] name Name of the object whose comment is to be set or reset\n941\t *                 name must be \\TText{'.'} (dot) if \\p loc_id fully specifies\n942\t *                 the object for which the comment is to be set.\n943\t * \\param[in] bufsize Maximum number of comment characters to be returned in \\p buf.\n944\t * \\param[out] buf The comment\n945\t *\n946\t * \\return Returns the number of characters in the comment, counting the \\c NULL\n947\t *         terminator, if successful; the value returned may be larger than\n948\t *         \\p bufsize. Otherwise returns a negative value.\n949\t *\n950\t * \\deprecated This function is deprecated in favor of the function\n951\t *             H5Oget_comment().\n952\t *\n953\t * \\details H5Gget_comment() retrieves the comment for the object specified\n954\t *          by \\p loc_id and \\p name. The comment is returned in the buffer \\p\n955\t *          buf.\n956\t *\n957\t *          \\p loc_id can specify any object in the file. name can be one of the\n958\t *          following:\n959\t *          \\li The name of the object relative to \\p loc_id\n960\t *          \\li An absolute name of the object, starting from \\c /, the file's\n961\t *              root group\n962\t *          \\li A dot (\\c .), if \\p loc_id fully specifies the object\n963\t *\n964\t *          \\details_namelen{comment,H5Gget_comment}\n965\t *\n966\t *          If an object does not have a comment, the empty string is returned\n967\t *          in comment.\n968\t *\n969\t * \\version 1.8.0 Function deprecated in this release.\n970\t *\n971\t * \\since 1.0.0\n972\t *\n973\t */\n974\tH5_DLL int H5Gget_comment(hid_t loc_id, const char *name, size_t bufsize, char *buf);\n975\t/**\n976\t *-------------------------------------------------------------------------\n977\t * \\ingroup H5G\n978\t *\n979\t * \\brief Iterates over the entries of a group invoking a callback for each\n980\t *        entry encountered\n981\t *\n982\t * \\fg_loc_id\n983\t * \\param[in] name Group over which the iteration is performed\n984\t * \\param[in,out] idx Location at which to begin the iteration\n985\t * \\param[in] op Operation to be performed on an object at each step of the\n986\t *               iteration\n987\t * \\param[in,out] op_data Data associated with the operation\n988\t *\n989\t * \\return \\herr_t\n990\t *\n991\t * \\deprecated This function is deprecated in favor of the function\n992\t *             H5Literate1().\n993\t *\n994\t * \\details H5Giterate() iterates over the members of name in the file or group\n995\t *          specified with \\p loc_id. For each object in the group, the \\p\n996\t *          op_data and some additional information, specified below, are passed\n997\t *          to the operator function. The iteration begins with the \\p idx\n998\t *          object in the group and the next element to be processed by the\n999\t *          operator is returned in \\p idx. If \\p idx is NULL, then the iterator\n1000\t *          starts at the first group member; since no stopping point is\n1001\t *          returned in this case, the iterator cannot be restarted if one of\n1002\t *          the calls to its operator returns non-zero. H5Giterate() does not\n1003\t *          recursively follow links into subgroups of the specified group.\n1004\t *\n1005\t *          The prototype for \\ref H5G_iterate_t is:\n1006\t *          \\snippet this H5G_iterate_t_snip\n1007\t *\n1008\t *          The operation receives the group identifier for the group being\n1009\t *          iterated over, \\p group, the name of the current object within\n1010\t *          the group, \\p name, and the pointer to the operator data\n1011\t *          passed into H5Giterate(), \\p op_data.\n1012\t *\n1013\t *          The return values from an operator are:\n1014\t *          \\li Zero causes the iterator to continue, returning zero when all\n1015\t *              group members have been processed.\n1016\t *          \\li Positive causes the iterator to immediately return that positive\n1017\t *              value, indicating short-circuit success. The iterator can be\n1018\t *              restarted at the next group member.\n1019\t *          \\li Negative causes the iterator to immediately return that value,\n1020\t *              indicating failure. The iterator can be restarted at the next\n1021\t *              group member.\n1022\t *\n1023\t *          H5Giterate() assumes that the membership of the group identified by\n1024\t *          \\p name remains unchanged through the iteration. If the membership\n1025\t *          changes during the iteration, the function's behavior is undefined.\n1026\t *\n1027\t *          H5Giterate() is not recursive. In particular, if a member of \\p name\n1028\t *          is found to be a group, call it \\c subgroup_a, H5Giterate() does not\n1029\t *          examine the members of \\c subgroup_a. When recursive iteration is\n1030\t *          required, the application must handle the recursion, explicitly\n1031\t *          calling H5Giterate() on discovered subgroups.\n1032\t *\n1033\t * \\warning  Adding or removing members to the group during iteration\n1034\t *           will lead to undefined behavior.\n1035\t *\n1036\t * \\callback_note\n1037\t *\n1038\t * \\version 1.8.0 Function deprecated in this release.\n1039\t *\n1040\t * \\since 1.0.0\n1041\t *\n1042\t */\n1043\tH5_DLL herr_t H5Giterate(hid_t loc_id, const char *name, int *idx, H5G_iterate_t op, void *op_data);\n1044\t/**\n1045\t *-------------------------------------------------------------------------\n1046\t * \\ingroup H5G\n1047\t *\n1048\t * \\brief Returns number of objects in the group specified by its identifier\n1049\t *\n1050\t * \\fg_loc_id\n1051\t * \\param[out] num_objs Number of objects in the group\n1052\t *\n1053\t * \\return \\herr_t\n1054\t *\n1055\t * \\deprecated This function is deprecated in favor of the function H5Gget_info().\n1056\t *\n1057\t * \\details H5Gget_num_objs() returns number of objects in a group. Group is\n1058\t *          specified by its identifier \\p loc_id. If a file identifier is\n1059\t *          passed in, then the number of objects in the root group is returned.\n1060\t *\n1061\t * \\version 1.8.0 Function deprecated in this release.\n1062\t *\n1063\t * \\since 1.6.0\n1064\t *\n1065\t */\n1066\tH5_DLL herr_t H5Gget_num_objs(hid_t loc_id, hsize_t *num_objs);\n1067\t/**\n1068\t *-------------------------------------------------------------------------\n1069\t * \\ingroup H5G\n1070\t *\n1071\t * \\brief Returns information about an object.\n1072\t *\n1073\t * \\fgdt_loc_id\n1074\t * \\param[in] name Name of the object for which status is being sought\n1075\t * \\param[in] follow_link Link flag\n1076\t * \\param[out] statbuf Buffer in which to return information about the object\n1077\t *\n1078\t * \\return \\herr_t\n1079\t *\n1080\t * \\deprecated This function is deprecated in favor of the functions H5Oget_info()\n1081\t *             and H5Lget_info1().\n1082\t *\n1083\t * \\details H5Gget_objinfo() returns information about the specified object\n1084\t *          through the \\p statbuf argument.\n1085\t *\n1086\t *          A file or group identifier, \\p loc_id, and an object name, \\p name,\n1087\t *          relative to \\p loc_id, are commonly used to specify the\n1088\t *          object. However, if the object identifier is already known to the\n1089\t *          application, an alternative approach is to use that identifier, \\c\n1090\t *          obj_id, in place of \\p loc_id, and a dot (\\c .) in place of \\p\n1091\t *          name. Thus, the alternative versions of the first portion of an\n1092\t *          H5Gget_objinfo() call would be as follows:\n1093\t *          \\code\n1094\t *          H5Gget_objinfo (loc_id name  ...)\n1095\t *          H5Gget_objinfo (obj_id .     ...)\n1096\t *          \\endcode\n1097\t *\n1098\t *          If the object is a symbolic link and follow_link is zero (0), then\n1099\t *          the information returned describes the link itself; otherwise the\n1100\t *          link is followed and the information returned describes the object\n1101\t *          to which the link points. If \\p follow_link is non-zero but the\n1102\t *          final symbolic link is dangling (does not point to anything), then\n1103\t *          an error is returned. The \\p statbuf fields are undefined for an\n1104\t *          error. The existence of an object can be tested by calling this\n1105\t *          function with a \\c NULL \\p statbuf.\n1106\t *\n1107\t *          H5Gget_objinfo() fills in the following data structure (defined in\n1108\t *          H5Gpublic.h):\n1109\t *          \\snippet this H5G_stat_t_snip\n1110\t *\n1111\t *          where \\ref H5O_stat_t (defined in H5Opublic.h) is:\n1112\t *          \\snippet H5Opublic.h H5O_stat_t_snip\n1113\t *\n1114\t * \\attention Some systems will be able to record the time accurately but unable\n1115\t *            to retrieve the correct time; such systems (e.g., Irix64) will\n1116\t *            report an \\c mtime value of 0 (zero).\n1117\t *\n1118\t * \\version 1.8.0 Function deprecated in this release.\n1119\t * \\version 1.6.1 Two new fields were added to the \\ref H5G_stat_t struct in\n1120\t *                this release.\n1121\t *\n1122\t * \\since 1.0.0\n1123\t *\n1124\t */\n1125\tH5_DLL herr_t H5Gget_objinfo(hid_t loc_id, const char *name, bool follow_link, H5G_stat_t *statbuf /*out*/);\n1126\t/**\n1127\t *-------------------------------------------------------------------------\n1128\t * \\ingroup H5G\n1129\t *\n1130\t * \\brief Returns the name of an object specified by an index\n1131\t *\n1132\t * \\fg_loc_id\n1133\t * \\param[in] idx Transient index identifying object\n1134\t * \\param[out] name Pointer to user-provided buffer the object name\n1135\t * \\param[in] size Name length\n1136\t *\n1137\t * \\return Returns the size of the object name if successful, or 0 if no name is\n1138\t *         associated with the group identifier. Otherwise returns a negative\n1139\t *         value.\n1140\t *\n1141\t * \\deprecated This function is deprecated in favor of the function H5Lget_name_by_idx().\n1142\t *\n1143\t * \\details H5Gget_objname_by_idx() returns the name of the object specified by\n1144\t *          the index \\p idx in the group \\p loc_id.\n1145\t *\n1146\t *          The group is specified by a group identifier \\p loc_id. If\n1147\t *          preferred, a file identifier may be passed in \\p loc_id; that file's\n1148\t *          root group will be assumed.\n1149\t *\n1150\t *          \\p idx is the transient index used to iterate through the objects in\n1151\t *          the group. The value of \\p idx is any nonnegative number less than\n1152\t *          the total number of objects in the group, which is returned by the\n1153\t *          function H5Gget_num_objs(). Note that this is a transient index; an\n1154\t *          object may have a different index each time a group is opened.\n1155\t *\n1156\t *          The object name is returned in the user-specified buffer \\p name.\n1157\t *\n1158\t *          If the size of the provided buffer \\p name is less or equal the\n1159\t *          actual object name length, the object name is truncated to\n1160\t *          \\TText{max_size - 1} characters.\n1161\t *\n1162\t *          Note that if the size of the object's name is unknown, a preliminary\n1163\t *          call to H5Gget_objname_by_idx() with \\p name set to \\c NULL will\n1164\t *          return the length of the object's name. A second call to\n1165\t *          H5Gget_objname_by_idx() can then be used to retrieve the actual\n1166\t *          name.\n1167\t *\n1168\t * \\version 1.8.0 Function deprecated in this release.\n1169\t * \\since 1.6.0\n1170\t *\n1171\t */\n1172\tH5_DLL ssize_t H5Gget_objname_by_idx(hid_t loc_id, hsize_t idx, char *name, size_t size);\n1173\t/**\n1174\t *-------------------------------------------------------------------------\n1175\t * \\ingroup H5G\n1176\t *\n1177\t * \\brief Returns the type of an object specified by an index\n1178\t *\n1179\t * \\fg_loc_id\n1180\t * \\param[in] idx Transient index identifying object\n1181\t *\n1182\t * \\return Returns the type of the object if successful. Otherwise returns a\n1183\t *         negative value.\n1184\t *\n1185\t * \\deprecated This function is deprecated in favor of the function H5Oget_info().\n1186\t *\n1187\t * \\details H5Gget_objtype_by_idx() returns the type of the object specified by\n1188\t *          the index \\p idx in the group \\p loc_id.\n1189\t *\n1190\t *          The group is specified by a group identifier \\p loc_id. If\n1191\t *          preferred, a file identifier may be passed in \\p loc_id; that file's\n1192\t *          root group will be assumed.\n1193\t *\n1194\t *          \\p idx is the transient index used to iterate through the objects in\n1195\t *          the group. This parameter is described in more detail in the\n1196\t *          discussion of H5Gget_objname_by_idx().\n1197\t *\n1198\t * \\note    As of 1.12.0, H5Gget_objtype_by_idx() returns the type of the object\n1199\t *          that the link points to, but it has been deprecated for H5Oget_info().\n1200\t *          Previous behavior for this function returned H5G_LINK for any link type.\n1201\t *          To get the link type, an application may use H5Lget_info_by_idx()\n1202\t *          instead.\n1203\t *\n1204\t * \\version 1.8.0 Function deprecated in this release.\n1205\t * \\version 1.6.0 The function return type changed from \\c int to the enumerated\n1206\t *                type \\ref H5G_obj_t.\n1207\t * \\since 1.6.0\n1208\t *\n1209\t */\n1210\tH5_DLL H5G_obj_t H5Gget_objtype_by_idx(hid_t loc_id, hsize_t idx);\n1211\t\n1212\t#endif /* H5_NO_DEPRECATED_SYMBOLS */\n1213\t\n1214\t#ifdef __cplusplus\n1215\t}\n1216\t#endif\n1217\t#endif /* H5Gpublic_H */\n1218\t"}]},"parent_tool_use_id":null,"session_id":"23ddc9e0-d3f9-4675-87cb-79190a925bcc","uuid":"07e39ee8-85ae-42ef-8a2d-2633a37b98ec","timestamp":"2026-06-06T17:49:24.478Z","tool_use_result":{"type":"text","file":{"filePath":"/work/agent/target-src/src/H5Gpublic.h","content":"/* * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *\n * Copyright by The HDF Group.                                               *\n * All rights reserved.                                                      *\n *                                                                           *\n * This file is part of HDF5.  The full HDF5 copyright notice, including     *\n * terms governing use, modification, and redistribution, is contained in    *\n * the LICENSE file, which can be found at the root of the source code       *\n * distribution tree, or in https://www.hdfgroup.org/licenses.               *\n * If you do not have access to either file, you may request a copy from     *\n * help@hdfgroup.org.                                                        *\n * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * */\n\n/*-------------------------------------------------------------------------\n *\n * Created:             H5Gpublic.h\n *\n * Purpose:             Public declarations for the H5G package\n *\n *-------------------------------------------------------------------------\n */\n#ifndef H5Gpublic_H\n#define H5Gpublic_H\n\n#include \"H5public.h\"  /* Generic Functions                        */\n#include \"H5Ipublic.h\" /* Identifiers                              */\n#include \"H5Lpublic.h\" /* Links                                    */\n#include \"H5Opublic.h\" /* Object Headers                           */\n\n/*****************/\n/* Public Macros */\n/*****************/\n\n/*******************/\n/* Public Typedefs */\n/*******************/\n\n//! <!-- [H5G_storage_t_snip] -->\n/**\n * Types of link storage for groups\n */\ntypedef enum H5G_storage_type_t {\n    H5G_STORAGE_TYPE_UNKNOWN = -1, /**< Unknown link storage type\t*/\n    H5G_STORAGE_TYPE_SYMBOL_TABLE, /**< Links in group are stored with a \"symbol table\" */\n                                   /**< (this is sometimes called \"old-style\" groups) */\n    H5G_STORAGE_TYPE_COMPACT,      /**< Links are stored in object header */\n    H5G_STORAGE_TYPE_DENSE         /**< Links are stored in fractal heap & indexed with v2 B-tree */\n} H5G_storage_type_t;\n//! <!-- [H5G_storage_t_snip] -->\n\n//! <!-- [H5G_info_t_snip] -->\n/**\n * Information struct for group for\n * H5Gget_info(), H5Gget_info_by_name(), and H5Gget_info_by_idx()\n */\ntypedef struct H5G_info_t {\n    H5G_storage_type_t storage_type; /**< Type of storage for links in group */\n    hsize_t            nlinks;       /**< Number of links in group */\n    int64_t            max_corder;   /**< Current max. creation order value for group */\n    bool               mounted;      /**< Whether group has a file mounted on it */\n} H5G_info_t;\n//! <!-- [H5G_info_t_snip] -->\n\n/********************/\n/* Public Variables */\n/********************/\n\n/*********************/\n/* Public Prototypes */\n/*********************/\n#ifdef __cplusplus\nextern \"C\" {\n#endif\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Creates a new group and links it into the file\n *\n * \\fgdta_loc_id\n * \\param[in] name      Name of the group to create\n * \\lcpl_id\n * \\gcpl_id\n * \\gapl_id\n *\n * \\return \\hid_t{group}\n *\n * \\details H5Gcreate2() creates a new group in a file. After a\n *          group has been created, links to datasets and to other groups\n *          can be added.\n *\n *          The \\p loc_id and \\p name parameters specify where the group\n *          is located. \\p loc_id may be a file, group, dataset, named\n *          datatype or attribute in the file. If an attribute, dataset,\n *          or named datatype is specified for \\p loc_id then the group\n *          will be created at the location where the attribute, dataset,\n *          or named datatype is attached. \\p name is the link to the group;\n *          \\p name may be either an absolute path in the file (the links\n *          from the root group to the new group) or a relative path from\n *          \\p loc_id (the link(s) from the group specified by \\p loc_id\n *          to the new group).\n *\n *          \\p lcpl_id, \\p gcpl_id, and \\p gapl_id are property list\n *          identifiers. These property lists govern how the link to the\n *          group is created, how the group is created, and how the group\n *          can be accessed in the future, respectively. #H5P_DEFAULT can\n *          be passed in if the default properties are appropriate for\n *          these property lists. Currently, there are no APIs for the\n *          group access property list; use #H5P_DEFAULT.\n *\n *          The group identifier should be closed by H5Gclose() when access\n *          is no longer required to prevent resource leaks.\n *\n * \\since 1.8.0\n *\n * \\see H5Gopen2()\n *\n */\nH5_DLL hid_t H5Gcreate2(hid_t loc_id, const char *name, hid_t lcpl_id, hid_t gcpl_id, hid_t gapl_id);\n\n/**\n * --------------------------------------------------------------------------\n * \\ingroup ASYNC\n * \\async_variant_of{H5Gcreate}\n */\n#ifndef H5_DOXYGEN\nH5_DLL hid_t H5Gcreate_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n                             const char *name, hid_t lcpl_id, hid_t gcpl_id, hid_t gapl_id, hid_t es_id);\n#else\nH5_DLL hid_t H5Gcreate_async(hid_t loc_id, const char *name, hid_t lcpl_id, hid_t gcpl_id, hid_t gapl_id,\n                             hid_t es_id);\n#endif\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Creates a new empty group without linking it into the file structure\n *\n * \\fgdta_loc_id\n * \\gcpl_id\n * \\gapl_id\n *\n * \\return \\hid_t{group}\n *\n * \\details H5Gcreate_anon() creates a new empty group in the file\n *          specified by \\p loc_id. With default settings, H5Gcreate_anon()\n *          provides similar functionality to that provided by\n *          H5Gcreate1(), with the differences described in the list below.\n *\n *          The new group's creation and access properties are specified\n *          in \\p gcpl_id and \\p gapl_id, respectively.\n *\n *          H5Gcreate_anon() returns a new group identifier. This identifier\n *          must be linked into the HDF5 file structure with H5Olink()\n *          or it will be deleted from the file when the file is closed.\n *\n *          The differences between this function and H5Gcreate1() are\n *          as follows:\n *\n *          \\li H5Gcreate1() does not provide for the use of custom property\n *              lists; H5Gcreate1() always uses default properties.\n *          \\li H5Gcreate_anon() neither provides the new group's name\n *              nor links it into the HDF5 file structure; those actions\n *              must be performed separately through a call to H5Olink(),\n *              which offers greater control over linking.\n *          \\li H5Gcreate_anon() does not directly provide a hint mechanism\n *              for the group's heap size. Comparable information can be\n *              included in the group creation property list \\p gcpl_id through\n *              a H5Pset_local_heap_size_hint() call.\n *\n *          A group created with this function should be closed with\n *          H5Gclose() when the group is no longer needed so that resource\n *          leaks will not develop.\n *\n * \\see H5Olink(), H5Gcreate()\n *\n * \\since 1.8.0\n *\n */\nH5_DLL hid_t H5Gcreate_anon(hid_t loc_id, hid_t gcpl_id, hid_t gapl_id);\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Opens an existing group in a file\n *\n * \\fgdta_loc_id\n * \\param[in] name      Name of the group to open\n * \\gapl_id\n *\n * \\return \\hid_t{group}\n *\n * \\details H5Gopen2() opens an existing group, \\p name, at the location\n *          specified by \\p loc_id.\n *\n *          With default settings, H5Gopen2() provides similar functionality\n *          to that provided by H5Gopen(). The only difference is that\n *          H5Gopen2() can provide a group access property list, \\p gapl_id.\n *\n *          H5Gopen2() returns a group identifier for the group that was\n *          opened. This group identifier should be released by H5Gclose()\n *          when it is no longer needed to prevent resource leaks.\n *\n * \\since 1.8.0\n *\n * \\see H5Gcreate2()\n *\n */\nH5_DLL hid_t H5Gopen2(hid_t loc_id, const char *name, hid_t gapl_id);\n\n/**\n * --------------------------------------------------------------------------\n * \\ingroup ASYNC\n * \\async_variant_of{H5Gopen}\n *\n * \\since 1.12.0\n *\n */\n#ifndef H5_DOXYGEN\nH5_DLL hid_t H5Gopen_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n                           const char *name, hid_t gapl_id, hid_t es_id);\n#else\nH5_DLL hid_t H5Gopen_async(hid_t loc_id, const char *name, hid_t gapl_id, hid_t es_id);\n#endif\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Gets a group creation property list identifier\n *\n * \\group_id\n *\n * \\return \\hid_t{creation property list}\n *\n * \\details H5Gget_create_plist() returns an identifier for the group creation\n *          property list associated with the group specified by \\p group_id.\n *\n *          The creation property list identifier should be released with\n *          H5Pclose() to prevent resource leaks.\n *\n * \\since 1.8.0\n *\n */\nH5_DLL hid_t H5Gget_create_plist(hid_t group_id);\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Retrieves information about a group\n *\n * \\fgdta_loc_id\n * \\param[out] ginfo Struct in which group information is returned\n *\n * \\return \\hid_t{group}\n *\n * \\details H5Gget_info() retrieves information about the group at location\n *          specified by \\p loc_id. The information is returned in the \\p ginfo.\n *\n *          \\p ginfo is an H5G_info_t struct and is defined (in H5Gpublic.h)\n *          as follows:\n *\n * \\snippet this H5G_info_t_snip\n * Possible values of \\p storage_type are:\n * \\storage_type\n *\n * \\since 1.8.0\n *\n */\nH5_DLL herr_t H5Gget_info(hid_t loc_id, H5G_info_t *ginfo);\n\n/**\n * --------------------------------------------------------------------------\n * \\ingroup ASYNC\n * \\async_variant_of{H5Gget_info}\n *\n * \\since 1.12.0\n *\n */\n#ifndef H5_DOXYGEN\nH5_DLL herr_t H5Gget_info_async(const char *app_file, const char *app_func, unsigned app_line, hid_t loc_id,\n                                H5G_info_t *ginfo /*out*/, hid_t es_id);\n#else\nH5_DLL herr_t H5Gget_info_async(hid_t loc_id, H5G_info_t *ginfo /*out*/, hid_t es_id);\n#endif\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Retrieves information about a group by its name\n *\n * \\fgdta_loc_id\n * \\param[in] name      Name of the group to query\n * \\param[out] ginfo Struct in which group information is returned\n * \\lapl_id\n *\n * \\return \\herr_t\n *\n * \\details H5Gget_info_by_name() retrieves information about the group \\p name\n *          at location specified by \\p loc_id. The information is returned in\n *          the \\p ginfo struct.\n *\n *          If \\p loc_id specifies the group for which information is queried,\n *          then the group's \\p name can be a dot (.).\n *\n *          \\p ginfo is an H5G_info_t struct and is defined (in H5Gpublic.h)\n *          as follows:\n *\n * \\snippet this H5G_info_t_snip\n * Possible values of \\p storage_type are:\n * \\storage_type\n *\n * \\since 1.8.0\n *\n */\nH5_DLL herr_t H5Gget_info_by_name(hid_t loc_id, const char *name, H5G_info_t *ginfo, hid_t lapl_id);\n\n/**\n * --------------------------------------------------------------------------\n * \\ingroup ASYNC\n * \\async_variant_of{H5Gget_info_by_name}\n *\n * \\since 1.12.0\n *\n */\n#ifndef H5_DOXYGEN\nH5_DLL herr_t H5Gget_info_by_name_async(const char *app_file, const char *app_func, unsigned app_line,\n                                        hid_t loc_id, const char *name, H5G_info_t *ginfo /*out*/,\n                                        hid_t lapl_id, hid_t es_id);\n#else\nH5_DLL herr_t H5Gget_info_by_name_async(hid_t loc_id, const char *name, H5G_info_t *ginfo /*out*/,\n                                        hid_t lapl_id, hid_t es_id);\n#endif\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Retrieves information about a group, according to the group's\n *        position within an index\n *\n * \\fgdta_loc_id\n * \\param[in] group_name Name of the group to query\n * \\param[in] idx_type   Transient index identifying object\n * \\param[in] order      Transient index identifying object\n * \\param[in] n          Position in the index of the group to query\n * \\param[out] ginfo     Struct in which group information is returned\n * \\lapl_id\n *\n * \\return Returns\n *      \\li The size of the object name if successful, or\n *      \\li 0 if no name is associated with the group identifier, or\n *      \\li negative value, if failure occurred\n *\n * \\details H5Gget_info_by_idx() retrieves the same information\n *          about a group as retrieved by the function H5Gget_info(),\n *          but the means of identifying the group differs; the group is\n *          identified by position in an index rather than by name.\n *\n *          \\p loc_id and \\p group_name specify the group containing\n *          the group for which information is sought. The groups in \\p\n *          group_name are indexed by \\p idx_type; the group for which\n *          information is retrieved is identified in that index by index\n *          order, \\p order, and index position, \\p n.\n *\n *          If \\p loc_id specifies the group containing the group for\n *          which information is queried, \\p group_name can be a dot (.).\n *\n *          Valid values for \\p index_type are as follows:\n * \\indexes\n *          The order in which the index is to be examined, as specified\n *          by \\p order, can be one of the following:\n * \\orders\n *\n * \\since 1.8.0\n *\n */\nH5_DLL herr_t H5Gget_info_by_idx(hid_t loc_id, const char *group_name, H5_index_t idx_type,\n                                 H5_iter_order_t order, hsize_t n, H5G_info_t *ginfo, hid_t lapl_id);\n\n/**\n * --------------------------------------------------------------------------\n * \\ingroup ASYNC\n * \\async_variant_of{H5Gget_info_by_idx}\n *\n * \\since 1.12.0\n *\n */\n#ifndef H5_DOXYGEN\nH5_DLL herr_t H5Gget_info_by_idx_async(const char *app_file, const char *app_func, unsigned app_line,\n                                       hid_t loc_id, const char *group_name, H5_index_t idx_type,\n                                       H5_iter_order_t order, hsize_t n, H5G_info_t *ginfo /*out*/,\n                                       hid_t lapl_id, hid_t es_id);\n#else\nH5_DLL herr_t H5Gget_info_by_idx_async(hid_t loc_id, const char *group_name, H5_index_t idx_type,\n                                       H5_iter_order_t order, hsize_t n, H5G_info_t *ginfo /*out*/,\n                                       hid_t lapl_id, hid_t es_id);\n#endif\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Flushes all buffers associated with a group to disk\n *\n * \\group_id\n *\n * \\return \\herr_t\n *\n * \\details H5Gflush() causes all buffers associated with a group to be\n *          immediately flushed to the disk without removing the data from\n *          the cache.\n *\n * \\attention\n *          HDF5 does not possess full control over buffering. H5G_FLUSH\n *          flushes the internal HDF5 buffers and then asks the operating\n *          system (the OS) to flush the system buffers for the open\n *          files. After that, the OS is responsible for ensuring that\n *          the data is actually flushed to the disk.\n *\n * \\since 1.8.0\n *\n */\nH5_DLL herr_t H5Gflush(hid_t group_id);\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Refreshes all buffers associated with a group\n *\n * \\group_id\n *\n * \\return \\herr_t\n *\n * \\details H5Grefresh() causes all buffers associated with a group to be\n *          cleared and immediately re-loaded with updated contents from disk.\n *\n *          This function essentially closes the group, evicts all\n *          metadata associated with it from the cache, and then reopens\n *          the group. The reopened group is automatically re-registered\n *          with the same identifier.\n *\n * \\since 1.8.0\n *\n */\nH5_DLL herr_t H5Grefresh(hid_t group_id);\n\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Closes the specified group\n *\n * \\group_id\n *\n * \\return \\herr_t\n *\n * \\details H5Gclose() releases resources used by a group that was\n *          opened by H5Gcreate() or H5Gopen().  After closing a group,\n *          \\p group_id cannot be used again until another H5Gcreate()\n *          or H5Gopen() is called on it.\n *\n *          Failure to release a group with this call will result in\n *          resource leaks.\n *\n * \\par Example\n * \\snippet H5F_examples.c mount\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Gclose(hid_t group_id);\n\n/**\n * --------------------------------------------------------------------------\n * \\ingroup ASYNC\n * \\async_variant_of{H5Gclose}\n *\n * \\since 1.12.0\n *\n */\n#ifndef H5_DOXYGEN\nH5_DLL herr_t H5Gclose_async(const char *app_file, const char *app_func, unsigned app_line, hid_t group_id,\n                             hid_t es_id);\n#else\nH5_DLL herr_t H5Gclose_async(hid_t group_id, hid_t es_id);\n#endif\n\n/// \\cond DEV\n/* API Wrappers for async routines */\n/* (Must be defined _after_ the function prototype) */\n/* (And must only defined when included in application code, not the library) */\n#ifndef H5G_MODULE\n#define H5Gcreate_async(...)           H5Gcreate_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n#define H5Gopen_async(...)             H5Gopen_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n#define H5Gget_info_async(...)         H5Gget_info_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n#define H5Gget_info_by_name_async(...) H5Gget_info_by_name_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n#define H5Gget_info_by_idx_async(...)  H5Gget_info_by_idx_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n#define H5Gclose_async(...)            H5Gclose_async(__FILE__, __func__, __LINE__, __VA_ARGS__)\n\n/* Define \"wrapper\" versions of function calls, to allow compile-time values to\n *      be passed in by language wrapper or library layer on top of HDF5.\n */\n#define H5Gcreate_async_wrap           H5_NO_EXPAND(H5Gcreate_async)\n#define H5Gopen_async_wrap             H5_NO_EXPAND(H5Gopen_async)\n#define H5Gget_info_async_wrap         H5_NO_EXPAND(H5Gget_info_async)\n#define H5Gget_info_by_name_async_wrap H5_NO_EXPAND(H5Gget_info_by_name_async)\n#define H5Gget_info_by_idx_async_wrap  H5_NO_EXPAND(H5Gget_info_by_idx_async)\n#define H5Gclose_async_wrap            H5_NO_EXPAND(H5Gclose_async)\n#endif /* H5G_MODULE */\n/// \\endcond\n\n/* Symbols defined for compatibility with previous versions of the HDF5 API.\n *\n * Use of these symbols is deprecated.\n */\n#ifndef H5_NO_DEPRECATED_SYMBOLS\n\n/* Macros */\n\n/* Link definitions */\n#define H5G_SAME_LOC   H5L_SAME_LOC   /**< Indicates operation occurs on same location \\since 1.6.0 */\n#define H5G_LINK_ERROR H5L_TYPE_ERROR /**< Invalid link type id \\since 1.8.0 */\n#define H5G_LINK_HARD  H5L_TYPE_HARD  /**< Hard link id \\since 1.8.0 */\n#define H5G_LINK_SOFT  H5L_TYPE_SOFT  /**< Soft link id \\since 1.8.0 */\n#define H5G_link_t     H5L_type_t     /**< Link types \\since 1.0.0 */\n\n/* Macros for types of objects in a group (see H5G_obj_t definition) */\n#define H5G_NTYPES     256 /**< Max possible number of types \\since 1.0.0 */\n#define H5G_NLIBTYPES  8   /**< Number of internal types \\since 1.2.0 */\n#define H5G_NUSERTYPES (H5G_NTYPES - H5G_NLIBTYPES)\n/**< Number of user-defined types \\since 1.2.0 */\n#define H5G_USERTYPE(X) (8 + (X)) /**< User defined types \\since 1.2.0 */\n\n/* Typedefs */\n\n//! <!-- [H5G_obj_t_snip] -->\n/**\n * An object has a certain type. The first few numbers are reserved for use\n * internally by HDF5. Users may add their own types with higher values.  The\n * values are never stored in the file -- they only exist while an application\n * is running.  An object may satisfy the `isa` function for more than one type.\n *\n * \\deprecated\n */\ntypedef enum H5G_obj_t {\n    H5G_UNKNOWN = -1, /**< Unknown object type\t\t*/\n    H5G_GROUP,        /**< Object is a group\t\t*/\n    H5G_DATASET,      /**< Object is a dataset\t\t*/\n    H5G_TYPE,         /**< Object is a named data type\t*/\n    H5G_LINK,         /**< Object is a symbolic link\t*/\n    H5G_UDLINK,       /**< Object is a user-defined link */\n    H5G_RESERVED_5,   /**< Reserved for future use\t*/\n    H5G_RESERVED_6,   /**< Reserved for future use\t*/\n    H5G_RESERVED_7    /**< Reserved for future use\t*/\n} H5G_obj_t;\n//! <!-- [H5G_obj_t_snip] -->\n\n//! <!-- [H5G_iterate_t_snip] -->\n/**\n * Callback for H5Giterate()\n *\n * \\deprecated\n */\ntypedef herr_t (*H5G_iterate_t)(hid_t group, const char *name, void *op_data);\n//! <!-- [H5G_iterate_t_snip] -->\n\n//! <!-- [H5G_stat_t_snip] -->\n/**\n * Information about an object\n *\n * \\deprecated\n */\ntypedef struct H5G_stat_t {\n    unsigned long fileno[2]; /**< file number\t\t\t*/\n    unsigned long objno[2];  /**< object number\t\t\t*/\n    unsigned      nlink;     /**< number of hard links to object*/\n    H5G_obj_t     type;      /**< basic object type\t\t*/\n    time_t        mtime;     /**< modification time\t\t*/\n    size_t        linklen;   /**< symbolic link value length\t*/\n    H5O_stat_t    ohdr;      /**< Object header information    */\n} H5G_stat_t;\n//! <!-- [H5G_stat_t_snip] -->\n\n/* Function prototypes */\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Creates a new group and links it into the file\n *\n * \\fgdta_loc_id\n * \\param[in] name      Name of the group to create\n * \\param[in] size_hint The number of bytes to reserve for the names\n *                      that will appear in the group\n *\n * \\return \\hid_t{group}\n *\n * \\deprecated This function is deprecated in favor of H5Gcreate2().\n *\n * \\details H5Gcreate1() creates a new group with the specified name at the\n *          specified location, \\p loc_id.  \\p loc_id may be a file, group,\n *          dataset, named datatype or attribute.  If an attribute, dataset, or\n *          named datatype is specified for \\p loc_id then the group will be\n *          created at the location where the attribute, dataset, or named\n *          datatype is attached. The name, name, must not already be taken by\n *          some other object and all parent groups must already exist.\n *\n *          \\p name can be a relative path based at \\p loc_id or an absolute\n *          path from the root of the file. Use of this function requires that\n *          any intermediate groups specified in the path already exist.\n *\n *          The length of a group name, or of the name of any object within a\n *          group, is not limited.\n *\n *          \\p size_hint is a hint for the number of bytes to reserve to store\n *          the names which will be eventually added to the new group. This\n *          value must be between 0 and UINT32_MAX (inclusive). If this\n *          parameter is zero, a default value will be used.\n *\n *          The return value is a group identifier for the open group. This\n *          group identifier should be closed by calling H5Gclose() when it is\n *          no longer needed.\n *\n *          See H5Gcreate_anon() for a discussion of the differences between\n *          H5Gcreate1() and H5Gcreate_anon().\n *\n * \\par Example\n * \\snippet H5F_examples.c mount\n *\n * \\version 1.8.0 Function H5Gcreate() renamed to H5Gcreate1() and deprecated\n *                in this release.\n * \\since 1.0.0\n *\n */\nH5_DLL hid_t H5Gcreate1(hid_t loc_id, const char *name, size_t size_hint);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Opens an existing group for modification and returns a group\n *        identifier for that group\n *\n * \\fgdta_loc_id\n * \\param[in] name      Name of the group to open\n *\n * \\return \\hid_t{group}\n *\n * \\deprecated This function is deprecated in favor of H5Gopen2().\n *\n * \\details H5Gopen1() opens an existing group, \\p name, at the location\n *          specified by \\p loc_id.\n *\n *          H5Gopen1() returns a group identifier for the group that was\n *          opened. This group identifier should be released by calling\n *          H5Gclose() when it is no longer needed.\n *\n * \\version 1.8.0 The function H5Gopen() was renamed to H5Gopen1()\n *                and deprecated in this release.\n * \\since 1.0.0\n *\n */\nH5_DLL hid_t H5Gopen1(hid_t loc_id, const char *name);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Creates a link of the specified type from \\p new_name to \\p\n *        cur_name\n *\n * \\fg_loc_id{cur_loc_id}\n * \\param[in] type Link type\n * \\param[in] cur_name Name of the existing object\n * \\param[in] new_name New name for the object\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated.\n *\n * \\details H5Glink() creates a new name for an object that has some current\n *          name, possibly one of many names it currently has.\n *\n *          If \\p link_type is #H5G_LINK_HARD, then \\p cur_name must specify\n *          the name of an existing object and both names are interpreted\n *          relative to \\p cur_loc_id, which is either a file identifier or a\n *          group identifier.\n *\n *          If \\p link_type is #H5G_LINK_SOFT, then \\p cur_name can be anything\n *          and is interpreted at lookup time relative to the group which\n *          contains the final component of \\p new_name. For instance, if \\p\n *          cur_name is \\TText{./foo}, \\p new_name is \\TText{./x/y/bar}, and a\n *          request is made for \\TText{./x/y/bar}, then the actual object looked\n *          up is \\TText{./x/y/./foo}.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Glink(hid_t cur_loc_id, H5G_link_t type, const char *cur_name, const char *new_name);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Creates a link of the specified type from \\p cur_name to \\p\n *        new_name\n *\n * \\fg_loc_id{cur_loc_id}\n * \\param[in] cur_name Name of the existing object\n * \\param[in] type Link type\n * \\fg_loc_id{new_loc_id}\n * \\param[in] new_name New name for the object\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated.\n *\n * \\details H5Glink2() creates a new name for an object that has some current\n *          name, possibly one of many names it currently has.\n *\n *          If \\p link_type is #H5G_LINK_HARD, then \\p cur_name must specify the\n *          name of an existing object and both names are interpreted relative\n *          to \\p cur_loc_id and \\p new_loc_id, respectively, which are either\n *          file identifiers or group identifiers.\n *\n *          If \\p link_type is #H5G_LINK_SOFT, then \\p cur_name can be anything\n *          and is interpreted at lookup time relative to the group which\n *          contains the final component of \\p new_name. For instance, if \\p\n *          current_name is \\TText{./foo}, \\p new_name is \\TText{./x/y/bar}, and a\n *          request is made for \\TText{./x/y/bar}, then the actual object looked\n *          up is \\TText{./x/y/./foo}.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.6.0\n *\n */\nH5_DLL herr_t H5Glink2(hid_t cur_loc_id, const char *cur_name, H5G_link_t type, hid_t new_loc_id,\n                       const char *new_name);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Renames an object within an HDF5 file\n *\n * \\fg_loc_id{src_loc_id}\n * \\param[in] src_name Object's original name\n * \\param[in] dst_name Object's new name\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated.\n *\n * \\details H5Gmove() renames an object within an HDF5 file. The original name,\n *          \\p src_name, is unlinked from the group graph and the new name, \\p\n *          dst_name, is inserted as an atomic operation. Both names are\n *          interpreted relative to \\p loc_id, which is either a file or a group\n *          identifier.\n *\n * \\attention Exercise care in moving groups as it is possible to render data in\n *            a file inaccessible with H5Gmove(). See The Group Interface in the\n *            \\ref UG.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Gmove(hid_t src_loc_id, const char *src_name, const char *dst_name);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Renames an object within an HDF5 file\n *\n * \\fg_loc_id{src_loc_id}\n * \\param[in] src_name Object's original name\n * \\fg_loc_id{dst_loc_id}\n * \\param[in] dst_name Object's new name\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated.\n *\n * \\details H5Gmove2() renames an object within an HDF5 file. The original name,\n *          \\p src_name, is unlinked from the group graph and the new name, \\p\n *          dst_name, is inserted as an atomic operation.\n *\n *          \\p src_name and \\p dst_name are interpreted relative to \\p\n *          src_loc_id and \\p dst_loc_id, respectively, which are either file or\n *          group identifiers.\n *\n * \\attention Exercise care in moving groups as it is possible to render data in\n *            a file inaccessible with H5Gmove2(). See The Group Interface in the\n *            \\ref UG.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.6.0\n *\n */\nH5_DLL herr_t H5Gmove2(hid_t src_loc_id, const char *src_name, hid_t dst_loc_id, const char *dst_name);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Removes the link to an object from a group\n *\n * \\fg_loc_id{loc_id}\n * \\param[in] name Name of the object to unlink\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated in favor of the function H5Ldelete().\n *\n * \\details H5Gunlink() removes the object specified by \\p name from the group\n *          graph and decrements the link count for the object to which \\p name\n *          points. This action eliminates any association between name and the\n *          object to which name pointed.\n *\n *          Object headers keep track of how many hard links refer to an object;\n *          when the link count reaches zero, the object can be removed from the\n *          file. Objects which are open are not removed until all identifiers\n *          to the object are closed.\n *\n *          If the link count reaches zero, all file space associated with the\n *          object will be released, i.e., identified in memory as freespace. If\n *          any object identifier is open for the object, the space will not be\n *          released until after the object identifier is closed.\n *\n *          Note that space identified as freespace is available for reuse only\n *          as long as the file remains open; once a file has been closed, the\n *          HDF5 library loses track of freespace. See “Freespace Management” in\n *          the \\ref UG for further details.\n *\n * \\attention Exercise care in moving groups as it is possible to render data in\n *            a file inaccessible with H5Gunlink(). See \\ref sec_group in the\n *            \\ref UG.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Gunlink(hid_t loc_id, const char *name);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Returns the name of the object that the symbolic link points to\n *\n * \\fg_loc_id{loc_id}\n * \\param[in] name Symbolic link to the object whose name is to be returned\n * \\param[in] size Maximum number of characters of value to be returned\n * \\param[out] buf A buffer to hold the name of the object being sought\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated in favor of the function H5Lget_val().\n *\n * \\details H5Gget_linkval() returns up to size characters of the name of the\n *          object that the symbolic link name points to.\n *\n *          The parameter \\p loc_id is a file or group identifier.\n *\n *          The parameter \\p name must be a symbolic link pointing to the\n *          desired object and must be defined relative to \\p loc_id.\n *\n *          If size is smaller than the size of the returned object name, then\n *          the name stored in the buffer value will not be \\c NULL terminated.\n *\n *          This function fails if \\p name is not a symbolic link. The presence\n *          of a symbolic link can be tested by passing zero for \\p size and \\p\n *          NULL for value.\n *\n *          This function should be used only after H5Lget_info1() (or the\n *          deprecated function H5Gget_objinfo()) has been called to verify that\n *          name is a symbolic link.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Gget_linkval(hid_t loc_id, const char *name, size_t size, char *buf /*out*/);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Sets comment for specified object\n *\n * \\fgdt_loc_id\n * \\param[in] name Name of the object whose comment is to be set or reset\n *                 name must be \\TText{'.'} (dot) if \\p loc_id fully specifies\n *                 the object for which the comment is to be set.\n * \\param[in] comment The new comment\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated in favor of the function\n *             H5Oset_comment().\n *\n * \\details H5Gset_comment() sets the comment for the object specified by \\p\n *          loc_id and name to comment. Any previously existing comment is\n *          overwritten.\n *\n *          \\p loc_id can specify any object in the file. name can be one of the\n *          following:\n *          \\li The name of the object relative to \\p loc_id\n *          \\li An absolute name of the object, starting from \\c /, the file's\n *              root group\n *          \\li A dot (\\c .), if \\p loc_id fully specifies the object\n *\n *          If \\p comment is the empty string or a null pointer, the comment\n *          message is removed from the object.\n *\n *          Comments should be relatively short, null-terminated, ASCII strings.\n *\n *          Comments can be attached to any object that has an object header,\n *          e.g., datasets, groups, and named datatypes, but not symbolic links.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Gset_comment(hid_t loc_id, const char *name, const char *comment);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Retrieves comment for specified object\n *\n * \\fgdt_loc_id\n * \\param[in] name Name of the object whose comment is to be set or reset\n *                 name must be \\TText{'.'} (dot) if \\p loc_id fully specifies\n *                 the object for which the comment is to be set.\n * \\param[in] bufsize Maximum number of comment characters to be returned in \\p buf.\n * \\param[out] buf The comment\n *\n * \\return Returns the number of characters in the comment, counting the \\c NULL\n *         terminator, if successful; the value returned may be larger than\n *         \\p bufsize. Otherwise returns a negative value.\n *\n * \\deprecated This function is deprecated in favor of the function\n *             H5Oget_comment().\n *\n * \\details H5Gget_comment() retrieves the comment for the object specified\n *          by \\p loc_id and \\p name. The comment is returned in the buffer \\p\n *          buf.\n *\n *          \\p loc_id can specify any object in the file. name can be one of the\n *          following:\n *          \\li The name of the object relative to \\p loc_id\n *          \\li An absolute name of the object, starting from \\c /, the file's\n *              root group\n *          \\li A dot (\\c .), if \\p loc_id fully specifies the object\n *\n *          \\details_namelen{comment,H5Gget_comment}\n *\n *          If an object does not have a comment, the empty string is returned\n *          in comment.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.0.0\n *\n */\nH5_DLL int H5Gget_comment(hid_t loc_id, const char *name, size_t bufsize, char *buf);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Iterates over the entries of a group invoking a callback for each\n *        entry encountered\n *\n * \\fg_loc_id\n * \\param[in] name Group over which the iteration is performed\n * \\param[in,out] idx Location at which to begin the iteration\n * \\param[in] op Operation to be performed on an object at each step of the\n *               iteration\n * \\param[in,out] op_data Data associated with the operation\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated in favor of the function\n *             H5Literate1().\n *\n * \\details H5Giterate() iterates over the members of name in the file or group\n *          specified with \\p loc_id. For each object in the group, the \\p\n *          op_data and some additional information, specified below, are passed\n *          to the operator function. The iteration begins with the \\p idx\n *          object in the group and the next element to be processed by the\n *          operator is returned in \\p idx. If \\p idx is NULL, then the iterator\n *          starts at the first group member; since no stopping point is\n *          returned in this case, the iterator cannot be restarted if one of\n *          the calls to its operator returns non-zero. H5Giterate() does not\n *          recursively follow links into subgroups of the specified group.\n *\n *          The prototype for \\ref H5G_iterate_t is:\n *          \\snippet this H5G_iterate_t_snip\n *\n *          The operation receives the group identifier for the group being\n *          iterated over, \\p group, the name of the current object within\n *          the group, \\p name, and the pointer to the operator data\n *          passed into H5Giterate(), \\p op_data.\n *\n *          The return values from an operator are:\n *          \\li Zero causes the iterator to continue, returning zero when all\n *              group members have been processed.\n *          \\li Positive causes the iterator to immediately return that positive\n *              value, indicating short-circuit success. The iterator can be\n *              restarted at the next group member.\n *          \\li Negative causes the iterator to immediately return that value,\n *              indicating failure. The iterator can be restarted at the next\n *              group member.\n *\n *          H5Giterate() assumes that the membership of the group identified by\n *          \\p name remains unchanged through the iteration. If the membership\n *          changes during the iteration, the function's behavior is undefined.\n *\n *          H5Giterate() is not recursive. In particular, if a member of \\p name\n *          is found to be a group, call it \\c subgroup_a, H5Giterate() does not\n *          examine the members of \\c subgroup_a. When recursive iteration is\n *          required, the application must handle the recursion, explicitly\n *          calling H5Giterate() on discovered subgroups.\n *\n * \\warning  Adding or removing members to the group during iteration\n *           will lead to undefined behavior.\n *\n * \\callback_note\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Giterate(hid_t loc_id, const char *name, int *idx, H5G_iterate_t op, void *op_data);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Returns number of objects in the group specified by its identifier\n *\n * \\fg_loc_id\n * \\param[out] num_objs Number of objects in the group\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated in favor of the function H5Gget_info().\n *\n * \\details H5Gget_num_objs() returns number of objects in a group. Group is\n *          specified by its identifier \\p loc_id. If a file identifier is\n *          passed in, then the number of objects in the root group is returned.\n *\n * \\version 1.8.0 Function deprecated in this release.\n *\n * \\since 1.6.0\n *\n */\nH5_DLL herr_t H5Gget_num_objs(hid_t loc_id, hsize_t *num_objs);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Returns information about an object.\n *\n * \\fgdt_loc_id\n * \\param[in] name Name of the object for which status is being sought\n * \\param[in] follow_link Link flag\n * \\param[out] statbuf Buffer in which to return information about the object\n *\n * \\return \\herr_t\n *\n * \\deprecated This function is deprecated in favor of the functions H5Oget_info()\n *             and H5Lget_info1().\n *\n * \\details H5Gget_objinfo() returns information about the specified object\n *          through the \\p statbuf argument.\n *\n *          A file or group identifier, \\p loc_id, and an object name, \\p name,\n *          relative to \\p loc_id, are commonly used to specify the\n *          object. However, if the object identifier is already known to the\n *          application, an alternative approach is to use that identifier, \\c\n *          obj_id, in place of \\p loc_id, and a dot (\\c .) in place of \\p\n *          name. Thus, the alternative versions of the first portion of an\n *          H5Gget_objinfo() call would be as follows:\n *          \\code\n *          H5Gget_objinfo (loc_id name  ...)\n *          H5Gget_objinfo (obj_id .     ...)\n *          \\endcode\n *\n *          If the object is a symbolic link and follow_link is zero (0), then\n *          the information returned describes the link itself; otherwise the\n *          link is followed and the information returned describes the object\n *          to which the link points. If \\p follow_link is non-zero but the\n *          final symbolic link is dangling (does not point to anything), then\n *          an error is returned. The \\p statbuf fields are undefined for an\n *          error. The existence of an object can be tested by calling this\n *          function with a \\c NULL \\p statbuf.\n *\n *          H5Gget_objinfo() fills in the following data structure (defined in\n *          H5Gpublic.h):\n *          \\snippet this H5G_stat_t_snip\n *\n *          where \\ref H5O_stat_t (defined in H5Opublic.h) is:\n *          \\snippet H5Opublic.h H5O_stat_t_snip\n *\n * \\attention Some systems will be able to record the time accurately but unable\n *            to retrieve the correct time; such systems (e.g., Irix64) will\n *            report an \\c mtime value of 0 (zero).\n *\n * \\version 1.8.0 Function deprecated in this release.\n * \\version 1.6.1 Two new fields were added to the \\ref H5G_stat_t struct in\n *                this release.\n *\n * \\since 1.0.0\n *\n */\nH5_DLL herr_t H5Gget_objinfo(hid_t loc_id, const char *name, bool follow_link, H5G_stat_t *statbuf /*out*/);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Returns the name of an object specified by an index\n *\n * \\fg_loc_id\n * \\param[in] idx Transient index identifying object\n * \\param[out] name Pointer to user-provided buffer the object name\n * \\param[in] size Name length\n *\n * \\return Returns the size of the object name if successful, or 0 if no name is\n *         associated with the group identifier. Otherwise returns a negative\n *         value.\n *\n * \\deprecated This function is deprecated in favor of the function H5Lget_name_by_idx().\n *\n * \\details H5Gget_objname_by_idx() returns the name of the object specified by\n *          the index \\p idx in the group \\p loc_id.\n *\n *          The group is specified by a group identifier \\p loc_id. If\n *          preferred, a file identifier may be passed in \\p loc_id; that file's\n *          root group will be assumed.\n *\n *          \\p idx is the transient index used to iterate through the objects in\n *          the group. The value of \\p idx is any nonnegative number less than\n *          the total number of objects in the group, which is returned by the\n *          function H5Gget_num_objs(). Note that this is a transient index; an\n *          object may have a different index each time a group is opened.\n *\n *          The object name is returned in the user-specified buffer \\p name.\n *\n *          If the size of the provided buffer \\p name is less or equal the\n *          actual object name length, the object name is truncated to\n *          \\TText{max_size - 1} characters.\n *\n *          Note that if the size of the object's name is unknown, a preliminary\n *          call to H5Gget_objname_by_idx() with \\p name set to \\c NULL will\n *          return the length of the object's name. A second call to\n *          H5Gget_objname_by_idx() can then be used to retrieve the actual\n *          name.\n *\n * \\version 1.8.0 Function deprecated in this release.\n * \\since 1.6.0\n *\n */\nH5_DLL ssize_t H5Gget_objname_by_idx(hid_t loc_id, hsize_t idx, char *name, size_t size);\n/**\n *-------------------------------------------------------------------------\n * \\ingroup H5G\n *\n * \\brief Returns the type of an object specified by an index\n *\n * \\fg_loc_id\n * \\param[in] idx Transient index identifying object\n *\n * \\return Returns the type of the object if successful. Otherwise returns a\n *         negative value.\n *\n * \\deprecated This function is deprecated in favor of the function H5Oget_info().\n *\n * \\details H5Gget_objtype_by_idx() returns the type of the object specified by\n *          the index \\p idx in the group \\p loc_id.\n *\n *          The group is specified by a group identifier \\p loc_id. If\n *          preferred, a file identifier may be passed in \\p loc_id; that file's\n *          root group will be assumed.\n *\n *          \\p idx is the transient index used to iterate through the objects in\n *          the group. This parameter is described in more detail in the\n *          discussion of H5Gget_objname_by_idx().\n *\n * \\note    As of 1.12.0, H5Gget_objtype_by_idx() returns the type of the object\n *          that the link points to, but it has been deprecated for H5Oget_info().\n *          Previous behavior for this function returned H5G_LINK for any link type.\n *          To get the link type, an application may use H5Lget_info_by_idx()\n *          instead.\n *\n * \\version 1.8.0 Function deprecated in this release.\n * \\version 1.6.0 The function return type changed from \\c int to the enumerated\n *                type \\ref H5G_obj_t.\n * \\since 1.6.0\n *\n */\nH5_DLL H5G_obj_t H5Gget_objtype_by_idx(hid_t loc_id, hsize_t idx);\n\n#endif /* H5_NO_DEPRECATED_SYMBOLS */\n\n#ifdef __cplusplus\n}\n#endif\n#endif /* H5Gpublic_H */\n","numLines":1218,"startLine":1,"totalLines":1218}}}
