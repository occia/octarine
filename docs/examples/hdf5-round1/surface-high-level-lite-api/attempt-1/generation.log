{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01EkCTCz76HxWiohFVWC1uCM","type":"tool_result","content":"1\t/* Copyright 2023 Google LLC\n2\tLicensed under the Apache License, Version 2.0 (the \"License\");\n3\tyou may not use this file except in compliance with the License.\n4\tYou may obtain a copy of the License at\n5\t      http://www.apache.org/licenses/LICENSE-2.0\n6\tUnless required by applicable law or agreed to in writing, software\n7\tdistributed under the License is distributed on an \"AS IS\" BASIS,\n8\tWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\n9\tSee the License for the specific language governing permissions and\n10\tlimitations under the License.\n11\t*/\n12\t\n13\t#include \"hdf5.h\"\n14\t\n15\t#include <unistd.h>\n16\t\n17\textern int LLVMFuzzerTestOneInput(const uint8_t *data, size_t size)\n18\t{\n19\t    // Some old logic with regards to skipping first byte. Leaving it here\n20\t    // to avoid affecting the clusterfuzz-generated corpus.\n21\t    if (size == 0) {\n22\t        return 0;\n23\t    }\n24\t    uint8_t decider = data[0];\n25\t    size -= 1;\n26\t    data += 1;\n27\t\n28\t    char filename[256];\n29\t    sprintf(filename, \"/tmp/libfuzzer.%d\", getpid());\n30\t\n31\t    FILE *fp = fopen(filename, \"wb\");\n32\t    if (!fp) {\n33\t        return 0;\n34\t    }\n35\t    fwrite(data, size, 1, fp);\n36\t    fclose(fp);\n37\t\n38\t    hid_t fuzz_h5_id = H5Fopen(filename, H5F_ACC_RDWR, H5P_DEFAULT);\n39\t    if (fuzz_h5_id != H5I_INVALID_HID) {\n40\t        H5Fclose(fuzz_h5_id);\n41\t    }\n42\t\n43\t    return 0;\n44\t}\n45\t"}]},"parent_tool_use_id":null,"session_id":"78b03bfe-9de1-460b-8747-2e452ecc1588","uuid":"f83d0e01-a0de-4abf-bf6e-7da3b8e1433e","timestamp":"2026-06-06T19:36:46.583Z","tool_use_result":{"type":"text","file":{"filePath":"/work/harness-proj/fuzz-proj/h5_read_fuzzer.c","content":"/* Copyright 2023 Google LLC\nLicensed under the Apache License, Version 2.0 (the \"License\");\nyou may not use this file except in compliance with the License.\nYou may obtain a copy of the License at\n      http://www.apache.org/licenses/LICENSE-2.0\nUnless required by applicable law or agreed to in writing, software\ndistributed under the License is distributed on an \"AS IS\" BASIS,\nWITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.\nSee the License for the specific language governing permissions and\nlimitations under the License.\n*/\n\n#include \"hdf5.h\"\n\n#include <unistd.h>\n\nextern int LLVMFuzzerTestOneInput(const uint8_t *data, size_t size)\n{\n    // Some old logic with regards to skipping first byte. Leaving it here\n    // to avoid affecting the clusterfuzz-generated corpus.\n    if (size == 0) {\n        return 0;\n    }\n    uint8_t decider = data[0];\n    size -= 1;\n    data += 1;\n\n    char filename[256];\n    sprintf(filename, \"/tmp/libfuzzer.%d\", getpid());\n\n    FILE *fp = fopen(filename, \"wb\");\n    if (!fp) {\n        return 0;\n    }\n    fwrite(data, size, 1, fp);\n    fclose(fp);\n\n    hid_t fuzz_h5_id = H5Fopen(filename, H5F_ACC_RDWR, H5P_DEFAULT);\n    if (fuzz_h5_id != H5I_INVALID_HID) {\n        H5Fclose(fuzz_h5_id);\n    }\n\n    return 0;\n}\n","numLines":45,"startLine":1,"totalLines":45}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Vc5A4bdsDcbrc9BNPwChQ2","type":"tool_result","content":"1\t/* * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * *\n2\t * Copyright by The HDF Group.                                               *\n3\t * All rights reserved.                                                      *\n4\t *                                                                           *\n5\t * This file is part of HDF5.  The full HDF5 copyright notice, including     *\n6\t * terms governing use, modification, and redistribution, is contained in    *\n7\t * the LICENSE file, which can be found at the root of the source code       *\n8\t * distribution tree, or in https://www.hdfgroup.org/licenses.               *\n9\t * If you do not have access to either file, you may request a copy from     *\n10\t * help@hdfgroup.org.                                                        *\n11\t * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * */\n12\t\n13\t#ifndef H5LTpublic_H\n14\t#define H5LTpublic_H\n15\t\n16\t/* Flag definitions for H5LTopen_file_image() */\n17\t#define H5LT_FILE_IMAGE_OPEN_RW   0x0001 /* Open image for read-write */\n18\t#define H5LT_FILE_IMAGE_DONT_COPY 0x0002 /* The HDF5 lib won't copy   */\n19\t/* user supplied image buffer. The same image is open with the core driver.  */\n20\t#define H5LT_FILE_IMAGE_DONT_RELEASE 0x0004 /* The HDF5 lib won't        */\n21\t/* deallocate user supplied image buffer. The user application is responsible */\n22\t/* for doing so.                                                             */\n23\t#define H5LT_FILE_IMAGE_ALL 0x0007\n24\t\n25\ttypedef enum H5LT_lang_t {\n26\t    H5LT_LANG_ERR = -1, /*this is the first*/\n27\t    H5LT_DDL      = 0,  /*for DDL*/\n28\t    H5LT_C        = 1,  /*for C*/\n29\t    H5LT_FORTRAN  = 2,  /*for Fortran*/\n30\t    H5LT_NO_LANG  = 3   /*this is the last*/\n31\t} H5LT_lang_t;\n32\t\n33\t#ifdef __cplusplus\n34\textern \"C\" {\n35\t#endif\n36\t\n37\t/** \\page H5LT_UG HDF5 High Level Lite\n38\t *\n39\t * Navigate back: \\ref index \"Main\" / \\ref UG\n40\t * <hr>\n41\t *\n42\t * \\section sec_hl_lite_api HDF5 Lite APIs\n43\t *\n44\t * \\subsection subsec_hl_lite_intro Introduction\n45\t *\n46\t * The HDF5 Lite API (H5LT) provides simplified functions for common HDF5 operations, combining\n47\t * multiple low-level calls into single high-level functions. This reduces code complexity and\n48\t * makes HDF5 more accessible for straightforward data storage tasks.\n49\t *\n50\t * @see H5LT Reference Manual\n51\t *\n52\t * \\subsection subsec_hl_lite_dataset Dataset Operations\n53\t *\n54\t * Create and access datasets with single function calls using type-specific functions like\n55\t * #H5LTmake_dataset_int, #H5LTmake_dataset_float, #H5LTread_dataset_int, etc. Query dataset\n56\t * properties with #H5LTget_dataset_ndims, #H5LTget_dataset_info, and #H5LTfind_dataset.\n57\t *\n58\t * \\subsection subsec_hl_lite_attr Attribute Operations\n59\t *\n60\t * Set and read attributes using type-specific functions such as #H5LTset_attribute_int,\n61\t * #H5LTset_attribute_string, #H5LTget_attribute_int, etc. Query attribute information\n62\t * with #H5LTget_attribute_ndims and #H5LTget_attribute_info.\n63\t *\n64\t * \\subsection subsec_hl_lite_util Utility Functions\n65\t *\n66\t * Convert between datatypes and text representations using #H5LTtext_to_dtype and #H5LTdtype_to_text.\n67\t * Validate paths with #H5LTpath_valid, and work with file images using #H5LTopen_file_image.\n68\t *\n69\t * Previous Chapter \\ref sec_hl_images - Next Chapter \\ref sec_hl_table_api\n70\t *\n71\t * <hr>\n72\t * Navigate back: \\ref index \"Main\" / \\ref UG\n73\t */\n74\t\n75\t/**\\defgroup H5LT HDF5 Lite APIs (H5LT,H5LD)\n76\t * <em>Functions used to simplify creating and manipulating datasets,\n77\t * attributes and other features (H5LT, H5LD)</em>\n78\t *\n79\t * The HDF5 Lite API consists of higher-level functions which do\n80\t * more operations per call than the basic HDF5 interface.\n81\t * The purpose is to wrap intuitive functions around certain sets\n82\t * of features in the existing APIs.\n83\t * It has the following sets of functions listed below.\n84\t *\n85\t * \\note \\Bold{Programming hints:}\n86\t * \\note To use any of these functions or subroutines,\n87\t *       you must first include the relevant include file (C) or\n88\t *       module (Fortran) in your application.\n89\t * \\note The following line includes the HDF5 Lite package, H5LT,\n90\t *       in C applications:\n91\t *       \\code #include \"hdf5_hl.h\" \\endcode\n92\t * \\note This line includes the H5LT module in Fortran applications:\n93\t *       \\code use h5lt \\endcode\n94\t *\n95\t * <table>\n96\t * <tr valign=\"top\"><td style=\"border: none;\">\n97\t *\n98\t * - Dataset Functions\n99\t *   - Make dataset functions\n100\t *      - \\ref H5LTmake_dataset\n101\t *      - \\ref H5LTmake_dataset_char\n102\t *      - \\ref H5LTmake_dataset_short\n103\t *      - \\ref H5LTmake_dataset_int\n104\t *      - \\ref H5LTmake_dataset_long\n105\t *      - \\ref H5LTmake_dataset_float\n106\t *      - \\ref H5LTmake_dataset_double\n107\t *      - \\ref H5LTmake_dataset_string\n108\t *\n109\t *   - Read dataset functions\n110\t *      - \\ref H5LTread_dataset\n111\t *      - \\ref H5LTread_dataset_char\n112\t *      - \\ref H5LTread_dataset_short\n113\t *      - \\ref H5LTread_dataset_int\n114\t *      - \\ref H5LTread_dataset_long\n115\t *      - \\ref H5LTread_dataset_float\n116\t *      - \\ref H5LTread_dataset_double\n117\t *      - \\ref H5LTread_dataset_string\n118\t *\n119\t *   - Query dataset functions\n120\t *      - \\ref H5LTfind_dataset\n121\t *      - \\ref H5LTget_dataset_ndims\n122\t *      - \\ref H5LTget_dataset_info\n123\t *\n124\t *   - Dataset watch functions\n125\t *      - \\ref H5LDget_dset_dims\n126\t *      - \\ref H5LDget_dset_elmts\n127\t *      - \\ref H5LDget_dset_type_size\n128\t *\n129\t * </td><td style=\"border: none;\">\n130\t *\n131\t * - Attribute Functions\n132\t *   - Set attribute functions\n133\t *      - \\ref H5LTset_attribute_string\n134\t *      - \\ref H5LTset_attribute_char\n135\t *      - \\ref H5LTset_attribute_uchar\n136\t *      - \\ref H5LTset_attribute_short\n137\t *      - \\ref H5LTset_attribute_ushort\n138\t *      - \\ref H5LTset_attribute_int\n139\t *      - \\ref H5LTset_attribute_uint\n140\t *      - \\ref H5LTset_attribute_long\n141\t *      - \\ref H5LTset_attribute_long_long\n142\t *      - \\ref H5LTset_attribute_ulong\n143\t *      - \\ref H5LTset_attribute_ullong\n144\t *      - \\ref H5LTset_attribute_float\n145\t *      - \\ref H5LTset_attribute_double\n146\t *      - <code>H5LTset_attribute_f</code> (fortran ONLY)\n147\t *\n148\t *   - Get attribute functions\n149\t *      - \\ref H5LTget_attribute\n150\t *      - \\ref H5LTget_attribute_string\n151\t *      - \\ref H5LTget_attribute_char\n152\t *      - \\ref H5LTget_attribute_uchar\n153\t *      - \\ref H5LTget_attribute_short\n154\t *      - \\ref H5LTget_attribute_ushort\n155\t *      - \\ref H5LTget_attribute_int\n156\t *      - \\ref H5LTget_attribute_uint\n157\t *      - \\ref H5LTget_attribute_long\n158\t *      - \\ref H5LTget_attribute_long_long\n159\t *      - \\ref H5LTget_attribute_ulong\n160\t *      - \\ref H5LTget_attribute_ullong\n161\t *      - \\ref H5LTget_attribute_float\n162\t *      - \\ref H5LTget_attribute_double\n163\t *\n164\t *   - Query attribute functions\n165\t *      - \\ref H5LTfind_attribute\n166\t *      - \\ref H5LTget_attribute_info\n167\t *      - \\ref H5LTget_attribute_ndims\n168\t *\n169\t * </td><td style=\"border: none;\">\n170\t *\n171\t * - Datatype Functions\n172\t *   - Datatype translation functions\n173\t *      - \\ref H5LTtext_to_dtype\n174\t *      - \\ref H5LTdtype_to_text\n175\t *\n176\t * - File image function\n177\t *   - Open file image function\n178\t *      - \\ref H5LTopen_file_image\n179\t *\n180\t * - Path and object function\n181\t *   - Query path and object function\n182\t *      - \\ref H5LTpath_valid\n183\t *\n184\t * </td></tr>\n185\t * </table>\n186\t *\n187\t */\n188\t\n189\t/*-------------------------------------------------------------------------\n190\t *\n191\t * Make dataset functions\n192\t *\n193\t *-------------------------------------------------------------------------\n194\t */\n195\t\n196\t/**\n197\t *-------------------------------------------------------------------------\n198\t * \\ingroup H5LT\n199\t *\n200\t * \\brief Creates and writes a dataset of a type \\p type_id.\n201\t *\n202\t * \\fg_loc_id\n203\t * \\param[in] dset_name The Name of the dataset to create\n204\t * \\param[in] rank      Number of dimensions of dataspace\n205\t * \\param[in] dims      An array of the size of each dimension\n206\t * \\param[in] type_id   Identifier of the datatype to use when creating the dataset\n207\t * \\param[in] buffer    Buffer with data to be written to the dataset\n208\t *\n209\t * \\return \\herr_t\n210\t *\n211\t * \\details H5LTmake_dataset() creates and writes a dataset named\n212\t *          \\p dset_name attached to the object specified by the\n213\t *          identifier \\p loc_id.\n214\t *\n215\t *          The parameter \\p type_id can be any valid HDF5 Prdefined \\ref PDTNAT;\n216\t *          For example, setting \\p type_id to #H5T_NATIVE_INT will result in a dataset\n217\t *          of <em>signed \\e integer datatype</em>.\n218\t *\n219\t * \\version 1.10.0 Fortran 2003 subroutine added to accept a C address of the data buffer.\n220\t * \\version 1.8.7 Fortran subroutine modified in this release to accommodate arrays\n221\t *                with more than three dimensions.\n222\t *\n223\t */\n224\tH5HL_DLL herr_t H5LTmake_dataset(hid_t loc_id, const char *dset_name, int rank, const hsize_t *dims,\n225\t                                 hid_t type_id, const void *buffer);\n226\t\n227\t/**\n228\t *-------------------------------------------------------------------------\n229\t * \\ingroup H5LT\n230\t *\n231\t * \\brief Creates and writes a dataset.\n232\t *\n233\t * \\fg_loc_id\n234\t * \\param[in] dset_name The Name of the dataset to create\n235\t * \\param[in] rank      Number of dimensions of dataspace\n236\t * \\param[in] dims      An array of the size of each dimension\n237\t * \\param[in] buffer    Buffer with data to be written to the dataset\n238\t *\n239\t * \\return \\herr_t\n240\t *\n241\t * \\details H5LTmake_dataset_char() creates and writes a dataset\n242\t *          named \\p dset_name attached to the object specified by\n243\t *          the identifier \\p loc_id.\n244\t *\n245\t *          The dataset's datatype will be \\e character, #H5T_NATIVE_CHAR.\n246\t *\n247\t */\n248\tH5HL_DLL herr_t H5LTmake_dataset_char(hid_t loc_id, const char *dset_name, int rank, const hsize_t *dims,\n249\t                                      const char *buffer);\n250\t\n251\t/**\n252\t *-------------------------------------------------------------------------\n253\t * \\ingroup H5LT\n254\t *\n255\t * \\brief Creates and writes a dataset.\n256\t *\n257\t * \\fg_loc_id\n258\t * \\param[in] dset_name The Name of the dataset to create\n259\t * \\param[in] rank      Number of dimensions of dataspace\n260\t * \\param[in] dims      An array of the size of each dimension\n261\t * \\param[in] buffer    Buffer with data to be written to the dataset\n262\t *\n263\t * \\return \\herr_t\n264\t *\n265\t * \\details H5LTmake_dataset_short() creates and writes a dataset\n266\t *          named \\p dset_name attached to the object specified by\n267\t *          the identifier \\p loc_id.\n268\t *\n269\t *          The dataset's datatype will be <em>short signed integer</em>,\n270\t *          #H5T_NATIVE_SHORT.\n271\t *\n272\t */\n273\tH5HL_DLL herr_t H5LTmake_dataset_short(hid_t loc_id, const char *dset_name, int rank, const hsize_t *dims,\n274\t                                       const short *buffer);\n275\t\n276\t/**\n277\t *-------------------------------------------------------------------------\n278\t * \\ingroup H5LT\n279\t *\n280\t * \\brief Creates and writes a dataset.\n281\t *\n282\t * \\fg_loc_id\n283\t * \\param[in] dset_name The Name of the dataset to create\n284\t * \\param[in] rank      Number of dimensions of dataspace\n285\t * \\param[in] dims      An array of the size of each dimension\n286\t * \\param[in] buffer    Buffer with data to be written to the dataset\n287\t *\n288\t * \\return \\herr_t\n289\t *\n290\t * \\details H5LTmake_dataset_int() creates and writes a dataset\n291\t *          named \\p dset_name attached to the object specified by\n292\t *          the identifier \\p loc_id.\n293\t *\n294\t *          The dataset's datatype will be <em>native signed integer</em>,\n295\t *          #H5T_NATIVE_INT.\n296\t *\n297\t * \\version Fortran subroutine modified in this release to accommodate\n298\t *          arrays with more than three dimensions.\n299\t *\n300\t */\n301\tH5HL_DLL herr_t H5LTmake_dataset_int(hid_t loc_id, const char *dset_name, int rank, const hsize_t *dims,\n302\t                                     const int *buffer);\n303\t\n304\t/**\n305\t *-------------------------------------------------------------------------\n306\t * \\ingroup H5LT\n307\t *\n308\t * \\brief Creates and writes a dataset.\n309\t *\n310\t * \\fg_loc_id\n311\t * \\param[in] dset_name The Name of the dataset to create\n312\t * \\param[in] rank      Number of dimensions of dataspace\n313\t * \\param[in] dims      An array of the size of each dimension\n314\t * \\param[in] buffer    Buffer with data to be written to the dataset\n315\t *\n316\t * \\return \\herr_t\n317\t *\n318\t * \\details H5LTmake_dataset_long() creates and writes a dataset\n319\t *          named \\p dset_name attached to the object specified by\n320\t *          the identifier \\p loc_id.\n321\t *\n322\t *          The dataset's datatype will be <em>long signed integer</em>,\n323\t *          #H5T_NATIVE_LONG.\n324\t *\n325\t */\n326\tH5HL_DLL herr_t H5LTmake_dataset_long(hid_t loc_id, const char *dset_name, int rank, const hsize_t *dims,\n327\t                                      const long *buffer);\n328\t\n329\t/**\n330\t *-------------------------------------------------------------------------\n331\t * \\ingroup H5LT\n332\t *\n333\t * \\brief Creates and writes a dataset.\n334\t *\n335\t * \\fg_loc_id\n336\t * \\param[in] dset_name The Name of the dataset to create\n337\t * \\param[in] rank      Number of dimensions of dataspace\n338\t * \\param[in] dims      An array of the size of each dimension\n339\t * \\param[in] buffer    Buffer with data to be written to the dataset\n340\t *\n341\t * \\return \\herr_t\n342\t *\n343\t * \\details H5LTmake_dataset_float() creates and writes a dataset\n344\t *          named \\p dset_name attached to the object specified by\n345\t *          the identifier \\p loc_id.\n346\t *\n347\t *          The dataset's datatype will be <em>native floating point</em>,\n348\t *          #H5T_NATIVE_FLOAT.\n349\t *\n350\t * \\version 1.8.7 Fortran subroutine modified in this release to accommodate\n351\t *                arrays with more than three dimensions.\n352\t *\n353\t */\n354\tH5HL_DLL herr_t H5LTmake_dataset_float(hid_t loc_id, const char *dset_name, int rank, const hsize_t *dims,\n355\t                                       const float *buffer);\n356\t\n357\t/**\n358\t *-------------------------------------------------------------------------\n359\t * \\ingroup H5LT\n360\t *\n361\t * \\brief Creates and writes a dataset.\n362\t *\n363\t * \\fg_loc_id\n364\t * \\param[in] dset_name The Name of the dataset to create\n365\t * \\param[in] rank      Number of dimensions of dataspace\n366\t * \\param[in] dims      An array of the size of each dimension\n367\t * \\param[in] buffer    Buffer with data to be written to the dataset\n368\t *\n369\t * \\return \\herr_t\n370\t *\n371\t * \\details H5LTmake_dataset_double() creates and writes a dataset\n372\t *          named \\p dset_name attached to the object specified by\n373\t *          the identifier \\p loc_id.\n374\t *\n375\t *          The dataset's datatype will be\n376\t *          <em>native floating-point double</em>, #H5T_NATIVE_DOUBLE.\n377\t *\n378\t * \\version 1.8.7 Fortran subroutine modified in this release to accommodate\n379\t *                arrays with more than three dimensions.\n380\t *\n381\t */\n382\tH5HL_DLL herr_t H5LTmake_dataset_double(hid_t loc_id, const char *dset_name, int rank, const hsize_t *dims,\n383\t                                        const double *buffer);\n384\t\n385\t/**\n386\t *-------------------------------------------------------------------------\n387\t * \\ingroup H5LT\n388\t *\n389\t * \\brief Creates and writes a dataset with string datatype.\n390\t *\n391\t * \\fg_loc_id\n392\t * \\param[in] dset_name The name of the dataset to create\n393\t * \\param[in] buf       Buffer with data to be written to the dataset\n394\t *\n395\t * \\return \\herr_t\n396\t *\n397\t * \\details H5LTmake_dataset_string() creates and writes a dataset\n398\t *          named \\p dset_name attached to the object specified by\n399\t *          the identifier \\p loc_id.\n400\t *\n401\t *          The dataset's datatype will be <em>C string</em>, #H5T_C_S1.\n402\t *\n403\t */\n404\tH5HL_DLL herr_t H5LTmake_dataset_string(hid_t loc_id, const char *dset_name, const char *buf);\n405\t\n406\t/*-------------------------------------------------------------------------\n407\t *\n408\t * Read dataset functions\n409\t *\n410\t *-------------------------------------------------------------------------\n411\t */\n412\t\n413\t/**\n414\t *-------------------------------------------------------------------------\n415\t * \\ingroup H5LT\n416\t *\n417\t * \\brief Reads a dataset from disk.\n418\t *\n419\t * \\fg_loc_id\n420\t * \\param[in] dset_name The name of the dataset to read\n421\t * \\param[in] type_id   Identifier of the datatype to use when reading\n422\t *                      the dataset\n423\t * \\param[out] buffer   Buffer with data\n424\t *\n425\t * \\return \\herr_t\n426\t *\n427\t * \\details H5LTread_dataset() reads a dataset named \\p dset_name\n428\t *          attached to the object specified by the identifier \\p loc_id.\n429\t *\n430\t * \\version 1.10.0  Fortran 2003 subroutine added to accept a C\n431\t *                  address of the data buffer.\n432\t * \\version 1.8.7   Fortran subroutine modified in this release to\n433\t *                  accommodate arrays with more than three dimensions.\n434\t *\n435\t */\n436\tH5HL_DLL herr_t H5LTread_dataset(hid_t loc_id, const char *dset_name, hid_t type_id, void *buffer);\n437\t\n438\t/**\n439\t *-------------------------------------------------------------------------\n440\t * \\ingroup H5LT\n441\t *\n442\t * \\brief Reads a dataset from disk.\n443\t *\n444\t * \\fg_loc_id\n445\t * \\param[in] dset_name The name of the dataset to read\n446\t * \\param[out] buffer   Buffer with data\n447\t *\n448\t * \\return \\herr_t\n449\t *\n450\t * \\details H5LTread_dataset_char() reads a dataset named \\p dset_name\n451\t *          attached to the object specified by the identifier \\p loc_id.\n452\t *          The HDF5 datatype is #H5T_NATIVE_CHAR.\n453\t *\n454\t */\n455\tH5HL_DLL herr_t H5LTread_dataset_char(hid_t loc_id, const char *dset_name, char *buffer);\n456\t\n457\t/**\n458\t *-------------------------------------------------------------------------\n459\t * \\ingroup H5LT\n460\t *\n461\t * \\brief Reads a dataset from disk.\n462\t *\n463\t * \\fg_loc_id\n464\t * \\param[in] dset_name The name of the dataset to read\n465\t * \\param[out] buffer   Buffer with data\n466\t *\n467\t * \\return \\herr_t\n468\t *\n469\t * \\details H5LTread_dataset_short() reads a dataset named \\p dset_name\n470\t *          attached to the object specified by the identifier \\p loc_id.\n471\t *          The HDF5 datatype is #H5T_NATIVE_SHORT.\n472\t *\n473\t */\n474\tH5HL_DLL herr_t H5LTread_dataset_short(hid_t loc_id, const char *dset_name, short *buffer);\n475\t\n476\t/**\n477\t *-------------------------------------------------------------------------\n478\t * \\ingroup H5LT\n479\t *\n480\t * \\brief Reads a dataset from disk.\n481\t *\n482\t * \\fg_loc_id\n483\t * \\param[in] dset_name The name of the dataset to read\n484\t * \\param[out] buffer   Buffer with data\n485\t *\n486\t * \\return \\herr_t\n487\t *\n488\t * \\details H5LTread_dataset_int() reads a dataset named \\p dset_name\n489\t *          attached to the object specified by the identifier \\p loc_id.\n490\t *          The HDF5 datatype is #H5T_NATIVE_INT.\n491\t *\n492\t * \\version 1.8.7 Fortran subroutine modified in this release to\n493\t *                accommodate arrays with more than three dimensions.\n494\t *\n495\t */\n496\tH5HL_DLL herr_t H5LTread_dataset_int(hid_t loc_id, const char *dset_name, int *buffer);\n497\t\n498\t/**\n499\t *-------------------------------------------------------------------------\n500\t * \\ingroup H5LT\n501\t *\n502\t * \\brief Reads a dataset from disk.\n503\t *\n504\t * \\fg_loc_id\n505\t * \\param[in] dset_name The name of the dataset to read\n506\t * \\param[out] buffer   Buffer with data\n507\t *\n508\t * \\return \\herr_t\n509\t *\n510\t * \\details H5LTread_dataset_long() reads a dataset named \\p dset_name\n511\t *          attached to the object specified by the identifier \\p loc_id.\n512\t *          The HDF5 datatype is #H5T_NATIVE_LONG.\n513\t *\n514\t */\n515\tH5HL_DLL herr_t H5LTread_dataset_long(hid_t loc_id, const char *dset_name, long *buffer);\n516\t\n517\t/**\n518\t *-------------------------------------------------------------------------\n519\t * \\ingroup H5LT\n520\t *\n521\t * \\brief Reads a dataset from disk.\n522\t *\n523\t * \\fg_loc_id\n524\t * \\param[in] dset_name The name of the dataset to read\n525\t * \\param[out] buffer   Buffer with data\n526\t *\n527\t * \\return \\herr_t\n528\t *\n529\t * \\details H5LTread_dataset_float() reads a dataset named \\p dset_name\n530\t *          attached to the object specified by the identifier \\p loc_id.\n531\t *          The HDF5 datatype is #H5T_NATIVE_FLOAT.\n532\t *\n533\t * \\version 1.8.7 Fortran subroutine modified in this release to\n534\t *                accommodate arrays with more than three dimensions.\n535\t */\n536\tH5HL_DLL herr_t H5LTread_dataset_float(hid_t loc_id, const char *dset_name, float *buffer);\n537\t\n538\t/**\n539\t *-------------------------------------------------------------------------\n540\t * \\ingroup H5LT\n541\t *\n542\t * \\brief Reads a dataset from disk.\n543\t *\n544\t * \\fg_loc_id\n545\t * \\param[in] dset_name The name of the dataset to read\n546\t * \\param[out] buffer   Buffer with data\n547\t *\n548\t * \\return \\herr_t\n549\t *\n550\t * \\details H5LTread_dataset_double() reads a dataset named \\p dset_name\n551\t *          attached to the object specified by the identifier \\p loc_id.\n552\t *          The HDF5 datatype is #H5T_NATIVE_DOUBLE.\n553\t *\n554\t * \\version 1.8.7 Fortran subroutine modified in this release to\n555\t *                accommodate arrays with more than three dimensions.\n556\t */\n557\tH5HL_DLL herr_t H5LTread_dataset_double(hid_t loc_id, const char *dset_name, double *buffer);\n558\t\n559\t/**\n560\t *-------------------------------------------------------------------------\n561\t * \\ingroup H5LT\n562\t *\n563\t * \\brief Reads a dataset from disk.\n564\t *\n565\t * \\fg_loc_id\n566\t * \\param[in] dset_name The name of the dataset to read\n567\t * \\param[out] buf      Buffer with data\n568\t *\n569\t * \\return \\herr_t\n570\t *\n571\t * \\details H5LTread_dataset_string() reads a dataset named \\p dset_name\n572\t *          attached to the object specified by the identifier \\p loc_id.\n573\t *          The HDF5 datatype is #H5T_C_S1.\n574\t *\n575\t */\n576\tH5HL_DLL herr_t H5LTread_dataset_string(hid_t loc_id, const char *dset_name, char *buf);\n577\t\n578\t/*-------------------------------------------------------------------------\n579\t *\n580\t * Query dataset functions\n581\t *\n582\t *-------------------------------------------------------------------------\n583\t */\n584\t\n585\t/**\n586\t *-------------------------------------------------------------------------\n587\t * \\ingroup H5LT\n588\t *\n589\t * \\brief Gets the dimensionality of a dataset\n590\t *\n591\t * \\param[in]   loc_id      Identifier of the object to\n592\t *                          locate the dataset within\n593\t * \\param[in]   dset_name   The dataset name\n594\t * \\param[out]  rank        The dimensionality of the dataset\n595\t *\n596\t * \\return \\herr_t\n597\t *\n598\t * \\details H5LTget_dataset_ndims() gets the dimensionality of a dataset\n599\t *          named \\p dset_name exists attached to the object \\p loc_id.\n600\t *\n601\t */\n602\tH5HL_DLL herr_t H5LTget_dataset_ndims(hid_t loc_id, const char *dset_name, int *rank);\n603\t\n604\t/**\n605\t *-------------------------------------------------------------------------\n606\t * \\ingroup H5LT\n607\t *\n608\t * \\brief Retrieves information about a dataset\n609\t *\n610\t * \\param[in]   loc_id      Identifier of the object to locate\n611\t *                          the dataset within\n612\t * \\param[in]   dset_name   The dataset name\n613\t * \\param[out]  dims        The dimensions of the dataset\n614\t * \\param[out]  type_class  The class identifier. #H5T_class_t is defined in\n615\t *                          H5Tpublic.h. See H5Tget_class() for a list\n616\t *                          of class types.\n617\t * \\param[out]  type_size   The size of the datatype in bytes\n618\t *\n619\t * \\return \\herr_t\n620\t *\n621\t * \\details H5LTget_dataset_info() retrieves information about a dataset\n622\t *          named \\p dset_name attached to the object \\p loc_id.\n623\t *\n624\t */\n625\tH5HL_DLL herr_t H5LTget_dataset_info(hid_t loc_id, const char *dset_name, hsize_t *dims,\n626\t                                     H5T_class_t *type_class, size_t *type_size);\n627\t\n628\t/**\n629\t *-------------------------------------------------------------------------\n630\t * \\ingroup H5LT\n631\t *\n632\t * \\brief Determines whether a dataset exists.\n633\t *\n634\t * \\param[in]   loc_id  Identifier of the group containing the dataset\n635\t * \\param[in]   name    Dataset name\n636\t *\n637\t * \\return \\htri_t\n638\t *\n639\t * \\details H5LTfind_dataset() determines whether a dataset named\n640\t *          \\p name exists in the group specified by \\p loc_id.\n641\t *\n642\t *          \\p loc_id must be a group identifier and \\p name must\n643\t *          specify a dataset that is a member of that group.\n644\t *\n645\t */\n646\tH5HL_DLL herr_t H5LTfind_dataset(hid_t loc_id, const char *name);\n647\t\n648\t/*-------------------------------------------------------------------------\n649\t *\n650\t * Set attribute functions\n651\t *\n652\t *-------------------------------------------------------------------------\n653\t */\n654\t\n655\t/**\n656\t *-------------------------------------------------------------------------\n657\t * \\ingroup H5LT\n658\t *\n659\t * \\brief Creates and writes a string attribute.\n660\t *\n661\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n662\t *                          to create the attribute within\n663\t * \\param[in]   obj_name    The name of the object to attach the attribute\n664\t * \\param[in]   attr_name   The attribute name\n665\t * \\param[in]   attr_data   Buffer with data to be written to the attribute\n666\t *\n667\t * \\return \\herr_t\n668\t *\n669\t * \\details H5LTset_attribute_string() creates and writes a string attribute\n670\t *          named \\p attr_name and attaches it to the object specified by\n671\t *          the name \\p obj_name. If the attribute already exists,\n672\t *          it is overwritten.\n673\t *\n674\t */\n675\tH5HL_DLL herr_t H5LTset_attribute_string(hid_t loc_id, const char *obj_name, const char *attr_name,\n676\t                                         const char *attr_data);\n677\t\n678\t/**\n679\t *-------------------------------------------------------------------------\n680\t * \\ingroup H5LT\n681\t *\n682\t * \\brief Creates and writes an attribute.\n683\t *\n684\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n685\t *                          to create the attribute within\n686\t * \\param[in]   obj_name    The name of the object to attach the attribute\n687\t * \\param[in]   attr_name   The attribute name\n688\t * \\param[in]   buffer      Buffer with data to be written to the attribute\n689\t * \\param[in]   size        The size of the 1D array (one in the case of a\n690\t *                          scalar attribute). This value is used by\n691\t *                          H5Screate_simple() to create the dataspace.\n692\t *\n693\t * \\return \\herr_t\n694\t *\n695\t * \\details H5LTset_attribute_char() creates and writes a numerical attribute\n696\t *          named \\p attr_name and attaches it to the object specified by the\n697\t *          name \\p obj_name. The attribute has a dimensionality of 1.\n698\t *          The HDF5 datatype of the attribute is #H5T_NATIVE_CHAR.\n699\t *\n700\t */\n701\tH5HL_DLL herr_t H5LTset_attribute_char(hid_t loc_id, const char *obj_name, const char *attr_name,\n702\t                                       const char *buffer, size_t size);\n703\t\n704\t/**\n705\t *-------------------------------------------------------------------------\n706\t * \\ingroup H5LT\n707\t *\n708\t * \\brief Creates and writes an attribute.\n709\t *\n710\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n711\t *                          to create the attribute within\n712\t * \\param[in]   obj_name    The name of the object to attach the attribute\n713\t * \\param[in]   attr_name   The attribute name\n714\t * \\param[in]   buffer      Buffer with data to be written to the attribute\n715\t * \\param[in]   size        The size of the 1D array (one in the case of a\n716\t *                          scalar attribute). This value is used by\n717\t *                          H5Screate_simple() to create the dataspace.\n718\t *\n719\t * \\return \\herr_t\n720\t *\n721\t * \\details H5LTset_attribute_uchar() creates and writes a numerical attribute\n722\t *          named \\p attr_name and attaches it to the object specified by the\n723\t *          name \\p obj_name. The attribute has a dimensionality of 1.\n724\t *          The HDF5 datatype of the attribute is #H5T_NATIVE_UCHAR.\n725\t *\n726\t */\n727\tH5HL_DLL herr_t H5LTset_attribute_uchar(hid_t loc_id, const char *obj_name, const char *attr_name,\n728\t                                        const unsigned char *buffer, size_t size);\n729\t\n730\t/**\n731\t *-------------------------------------------------------------------------\n732\t * \\ingroup H5LT\n733\t *\n734\t * \\brief Creates and writes an attribute.\n735\t *\n736\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n737\t *                          to create the attribute within\n738\t * \\param[in]   obj_name    The name of the object to attach the attribute\n739\t * \\param[in]   attr_name   The attribute name\n740\t * \\param[in]   buffer      Buffer with data to be written to the attribute\n741\t * \\param[in]   size        The size of the 1D array (one in the case of a\n742\t *                          scalar attribute). This value is used by\n743\t *                          H5Screate_simple() to create the dataspace.\n744\t *\n745\t * \\return \\herr_t\n746\t *\n747\t * \\details H5LTset_attribute_short() creates and writes a numerical attribute\n748\t *          named \\p attr_name and attaches it to the object specified by the\n749\t *          name \\p obj_name. The attribute has a dimensionality of 1.\n750\t *          The HDF5 datatype of the attribute is #H5T_NATIVE_SHORT.\n751\t *\n752\t */\n753\tH5HL_DLL herr_t H5LTset_attribute_short(hid_t loc_id, const char *obj_name, const char *attr_name,\n754\t                                        const short *buffer, size_t size);\n755\t\n756\t/**\n757\t *-------------------------------------------------------------------------\n758\t * \\ingroup H5LT\n759\t *\n760\t * \\brief Creates and writes an attribute.\n761\t *\n762\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n763\t *                          to create the attribute within\n764\t * \\param[in]   obj_name    The name of the object to attach the attribute\n765\t * \\param[in]   attr_name   The attribute name\n766\t * \\param[in]   buffer      Buffer with data to be written to the attribute\n767\t * \\param[in]   size        The size of the 1D array (one in the case of a\n768\t *                          scalar attribute). This value is used by\n769\t *                          H5Screate_simple() to create the dataspace.\n770\t *\n771\t * \\return \\herr_t\n772\t *\n773\t * \\details H5LTset_attribute_ushort() creates and writes a numerical attribute\n774\t *          named \\p attr_name and attaches it to the object specified by the\n775\t *          name \\p obj_name. The attribute has a dimensionality of 1.\n776\t *          The HDF5 datatype of the attribute is #H5T_NATIVE_USHORT.\n777\t *\n778\t */\n779\tH5HL_DLL herr_t H5LTset_attribute_ushort(hid_t loc_id, const char *obj_name, const char *attr_name,\n780\t                                         const unsigned short *buffer, size_t size);\n781\t\n782\t/**\n783\t *-------------------------------------------------------------------------\n784\t * \\ingroup H5LT\n785\t *\n786\t * \\brief Creates and writes an attribute.\n787\t *\n788\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n789\t *                          to create the attribute within\n790\t * \\param[in]   obj_name    The name of the object to attach the attribute\n791\t * \\param[in]   attr_name   The attribute name\n792\t * \\param[in]   buffer      Buffer with data to be written to the attribute\n793\t * \\param[in]   size        The size of the 1D array (one in the case of a\n794\t *                          scalar attribute). This value is used by\n795\t *                          H5Screate_simple() to create the dataspace.\n796\t *\n797\t * \\return \\herr_t\n798\t *\n799\t * \\details H5LTset_attribute_int() creates and writes a numerical integer\n800\t *          attribute named \\p attr_name and attaches it to the object\n801\t *          specified by the name \\p obj_name. The attribute has a\n802\t *          dimensionality of 1.  The HDF5 datatype of the attribute\n803\t *          is #H5T_NATIVE_INT.\n804\t *\n805\t */\n806\tH5HL_DLL herr_t H5LTset_attribute_int(hid_t loc_id, const char *obj_name, const char *attr_name,\n807\t                                      const int *buffer, size_t size);\n808\t\n809\t/**\n810\t *-------------------------------------------------------------------------\n811\t * \\ingroup H5LT\n812\t *\n813\t * \\brief Creates and writes an attribute.\n814\t *\n815\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n816\t *                          to create the attribute within\n817\t * \\param[in]   obj_name    The name of the object to attach the attribute\n818\t * \\param[in]   attr_name   The attribute name\n819\t * \\param[in]   buffer      Buffer with data to be written to the attribute\n820\t * \\param[in]   size        The size of the 1D array (one in the case of a\n821\t *                          scalar attribute). This value is used by\n822\t *                          H5Screate_simple() to create the dataspace.\n823\t *\n824\t * \\return \\herr_t\n825\t *\n826\t * \\details H5LTset_attribute_uint() creates and writes a numerical integer\n827\t *          attribute named \\p attr_name and attaches it to the object specified\n828\t *          by the name \\p obj_name. The attribute has a dimensionality of 1.\n829\t *          The HDF5 datatype of the attribute is #H5T_NATIVE_UINT.\n830\t *\n831\t */\n832\tH5HL_DLL herr_t H5LTset_attribute_uint(hid_t loc_id, const char *obj_name, const char *attr_name,\n833\t                                       const unsigned int *buffer, size_t size);\n834\t\n835\t/**\n836\t *-------------------------------------------------------------------------\n837\t * \\ingroup H5LT\n838\t *\n839\t * \\brief Creates and writes an attribute.\n840\t *\n841\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n842\t *                          to create the attribute within\n843\t * \\param[in]   obj_name    The name of the object to attach the attribute\n844\t * \\param[in]   attr_name   The attribute name\n845\t * \\param[in]   buffer      Buffer with data to be written to the attribute\n846\t * \\param[in]   size        The size of the 1D array (one in the case of a\n847\t *                          scalar attribute). This value is used by\n848\t *                          H5Screate_simple() to create the dataspace.\n849\t *\n850\t * \\return \\herr_t\n851\t *\n852\t * \\details H5LTset_attribute_long() creates and writes a numerical\n853\t *          attribute named \\p attr_name and attaches it to the object\n854\t *          specified by the name \\p obj_name. The attribute has a\n855\t *          dimensionality of 1.  The HDF5 datatype of the attribute\n856\t *          is #H5T_NATIVE_LONG.\n857\t *\n858\t */\n859\tH5HL_DLL herr_t H5LTset_attribute_long(hid_t loc_id, const char *obj_name, const char *attr_name,\n860\t                                       const long *buffer, size_t size);\n861\t\n862\t/**\n863\t *-------------------------------------------------------------------------\n864\t * \\ingroup H5LT\n865\t *\n866\t * \\brief Creates and writes an attribute.\n867\t *\n868\t * \\param[in]   loc_id      Location of the object to which the attribute\n869\t *                          is to be attached\n870\t * \\param[in]   obj_name    That object's name\n871\t * \\param[in]   attr_name   Attribute name\n872\t * \\param[in]   buffer      Attribute value\n873\t * \\param[in]   size        Attribute size\n874\t *\n875\t * \\return \\herr_t\n876\t *\n877\t * \\details H5LTset_attribute_long_long() creates and writes a numerical\n878\t *          attribute named \\p attr_name and attaches it to the object\n879\t *          specified by the name \\p obj_name.\n880\t *\n881\t *          The attribute has a dimensionality of 1 and its HDF5 datatype\n882\t *          is #H5T_NATIVE_LLONG.\n883\t *\n884\t */\n885\tH5HL_DLL herr_t H5LTset_attribute_long_long(hid_t loc_id, const char *obj_name, const char *attr_name,\n886\t                                            const long long *buffer, size_t size);\n887\t\n888\t/**\n889\t *-------------------------------------------------------------------------\n890\t * \\ingroup H5LT\n891\t *\n892\t * \\brief Creates and writes an attribute.\n893\t *\n894\t * \\param[in]   loc_id      Identifier of the object (dataset or group)\n895\t *                          to create the attribute within\n896\t * \\param[in]   obj_name    The name of the object to attach the attribute\n897\t * \\param[in]   attr_name   The attribute name\n898\t * \\param[in]   buffer      Buffer with data to be written to the attribute\n899\t * \\param[in]   size        The size of the 1D array (one in the case of a\n900\t *                          scalar attribute). This value is used by\n901\t *                          H5Screate_simple() to create the dataspace.\n902\t *\n903\t * \\return \\herr_t\n904\t *\n905\t * \\details H5LTset_attribute_ulong() creates and writes a numerical\n906\t *          attribute named \\p attr_name and attaches it to the object\n907\t *   